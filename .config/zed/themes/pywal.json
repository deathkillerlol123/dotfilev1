{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0a0a1890",
                "editor.background": "#0a0a1890",
                "editor.foreground": "#c1c1c5",
                "text": "#c1c1c5",
                "text.muted": "#c1c1c570",
                "text.ignored": "#c1c1c540",
                "text.placeholder": "#c1c1c550",
                "ignored": "#c1c1c530",
                "element.hover": "#c1c1c530",
                "ghost_element.hover": "#8F347130",
                "ghost_element.selected": "#8F347130",
                "ghost_element.active": "#8F347160",
                "border": "#0a0a18",
                "editor.highlighted_line.background": "#8F347110",
                "editor.active_line.background": "#8F347110",
                "panel.background": "#0a0a1890",
                "title_bar.background": "#0a0a1890",
                "title_bar.inactive_background": "#0a0a1890",
                "status_bar.background": "#0a0a1890",
                "drop_target.background": "#0a0a1890",
                "elevated_surface.background": "#0a0a18",
                "toolbar.background": "#0a0a1890",
                "tab_bar.background": "#0a0a1890",
                "tab.inactive_background": "#0a0a1890",
                "tab.active_background": "#8F347130",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0a0a18",
                "scrollbar.thumb.background": "#8F3471",
                "editor.gutter.background": "#0a0a1890",
                "terminal.background": "#0a0a1810",
                "terminal.foreground": "#c1c1c5",
                "terminal.dim_foreground": "#c1c1c5",
                "terminal.bright_foreground": "#c1c1c5",
                "terminal.ansi.black": "#0a0a18",
                "terminal.ansi.red": "#8F3471",
                "terminal.ansi.green": "#AD4C76",
                "terminal.ansi.yellow": "#C85678",
                "terminal.ansi.blue": "#352983",
                "terminal.ansi.magenta": "#663784",
                "terminal.ansi.cyan": "#A23D8A",
                "terminal.ansi.white": "#c1c1c5",
                "terminal.ansi.bright_black": "#59596d",
                "terminal.ansi.bright_red": "#8F3471",
                "terminal.ansi.bright_green": "#AD4C76",
                "terminal.ansi.bright_yellow": "#C85678",
                "terminal.ansi.bright_blue": "#352983",
                "terminal.ansi.bright_magenta": "#663784",
                "terminal.ansi.bright_cyan": "#A23D8A",
                "terminal.ansi.bright_white": "#c1c1c5",
                "modified": "#8F3471",
                "syntax": {
                    "attribute": {
                        "color": "#8F3471"
                    },
                    "boolean": {
                      "color": "#AD4C76"
                    },
                    "comment": {
                      "color": "#59596d"
                    },
                    "comment.doc": {
                      "color": "#59596d"
                    },
                    "constant": {
                      "color": "#AD4C76"
                    },
                    "function": {
                      "color": "#A23D8A"
                    },
                    "keyword": {
                      "color": "#352983"
                    },
                    "number": {
                      "color": "#663784"
                    },
                    "operator": {
                      "color": "#352983"
                    },
                    "string": {
                      "color": "#8F3471"
                    },
                    "variable": {
                      "color": "#AD4C76"
                    }
                },
                "players": [
                  {
                    "cursor": "#8F3471",
                    "background": "#0a0a18",
                    "selection": "#8F347130"
                  }
                ]
            }
        }
    ]
}
