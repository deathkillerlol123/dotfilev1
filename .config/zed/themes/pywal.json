{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0d0d1f90",
                "editor.background": "#0d0d1f90",
                "editor.foreground": "#c2c2c7",
                "text": "#c2c2c7",
                "text.muted": "#c2c2c770",
                "text.ignored": "#c2c2c740",
                "text.placeholder": "#c2c2c750",
                "ignored": "#c2c2c730",
                "element.hover": "#c2c2c730",
                "ghost_element.hover": "#64677D30",
                "ghost_element.selected": "#64677D30",
                "ghost_element.active": "#64677D60",
                "border": "#0d0d1f",
                "editor.highlighted_line.background": "#64677D10",
                "editor.active_line.background": "#64677D10",
                "panel.background": "#0d0d1f90",
                "title_bar.background": "#0d0d1f90",
                "title_bar.inactive_background": "#0d0d1f90",
                "status_bar.background": "#0d0d1f90",
                "drop_target.background": "#0d0d1f90",
                "elevated_surface.background": "#0d0d1f",
                "toolbar.background": "#0d0d1f90",
                "tab_bar.background": "#0d0d1f90",
                "tab.inactive_background": "#0d0d1f90",
                "tab.active_background": "#64677D30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0d0d1f",
                "scrollbar.thumb.background": "#64677D",
                "editor.gutter.background": "#0d0d1f90",
                "terminal.background": "#0d0d1f10",
                "terminal.foreground": "#c2c2c7",
                "terminal.dim_foreground": "#c2c2c7",
                "terminal.bright_foreground": "#c2c2c7",
                "terminal.ansi.black": "#0d0d1f",
                "terminal.ansi.red": "#64677D",
                "terminal.ansi.green": "#6D7087",
                "terminal.ansi.yellow": "#887C91",
                "terminal.ansi.blue": "#968EA9",
                "terminal.ansi.magenta": "#C3ABBA",
                "terminal.ansi.cyan": "#D5DAAE",
                "terminal.ansi.white": "#c2c2c7",
                "terminal.ansi.bright_black": "#5c5c71",
                "terminal.ansi.bright_red": "#64677D",
                "terminal.ansi.bright_green": "#6D7087",
                "terminal.ansi.bright_yellow": "#887C91",
                "terminal.ansi.bright_blue": "#968EA9",
                "terminal.ansi.bright_magenta": "#C3ABBA",
                "terminal.ansi.bright_cyan": "#D5DAAE",
                "terminal.ansi.bright_white": "#c2c2c7",
                "modified": "#64677D",
                "syntax": {
                    "attribute": {
                        "color": "#64677D"
                    },
                    "boolean": {
                      "color": "#6D7087"
                    },
                    "comment": {
                      "color": "#5c5c71"
                    },
                    "comment.doc": {
                      "color": "#5c5c71"
                    },
                    "constant": {
                      "color": "#6D7087"
                    },
                    "function": {
                      "color": "#D5DAAE"
                    },
                    "keyword": {
                      "color": "#968EA9"
                    },
                    "number": {
                      "color": "#C3ABBA"
                    },
                    "operator": {
                      "color": "#968EA9"
                    },
                    "string": {
                      "color": "#64677D"
                    },
                    "variable": {
                      "color": "#6D7087"
                    }
                },
                "players": [
                  {
                    "cursor": "#64677D",
                    "background": "#0d0d1f",
                    "selection": "#64677D30"
                  }
                ]
            }
        }
    ]
}
