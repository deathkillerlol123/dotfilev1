{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#1b1e2090",
                "editor.background": "#1b1e2090",
                "editor.foreground": "#c6c6c7",
                "text": "#c6c6c7",
                "text.muted": "#c6c6c770",
                "text.ignored": "#c6c6c740",
                "text.placeholder": "#c6c6c750",
                "ignored": "#c6c6c730",
                "element.hover": "#c6c6c730",
                "ghost_element.hover": "#528A7A30",
                "ghost_element.selected": "#528A7A30",
                "ghost_element.active": "#528A7A60",
                "border": "#1b1e20",
                "editor.highlighted_line.background": "#528A7A10",
                "editor.active_line.background": "#528A7A10",
                "panel.background": "#1b1e2090",
                "title_bar.background": "#1b1e2090",
                "title_bar.inactive_background": "#1b1e2090",
                "status_bar.background": "#1b1e2090",
                "drop_target.background": "#1b1e2090",
                "elevated_surface.background": "#1b1e20",
                "toolbar.background": "#1b1e2090",
                "tab_bar.background": "#1b1e2090",
                "tab.inactive_background": "#1b1e2090",
                "tab.active_background": "#528A7A30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#1b1e20",
                "scrollbar.thumb.background": "#528A7A",
                "editor.gutter.background": "#1b1e2090",
                "terminal.background": "#1b1e2010",
                "terminal.foreground": "#c6c6c7",
                "terminal.dim_foreground": "#c6c6c7",
                "terminal.bright_foreground": "#c6c6c7",
                "terminal.ansi.black": "#1b1e20",
                "terminal.ansi.red": "#528A7A",
                "terminal.ansi.green": "#4F6D84",
                "terminal.ansi.yellow": "#787A81",
                "terminal.ansi.blue": "#748B8A",
                "terminal.ansi.magenta": "#609183",
                "terminal.ansi.cyan": "#8E8E8A",
                "terminal.ansi.white": "#c6c6c7",
                "terminal.ansi.bright_black": "#616b76",
                "terminal.ansi.bright_red": "#528A7A",
                "terminal.ansi.bright_green": "#4F6D84",
                "terminal.ansi.bright_yellow": "#787A81",
                "terminal.ansi.bright_blue": "#748B8A",
                "terminal.ansi.bright_magenta": "#609183",
                "terminal.ansi.bright_cyan": "#8E8E8A",
                "terminal.ansi.bright_white": "#c6c6c7",
                "modified": "#528A7A",
                "syntax": {
                    "attribute": {
                        "color": "#528A7A"
                    },
                    "boolean": {
                      "color": "#4F6D84"
                    },
                    "comment": {
                      "color": "#616b76"
                    },
                    "comment.doc": {
                      "color": "#616b76"
                    },
                    "constant": {
                      "color": "#4F6D84"
                    },
                    "function": {
                      "color": "#8E8E8A"
                    },
                    "keyword": {
                      "color": "#748B8A"
                    },
                    "number": {
                      "color": "#609183"
                    },
                    "operator": {
                      "color": "#748B8A"
                    },
                    "string": {
                      "color": "#528A7A"
                    },
                    "variable": {
                      "color": "#4F6D84"
                    }
                },
                "players": [
                  {
                    "cursor": "#528A7A",
                    "background": "#1b1e20",
                    "selection": "#528A7A30"
                  }
                ]
            }
        }
    ]
}
