{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#17110a90",
                "editor.background": "#17110a90",
                "editor.foreground": "#c5c3c1",
                "text": "#c5c3c1",
                "text.muted": "#c5c3c170",
                "text.ignored": "#c5c3c140",
                "text.placeholder": "#c5c3c150",
                "ignored": "#c5c3c130",
                "element.hover": "#c5c3c130",
                "ghost_element.hover": "#B0493130",
                "ghost_element.selected": "#B0493130",
                "ghost_element.active": "#B0493160",
                "border": "#17110a",
                "editor.highlighted_line.background": "#B0493110",
                "editor.active_line.background": "#B0493110",
                "panel.background": "#17110a90",
                "title_bar.background": "#17110a90",
                "title_bar.inactive_background": "#17110a90",
                "status_bar.background": "#17110a90",
                "drop_target.background": "#17110a90",
                "elevated_surface.background": "#17110a",
                "toolbar.background": "#17110a90",
                "tab_bar.background": "#17110a90",
                "tab.inactive_background": "#17110a90",
                "tab.active_background": "#B0493130",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#17110a",
                "scrollbar.thumb.background": "#B04931",
                "editor.gutter.background": "#17110a90",
                "terminal.background": "#17110a10",
                "terminal.foreground": "#c5c3c1",
                "terminal.dim_foreground": "#c5c3c1",
                "terminal.bright_foreground": "#c5c3c1",
                "terminal.ansi.black": "#17110a",
                "terminal.ansi.red": "#B04931",
                "terminal.ansi.green": "#6A8677",
                "terminal.ansi.yellow": "#A19171",
                "terminal.ansi.blue": "#E19F64",
                "terminal.ansi.magenta": "#E7BB65",
                "terminal.ansi.cyan": "#5F958B",
                "terminal.ansi.white": "#c5c3c1",
                "terminal.ansi.bright_black": "#6d6459",
                "terminal.ansi.bright_red": "#B04931",
                "terminal.ansi.bright_green": "#6A8677",
                "terminal.ansi.bright_yellow": "#A19171",
                "terminal.ansi.bright_blue": "#E19F64",
                "terminal.ansi.bright_magenta": "#E7BB65",
                "terminal.ansi.bright_cyan": "#5F958B",
                "terminal.ansi.bright_white": "#c5c3c1",
                "modified": "#B04931",
                "syntax": {
                    "attribute": {
                        "color": "#B04931"
                    },
                    "boolean": {
                      "color": "#6A8677"
                    },
                    "comment": {
                      "color": "#6d6459"
                    },
                    "comment.doc": {
                      "color": "#6d6459"
                    },
                    "constant": {
                      "color": "#6A8677"
                    },
                    "function": {
                      "color": "#5F958B"
                    },
                    "keyword": {
                      "color": "#E19F64"
                    },
                    "number": {
                      "color": "#E7BB65"
                    },
                    "operator": {
                      "color": "#E19F64"
                    },
                    "string": {
                      "color": "#B04931"
                    },
                    "variable": {
                      "color": "#6A8677"
                    }
                },
                "players": [
                  {
                    "cursor": "#B04931",
                    "background": "#17110a",
                    "selection": "#B0493130"
                  }
                ]
            }
        }
    ]
}
