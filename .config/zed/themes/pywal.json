{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#05050d90",
                "editor.background": "#05050d90",
                "editor.foreground": "#c0c0c2",
                "text": "#c0c0c2",
                "text.muted": "#c0c0c270",
                "text.ignored": "#c0c0c240",
                "text.placeholder": "#c0c0c250",
                "ignored": "#c0c0c230",
                "element.hover": "#c0c0c230",
                "ghost_element.hover": "#44527A30",
                "ghost_element.selected": "#44527A30",
                "ghost_element.active": "#44527A60",
                "border": "#05050d",
                "editor.highlighted_line.background": "#44527A10",
                "editor.active_line.background": "#44527A10",
                "panel.background": "#05050d90",
                "title_bar.background": "#05050d90",
                "title_bar.inactive_background": "#05050d90",
                "status_bar.background": "#05050d90",
                "drop_target.background": "#05050d90",
                "elevated_surface.background": "#05050d",
                "toolbar.background": "#05050d90",
                "tab_bar.background": "#05050d90",
                "tab.inactive_background": "#05050d90",
                "tab.active_background": "#44527A30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#05050d",
                "scrollbar.thumb.background": "#44527A",
                "editor.gutter.background": "#05050d90",
                "terminal.background": "#05050d10",
                "terminal.foreground": "#c0c0c2",
                "terminal.dim_foreground": "#c0c0c2",
                "terminal.bright_foreground": "#c0c0c2",
                "terminal.ansi.black": "#05050d",
                "terminal.ansi.red": "#44527A",
                "terminal.ansi.green": "#4A5A87",
                "terminal.ansi.yellow": "#546796",
                "terminal.ansi.blue": "#5A71A3",
                "terminal.ansi.magenta": "#6176A5",
                "terminal.ansi.cyan": "#739EC3",
                "terminal.ansi.white": "#c0c0c2",
                "terminal.ansi.bright_black": "#555567",
                "terminal.ansi.bright_red": "#44527A",
                "terminal.ansi.bright_green": "#4A5A87",
                "terminal.ansi.bright_yellow": "#546796",
                "terminal.ansi.bright_blue": "#5A71A3",
                "terminal.ansi.bright_magenta": "#6176A5",
                "terminal.ansi.bright_cyan": "#739EC3",
                "terminal.ansi.bright_white": "#c0c0c2",
                "modified": "#44527A",
                "syntax": {
                    "attribute": {
                        "color": "#44527A"
                    },
                    "boolean": {
                      "color": "#4A5A87"
                    },
                    "comment": {
                      "color": "#555567"
                    },
                    "comment.doc": {
                      "color": "#555567"
                    },
                    "constant": {
                      "color": "#4A5A87"
                    },
                    "function": {
                      "color": "#739EC3"
                    },
                    "keyword": {
                      "color": "#5A71A3"
                    },
                    "number": {
                      "color": "#6176A5"
                    },
                    "operator": {
                      "color": "#5A71A3"
                    },
                    "string": {
                      "color": "#44527A"
                    },
                    "variable": {
                      "color": "#4A5A87"
                    }
                },
                "players": [
                  {
                    "cursor": "#44527A",
                    "background": "#05050d",
                    "selection": "#44527A30"
                  }
                ]
            }
        }
    ]
}
