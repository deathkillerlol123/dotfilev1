{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0d181f90",
                "editor.background": "#0d181f90",
                "editor.foreground": "#c2c5c7",
                "text": "#c2c5c7",
                "text.muted": "#c2c5c770",
                "text.ignored": "#c2c5c740",
                "text.placeholder": "#c2c5c750",
                "ignored": "#c2c5c730",
                "element.hover": "#c2c5c730",
                "ghost_element.hover": "#504A4930",
                "ghost_element.selected": "#504A4930",
                "ghost_element.active": "#504A4960",
                "border": "#0d181f",
                "editor.highlighted_line.background": "#504A4910",
                "editor.active_line.background": "#504A4910",
                "panel.background": "#0d181f90",
                "title_bar.background": "#0d181f90",
                "title_bar.inactive_background": "#0d181f90",
                "status_bar.background": "#0d181f90",
                "drop_target.background": "#0d181f90",
                "elevated_surface.background": "#0d181f",
                "toolbar.background": "#0d181f90",
                "tab_bar.background": "#0d181f90",
                "tab.inactive_background": "#0d181f90",
                "tab.active_background": "#504A4930",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0d181f",
                "scrollbar.thumb.background": "#504A49",
                "editor.gutter.background": "#0d181f90",
                "terminal.background": "#0d181f10",
                "terminal.foreground": "#c2c5c7",
                "terminal.dim_foreground": "#c2c5c7",
                "terminal.bright_foreground": "#c2c5c7",
                "terminal.ansi.black": "#0d181f",
                "terminal.ansi.red": "#504A49",
                "terminal.ansi.green": "#6C615D",
                "terminal.ansi.yellow": "#877770",
                "terminal.ansi.blue": "#95847B",
                "terminal.ansi.magenta": "#7E7C82",
                "terminal.ansi.cyan": "#A49893",
                "terminal.ansi.white": "#c2c5c7",
                "terminal.ansi.bright_black": "#5c6871",
                "terminal.ansi.bright_red": "#504A49",
                "terminal.ansi.bright_green": "#6C615D",
                "terminal.ansi.bright_yellow": "#877770",
                "terminal.ansi.bright_blue": "#95847B",
                "terminal.ansi.bright_magenta": "#7E7C82",
                "terminal.ansi.bright_cyan": "#A49893",
                "terminal.ansi.bright_white": "#c2c5c7",
                "modified": "#504A49",
                "syntax": {
                    "attribute": {
                        "color": "#504A49"
                    },
                    "boolean": {
                      "color": "#6C615D"
                    },
                    "comment": {
                      "color": "#5c6871"
                    },
                    "comment.doc": {
                      "color": "#5c6871"
                    },
                    "constant": {
                      "color": "#6C615D"
                    },
                    "function": {
                      "color": "#A49893"
                    },
                    "keyword": {
                      "color": "#95847B"
                    },
                    "number": {
                      "color": "#7E7C82"
                    },
                    "operator": {
                      "color": "#95847B"
                    },
                    "string": {
                      "color": "#504A49"
                    },
                    "variable": {
                      "color": "#6C615D"
                    }
                },
                "players": [
                  {
                    "cursor": "#504A49",
                    "background": "#0d181f",
                    "selection": "#504A4930"
                  }
                ]
            }
        }
    ]
}
