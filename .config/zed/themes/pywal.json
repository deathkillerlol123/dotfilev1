{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0d0c1d90",
                "editor.background": "#0d0c1d90",
                "editor.foreground": "#c2c2c6",
                "text": "#c2c2c6",
                "text.muted": "#c2c2c670",
                "text.ignored": "#c2c2c640",
                "text.placeholder": "#c2c2c650",
                "ignored": "#c2c2c630",
                "element.hover": "#c2c2c630",
                "ghost_element.hover": "#10199930",
                "ghost_element.selected": "#10199930",
                "ghost_element.active": "#10199960",
                "border": "#0d0c1d",
                "editor.highlighted_line.background": "#10199910",
                "editor.active_line.background": "#10199910",
                "panel.background": "#0d0c1d90",
                "title_bar.background": "#0d0c1d90",
                "title_bar.inactive_background": "#0d0c1d90",
                "status_bar.background": "#0d0c1d90",
                "drop_target.background": "#0d0c1d90",
                "elevated_surface.background": "#0d0c1d",
                "toolbar.background": "#0d0c1d90",
                "tab_bar.background": "#0d0c1d90",
                "tab.inactive_background": "#0d0c1d90",
                "tab.active_background": "#10199930",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0d0c1d",
                "scrollbar.thumb.background": "#101999",
                "editor.gutter.background": "#0d0c1d90",
                "terminal.background": "#0d0c1d10",
                "terminal.foreground": "#c2c2c6",
                "terminal.dim_foreground": "#c2c2c6",
                "terminal.bright_foreground": "#c2c2c6",
                "terminal.ansi.black": "#0d0c1d",
                "terminal.ansi.red": "#101999",
                "terminal.ansi.green": "#0858A3",
                "terminal.ansi.yellow": "#191FDA",
                "terminal.ansi.blue": "#5C1AC0",
                "terminal.ansi.magenta": "#0E5FDD",
                "terminal.ansi.cyan": "#B524CD",
                "terminal.ansi.white": "#c2c2c6",
                "terminal.ansi.bright_black": "#5c5c70",
                "terminal.ansi.bright_red": "#101999",
                "terminal.ansi.bright_green": "#0858A3",
                "terminal.ansi.bright_yellow": "#191FDA",
                "terminal.ansi.bright_blue": "#5C1AC0",
                "terminal.ansi.bright_magenta": "#0E5FDD",
                "terminal.ansi.bright_cyan": "#B524CD",
                "terminal.ansi.bright_white": "#c2c2c6",
                "modified": "#101999",
                "syntax": {
                    "attribute": {
                        "color": "#101999"
                    },
                    "boolean": {
                      "color": "#0858A3"
                    },
                    "comment": {
                      "color": "#5c5c70"
                    },
                    "comment.doc": {
                      "color": "#5c5c70"
                    },
                    "constant": {
                      "color": "#0858A3"
                    },
                    "function": {
                      "color": "#B524CD"
                    },
                    "keyword": {
                      "color": "#5C1AC0"
                    },
                    "number": {
                      "color": "#0E5FDD"
                    },
                    "operator": {
                      "color": "#5C1AC0"
                    },
                    "string": {
                      "color": "#101999"
                    },
                    "variable": {
                      "color": "#0858A3"
                    }
                },
                "players": [
                  {
                    "cursor": "#101999",
                    "background": "#0d0c1d",
                    "selection": "#10199930"
                  }
                ]
            }
        }
    ]
}
