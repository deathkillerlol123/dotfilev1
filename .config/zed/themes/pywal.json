{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0b050590",
                "editor.background": "#0b050590",
                "editor.foreground": "#c2c0c0",
                "text": "#c2c0c0",
                "text.muted": "#c2c0c070",
                "text.ignored": "#c2c0c040",
                "text.placeholder": "#c2c0c050",
                "ignored": "#c2c0c030",
                "element.hover": "#c2c0c030",
                "ghost_element.hover": "#17491A30",
                "ghost_element.selected": "#17491A30",
                "ghost_element.active": "#17491A60",
                "border": "#0b0505",
                "editor.highlighted_line.background": "#17491A10",
                "editor.active_line.background": "#17491A10",
                "panel.background": "#0b050590",
                "title_bar.background": "#0b050590",
                "title_bar.inactive_background": "#0b050590",
                "status_bar.background": "#0b050590",
                "drop_target.background": "#0b050590",
                "elevated_surface.background": "#0b0505",
                "toolbar.background": "#0b050590",
                "tab_bar.background": "#0b050590",
                "tab.inactive_background": "#0b050590",
                "tab.active_background": "#17491A30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0b0505",
                "scrollbar.thumb.background": "#17491A",
                "editor.gutter.background": "#0b050590",
                "terminal.background": "#0b050510",
                "terminal.foreground": "#c2c0c0",
                "terminal.dim_foreground": "#c2c0c0",
                "terminal.bright_foreground": "#c2c0c0",
                "terminal.ansi.black": "#0b0505",
                "terminal.ansi.red": "#17491A",
                "terminal.ansi.green": "#1B4826",
                "terminal.ansi.yellow": "#254C33",
                "terminal.ansi.blue": "#287038",
                "terminal.ansi.magenta": "#142E48",
                "terminal.ansi.cyan": "#2E5447",
                "terminal.ansi.white": "#c2c0c0",
                "terminal.ansi.bright_black": "#675454",
                "terminal.ansi.bright_red": "#17491A",
                "terminal.ansi.bright_green": "#1B4826",
                "terminal.ansi.bright_yellow": "#254C33",
                "terminal.ansi.bright_blue": "#287038",
                "terminal.ansi.bright_magenta": "#142E48",
                "terminal.ansi.bright_cyan": "#2E5447",
                "terminal.ansi.bright_white": "#c2c0c0",
                "modified": "#17491A",
                "syntax": {
                    "attribute": {
                        "color": "#17491A"
                    },
                    "boolean": {
                      "color": "#1B4826"
                    },
                    "comment": {
                      "color": "#675454"
                    },
                    "comment.doc": {
                      "color": "#675454"
                    },
                    "constant": {
                      "color": "#1B4826"
                    },
                    "function": {
                      "color": "#2E5447"
                    },
                    "keyword": {
                      "color": "#287038"
                    },
                    "number": {
                      "color": "#142E48"
                    },
                    "operator": {
                      "color": "#287038"
                    },
                    "string": {
                      "color": "#17491A"
                    },
                    "variable": {
                      "color": "#1B4826"
                    }
                },
                "players": [
                  {
                    "cursor": "#17491A",
                    "background": "#0b0505",
                    "selection": "#17491A30"
                  }
                ]
            }
        }
    ]
}
