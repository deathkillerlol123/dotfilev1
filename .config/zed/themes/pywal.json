{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#151b3190",
                "editor.background": "#151b3190",
                "editor.foreground": "#c4c6cb",
                "text": "#c4c6cb",
                "text.muted": "#c4c6cb70",
                "text.ignored": "#c4c6cb40",
                "text.placeholder": "#c4c6cb50",
                "ignored": "#c4c6cb30",
                "element.hover": "#c4c6cb30",
                "ghost_element.hover": "#59728B30",
                "ghost_element.selected": "#59728B30",
                "ghost_element.active": "#59728B60",
                "border": "#151b31",
                "editor.highlighted_line.background": "#59728B10",
                "editor.active_line.background": "#59728B10",
                "panel.background": "#151b3190",
                "title_bar.background": "#151b3190",
                "title_bar.inactive_background": "#151b3190",
                "status_bar.background": "#151b3190",
                "drop_target.background": "#151b3190",
                "elevated_surface.background": "#151b31",
                "toolbar.background": "#151b3190",
                "tab_bar.background": "#151b3190",
                "tab.inactive_background": "#151b3190",
                "tab.active_background": "#59728B30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#151b31",
                "scrollbar.thumb.background": "#59728B",
                "editor.gutter.background": "#151b3190",
                "terminal.background": "#151b3110",
                "terminal.foreground": "#c4c6cb",
                "terminal.dim_foreground": "#c4c6cb",
                "terminal.bright_foreground": "#c4c6cb",
                "terminal.ansi.black": "#151b31",
                "terminal.ansi.red": "#59728B",
                "terminal.ansi.green": "#738AA0",
                "terminal.ansi.yellow": "#558FC5",
                "terminal.ansi.blue": "#91A1B2",
                "terminal.ansi.magenta": "#A7B7C6",
                "terminal.ansi.cyan": "#B8C5D2",
                "terminal.ansi.white": "#c4c6cb",
                "terminal.ansi.bright_black": "#64697a",
                "terminal.ansi.bright_red": "#59728B",
                "terminal.ansi.bright_green": "#738AA0",
                "terminal.ansi.bright_yellow": "#558FC5",
                "terminal.ansi.bright_blue": "#91A1B2",
                "terminal.ansi.bright_magenta": "#A7B7C6",
                "terminal.ansi.bright_cyan": "#B8C5D2",
                "terminal.ansi.bright_white": "#c4c6cb",
                "modified": "#59728B",
                "syntax": {
                    "attribute": {
                        "color": "#59728B"
                    },
                    "boolean": {
                      "color": "#738AA0"
                    },
                    "comment": {
                      "color": "#64697a"
                    },
                    "comment.doc": {
                      "color": "#64697a"
                    },
                    "constant": {
                      "color": "#738AA0"
                    },
                    "function": {
                      "color": "#B8C5D2"
                    },
                    "keyword": {
                      "color": "#91A1B2"
                    },
                    "number": {
                      "color": "#A7B7C6"
                    },
                    "operator": {
                      "color": "#91A1B2"
                    },
                    "string": {
                      "color": "#59728B"
                    },
                    "variable": {
                      "color": "#738AA0"
                    }
                },
                "players": [
                  {
                    "cursor": "#59728B",
                    "background": "#151b31",
                    "selection": "#59728B30"
                  }
                ]
            }
        }
    ]
}
