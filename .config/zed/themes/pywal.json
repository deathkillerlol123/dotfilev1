{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#12121290",
                "editor.background": "#12121290",
                "editor.foreground": "#c3c3c3",
                "text": "#c3c3c3",
                "text.muted": "#c3c3c370",
                "text.ignored": "#c3c3c340",
                "text.placeholder": "#c3c3c350",
                "ignored": "#c3c3c330",
                "element.hover": "#c3c3c330",
                "ghost_element.hover": "#7C7C7C30",
                "ghost_element.selected": "#7C7C7C30",
                "ghost_element.active": "#7C7C7C60",
                "border": "#121212",
                "editor.highlighted_line.background": "#7C7C7C10",
                "editor.active_line.background": "#7C7C7C10",
                "panel.background": "#12121290",
                "title_bar.background": "#12121290",
                "title_bar.inactive_background": "#12121290",
                "status_bar.background": "#12121290",
                "drop_target.background": "#12121290",
                "elevated_surface.background": "#121212",
                "toolbar.background": "#12121290",
                "tab_bar.background": "#12121290",
                "tab.inactive_background": "#12121290",
                "tab.active_background": "#7C7C7C30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#121212",
                "scrollbar.thumb.background": "#7C7C7C",
                "editor.gutter.background": "#12121290",
                "terminal.background": "#12121210",
                "terminal.foreground": "#c3c3c3",
                "terminal.dim_foreground": "#c3c3c3",
                "terminal.bright_foreground": "#c3c3c3",
                "terminal.ansi.black": "#121212",
                "terminal.ansi.red": "#7C7C7C",
                "terminal.ansi.green": "#838383",
                "terminal.ansi.yellow": "#8B8B8B",
                "terminal.ansi.blue": "#979797",
                "terminal.ansi.magenta": "#A3A3A3",
                "terminal.ansi.cyan": "#ADADAD",
                "terminal.ansi.white": "#c3c3c3",
                "terminal.ansi.bright_black": "#6e5959",
                "terminal.ansi.bright_red": "#7C7C7C",
                "terminal.ansi.bright_green": "#838383",
                "terminal.ansi.bright_yellow": "#8B8B8B",
                "terminal.ansi.bright_blue": "#979797",
                "terminal.ansi.bright_magenta": "#A3A3A3",
                "terminal.ansi.bright_cyan": "#ADADAD",
                "terminal.ansi.bright_white": "#c3c3c3",
                "modified": "#7C7C7C",
                "syntax": {
                    "attribute": {
                        "color": "#7C7C7C"
                    },
                    "boolean": {
                      "color": "#838383"
                    },
                    "comment": {
                      "color": "#6e5959"
                    },
                    "comment.doc": {
                      "color": "#6e5959"
                    },
                    "constant": {
                      "color": "#838383"
                    },
                    "function": {
                      "color": "#ADADAD"
                    },
                    "keyword": {
                      "color": "#979797"
                    },
                    "number": {
                      "color": "#A3A3A3"
                    },
                    "operator": {
                      "color": "#979797"
                    },
                    "string": {
                      "color": "#7C7C7C"
                    },
                    "variable": {
                      "color": "#838383"
                    }
                },
                "players": [
                  {
                    "cursor": "#7C7C7C",
                    "background": "#121212",
                    "selection": "#7C7C7C30"
                  }
                ]
            }
        }
    ]
}
