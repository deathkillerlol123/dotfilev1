{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#140c1d90",
                "editor.background": "#140c1d90",
                "editor.foreground": "#c4c2c6",
                "text": "#c4c2c6",
                "text.muted": "#c4c2c670",
                "text.ignored": "#c4c2c640",
                "text.placeholder": "#c4c2c650",
                "ignored": "#c4c2c630",
                "element.hover": "#c4c2c630",
                "ghost_element.hover": "#4B3A6930",
                "ghost_element.selected": "#4B3A6930",
                "ghost_element.active": "#4B3A6960",
                "border": "#140c1d",
                "editor.highlighted_line.background": "#4B3A6910",
                "editor.active_line.background": "#4B3A6910",
                "panel.background": "#140c1d90",
                "title_bar.background": "#140c1d90",
                "title_bar.inactive_background": "#140c1d90",
                "status_bar.background": "#140c1d90",
                "drop_target.background": "#140c1d90",
                "elevated_surface.background": "#140c1d",
                "toolbar.background": "#140c1d90",
                "tab_bar.background": "#140c1d90",
                "tab.inactive_background": "#140c1d90",
                "tab.active_background": "#4B3A6930",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#140c1d",
                "scrollbar.thumb.background": "#4B3A69",
                "editor.gutter.background": "#140c1d90",
                "terminal.background": "#140c1d10",
                "terminal.foreground": "#c4c2c6",
                "terminal.dim_foreground": "#c4c2c6",
                "terminal.bright_foreground": "#c4c2c6",
                "terminal.ansi.black": "#140c1d",
                "terminal.ansi.red": "#4B3A69",
                "terminal.ansi.green": "#3C407A",
                "terminal.ansi.yellow": "#5C4576",
                "terminal.ansi.blue": "#83587B",
                "terminal.ansi.magenta": "#59599F",
                "terminal.ansi.cyan": "#665595",
                "terminal.ansi.white": "#c4c2c6",
                "terminal.ansi.bright_black": "#655c70",
                "terminal.ansi.bright_red": "#4B3A69",
                "terminal.ansi.bright_green": "#3C407A",
                "terminal.ansi.bright_yellow": "#5C4576",
                "terminal.ansi.bright_blue": "#83587B",
                "terminal.ansi.bright_magenta": "#59599F",
                "terminal.ansi.bright_cyan": "#665595",
                "terminal.ansi.bright_white": "#c4c2c6",
                "modified": "#4B3A69",
                "syntax": {
                    "attribute": {
                        "color": "#4B3A69"
                    },
                    "boolean": {
                      "color": "#3C407A"
                    },
                    "comment": {
                      "color": "#655c70"
                    },
                    "comment.doc": {
                      "color": "#655c70"
                    },
                    "constant": {
                      "color": "#3C407A"
                    },
                    "function": {
                      "color": "#665595"
                    },
                    "keyword": {
                      "color": "#83587B"
                    },
                    "number": {
                      "color": "#59599F"
                    },
                    "operator": {
                      "color": "#83587B"
                    },
                    "string": {
                      "color": "#4B3A69"
                    },
                    "variable": {
                      "color": "#3C407A"
                    }
                },
                "players": [
                  {
                    "cursor": "#4B3A69",
                    "background": "#140c1d",
                    "selection": "#4B3A6930"
                  }
                ]
            }
        }
    ]
}
