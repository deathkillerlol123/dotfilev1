{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0f0a1990",
                "editor.background": "#0f0a1990",
                "editor.foreground": "#c3c1c5",
                "text": "#c3c1c5",
                "text.muted": "#c3c1c570",
                "text.ignored": "#c3c1c540",
                "text.placeholder": "#c3c1c550",
                "ignored": "#c3c1c530",
                "element.hover": "#c3c1c530",
                "ghost_element.hover": "#4B135430",
                "ghost_element.selected": "#4B135430",
                "ghost_element.active": "#4B135460",
                "border": "#0f0a19",
                "editor.highlighted_line.background": "#4B135410",
                "editor.active_line.background": "#4B135410",
                "panel.background": "#0f0a1990",
                "title_bar.background": "#0f0a1990",
                "title_bar.inactive_background": "#0f0a1990",
                "status_bar.background": "#0f0a1990",
                "drop_target.background": "#0f0a1990",
                "elevated_surface.background": "#0f0a19",
                "toolbar.background": "#0f0a1990",
                "tab_bar.background": "#0f0a1990",
                "tab.inactive_background": "#0f0a1990",
                "tab.active_background": "#4B135430",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0f0a19",
                "scrollbar.thumb.background": "#4B1354",
                "editor.gutter.background": "#0f0a1990",
                "terminal.background": "#0f0a1910",
                "terminal.foreground": "#c3c1c5",
                "terminal.dim_foreground": "#c3c1c5",
                "terminal.bright_foreground": "#c3c1c5",
                "terminal.ansi.black": "#0f0a19",
                "terminal.ansi.red": "#4B1354",
                "terminal.ansi.green": "#5D1C68",
                "terminal.ansi.yellow": "#1D476C",
                "terminal.ansi.blue": "#1C2C95",
                "terminal.ansi.magenta": "#0B5499",
                "terminal.ansi.cyan": "#4241AF",
                "terminal.ansi.white": "#c3c1c5",
                "terminal.ansi.bright_black": "#61596e",
                "terminal.ansi.bright_red": "#4B1354",
                "terminal.ansi.bright_green": "#5D1C68",
                "terminal.ansi.bright_yellow": "#1D476C",
                "terminal.ansi.bright_blue": "#1C2C95",
                "terminal.ansi.bright_magenta": "#0B5499",
                "terminal.ansi.bright_cyan": "#4241AF",
                "terminal.ansi.bright_white": "#c3c1c5",
                "modified": "#4B1354",
                "syntax": {
                    "attribute": {
                        "color": "#4B1354"
                    },
                    "boolean": {
                      "color": "#5D1C68"
                    },
                    "comment": {
                      "color": "#61596e"
                    },
                    "comment.doc": {
                      "color": "#61596e"
                    },
                    "constant": {
                      "color": "#5D1C68"
                    },
                    "function": {
                      "color": "#4241AF"
                    },
                    "keyword": {
                      "color": "#1C2C95"
                    },
                    "number": {
                      "color": "#0B5499"
                    },
                    "operator": {
                      "color": "#1C2C95"
                    },
                    "string": {
                      "color": "#4B1354"
                    },
                    "variable": {
                      "color": "#5D1C68"
                    }
                },
                "players": [
                  {
                    "cursor": "#4B1354",
                    "background": "#0f0a19",
                    "selection": "#4B135430"
                  }
                ]
            }
        }
    ]
}
