{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0f091690",
                "editor.background": "#0f091690",
                "editor.foreground": "#c3c1c4",
                "text": "#c3c1c4",
                "text.muted": "#c3c1c470",
                "text.ignored": "#c3c1c440",
                "text.placeholder": "#c3c1c450",
                "ignored": "#c3c1c430",
                "element.hover": "#c3c1c430",
                "ghost_element.hover": "#27346630",
                "ghost_element.selected": "#27346630",
                "ghost_element.active": "#27346660",
                "border": "#0f0916",
                "editor.highlighted_line.background": "#27346610",
                "editor.active_line.background": "#27346610",
                "panel.background": "#0f091690",
                "title_bar.background": "#0f091690",
                "title_bar.inactive_background": "#0f091690",
                "status_bar.background": "#0f091690",
                "drop_target.background": "#0f091690",
                "elevated_surface.background": "#0f0916",
                "toolbar.background": "#0f091690",
                "tab_bar.background": "#0f091690",
                "tab.inactive_background": "#0f091690",
                "tab.active_background": "#27346630",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0f0916",
                "scrollbar.thumb.background": "#273466",
                "editor.gutter.background": "#0f091690",
                "terminal.background": "#0f091610",
                "terminal.foreground": "#c3c1c4",
                "terminal.dim_foreground": "#c3c1c4",
                "terminal.bright_foreground": "#c3c1c4",
                "terminal.ansi.black": "#0f0916",
                "terminal.ansi.red": "#273466",
                "terminal.ansi.green": "#444547",
                "terminal.ansi.yellow": "#5D5162",
                "terminal.ansi.blue": "#9C562E",
                "terminal.ansi.magenta": "#9B675A",
                "terminal.ansi.cyan": "#475E9B",
                "terminal.ansi.white": "#c3c1c4",
                "terminal.ansi.bright_black": "#62596c",
                "terminal.ansi.bright_red": "#273466",
                "terminal.ansi.bright_green": "#444547",
                "terminal.ansi.bright_yellow": "#5D5162",
                "terminal.ansi.bright_blue": "#9C562E",
                "terminal.ansi.bright_magenta": "#9B675A",
                "terminal.ansi.bright_cyan": "#475E9B",
                "terminal.ansi.bright_white": "#c3c1c4",
                "modified": "#273466",
                "syntax": {
                    "attribute": {
                        "color": "#273466"
                    },
                    "boolean": {
                      "color": "#444547"
                    },
                    "comment": {
                      "color": "#62596c"
                    },
                    "comment.doc": {
                      "color": "#62596c"
                    },
                    "constant": {
                      "color": "#444547"
                    },
                    "function": {
                      "color": "#475E9B"
                    },
                    "keyword": {
                      "color": "#9C562E"
                    },
                    "number": {
                      "color": "#9B675A"
                    },
                    "operator": {
                      "color": "#9C562E"
                    },
                    "string": {
                      "color": "#273466"
                    },
                    "variable": {
                      "color": "#444547"
                    }
                },
                "players": [
                  {
                    "cursor": "#273466",
                    "background": "#0f0916",
                    "selection": "#27346630"
                  }
                ]
            }
        }
    ]
}
