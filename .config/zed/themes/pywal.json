{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#191d2490",
                "editor.background": "#191d2490",
                "editor.foreground": "#c5c6c8",
                "text": "#c5c6c8",
                "text.muted": "#c5c6c870",
                "text.ignored": "#c5c6c840",
                "text.placeholder": "#c5c6c850",
                "ignored": "#c5c6c830",
                "element.hover": "#c5c6c830",
                "ghost_element.hover": "#C4666C30",
                "ghost_element.selected": "#C4666C30",
                "ghost_element.active": "#C4666C60",
                "border": "#191d24",
                "editor.highlighted_line.background": "#C4666C10",
                "editor.active_line.background": "#C4666C10",
                "panel.background": "#191d2490",
                "title_bar.background": "#191d2490",
                "title_bar.inactive_background": "#191d2490",
                "status_bar.background": "#191d2490",
                "drop_target.background": "#191d2490",
                "elevated_surface.background": "#191d24",
                "toolbar.background": "#191d2490",
                "tab_bar.background": "#191d2490",
                "tab.inactive_background": "#191d2490",
                "tab.active_background": "#C4666C30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#191d24",
                "scrollbar.thumb.background": "#C4666C",
                "editor.gutter.background": "#191d2490",
                "terminal.background": "#191d2410",
                "terminal.foreground": "#c5c6c8",
                "terminal.dim_foreground": "#c5c6c8",
                "terminal.bright_foreground": "#c5c6c8",
                "terminal.ansi.black": "#191d24",
                "terminal.ansi.red": "#C4666C",
                "terminal.ansi.green": "#5C708E",
                "terminal.ansi.yellow": "#A27C85",
                "terminal.ansi.blue": "#6D8FAD",
                "terminal.ansi.magenta": "#7AABC4",
                "terminal.ansi.cyan": "#91B6CA",
                "terminal.ansi.white": "#c5c6c8",
                "terminal.ansi.bright_black": "#616a77",
                "terminal.ansi.bright_red": "#C4666C",
                "terminal.ansi.bright_green": "#5C708E",
                "terminal.ansi.bright_yellow": "#A27C85",
                "terminal.ansi.bright_blue": "#6D8FAD",
                "terminal.ansi.bright_magenta": "#7AABC4",
                "terminal.ansi.bright_cyan": "#91B6CA",
                "terminal.ansi.bright_white": "#c5c6c8",
                "modified": "#C4666C",
                "syntax": {
                    "attribute": {
                        "color": "#C4666C"
                    },
                    "boolean": {
                      "color": "#5C708E"
                    },
                    "comment": {
                      "color": "#616a77"
                    },
                    "comment.doc": {
                      "color": "#616a77"
                    },
                    "constant": {
                      "color": "#5C708E"
                    },
                    "function": {
                      "color": "#91B6CA"
                    },
                    "keyword": {
                      "color": "#6D8FAD"
                    },
                    "number": {
                      "color": "#7AABC4"
                    },
                    "operator": {
                      "color": "#6D8FAD"
                    },
                    "string": {
                      "color": "#C4666C"
                    },
                    "variable": {
                      "color": "#5C708E"
                    }
                },
                "players": [
                  {
                    "cursor": "#C4666C",
                    "background": "#191d24",
                    "selection": "#C4666C30"
                  }
                ]
            }
        }
    ]
}
