{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#15091090",
                "editor.background": "#15091090",
                "editor.foreground": "#c4c1c3",
                "text": "#c4c1c3",
                "text.muted": "#c4c1c370",
                "text.ignored": "#c4c1c340",
                "text.placeholder": "#c4c1c350",
                "ignored": "#c4c1c330",
                "element.hover": "#c4c1c330",
                "ghost_element.hover": "#5E3C3F30",
                "ghost_element.selected": "#5E3C3F30",
                "ghost_element.active": "#5E3C3F60",
                "border": "#150910",
                "editor.highlighted_line.background": "#5E3C3F10",
                "editor.active_line.background": "#5E3C3F10",
                "panel.background": "#15091090",
                "title_bar.background": "#15091090",
                "title_bar.inactive_background": "#15091090",
                "status_bar.background": "#15091090",
                "drop_target.background": "#15091090",
                "elevated_surface.background": "#150910",
                "toolbar.background": "#15091090",
                "tab_bar.background": "#15091090",
                "tab.inactive_background": "#15091090",
                "tab.active_background": "#5E3C3F30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#150910",
                "scrollbar.thumb.background": "#5E3C3F",
                "editor.gutter.background": "#15091090",
                "terminal.background": "#15091010",
                "terminal.foreground": "#c4c1c3",
                "terminal.dim_foreground": "#c4c1c3",
                "terminal.bright_foreground": "#c4c1c3",
                "terminal.ansi.black": "#150910",
                "terminal.ansi.red": "#5E3C3F",
                "terminal.ansi.green": "#655450",
                "terminal.ansi.yellow": "#A2493C",
                "terminal.ansi.blue": "#956656",
                "terminal.ansi.magenta": "#C4946F",
                "terminal.ansi.cyan": "#866F91",
                "terminal.ansi.white": "#c4c1c3",
                "terminal.ansi.bright_black": "#6c5863",
                "terminal.ansi.bright_red": "#5E3C3F",
                "terminal.ansi.bright_green": "#655450",
                "terminal.ansi.bright_yellow": "#A2493C",
                "terminal.ansi.bright_blue": "#956656",
                "terminal.ansi.bright_magenta": "#C4946F",
                "terminal.ansi.bright_cyan": "#866F91",
                "terminal.ansi.bright_white": "#c4c1c3",
                "modified": "#5E3C3F",
                "syntax": {
                    "attribute": {
                        "color": "#5E3C3F"
                    },
                    "boolean": {
                      "color": "#655450"
                    },
                    "comment": {
                      "color": "#6c5863"
                    },
                    "comment.doc": {
                      "color": "#6c5863"
                    },
                    "constant": {
                      "color": "#655450"
                    },
                    "function": {
                      "color": "#866F91"
                    },
                    "keyword": {
                      "color": "#956656"
                    },
                    "number": {
                      "color": "#C4946F"
                    },
                    "operator": {
                      "color": "#956656"
                    },
                    "string": {
                      "color": "#5E3C3F"
                    },
                    "variable": {
                      "color": "#655450"
                    }
                },
                "players": [
                  {
                    "cursor": "#5E3C3F",
                    "background": "#150910",
                    "selection": "#5E3C3F30"
                  }
                ]
            }
        }
    ]
}
