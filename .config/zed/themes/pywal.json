{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#1e0d0d90",
                "editor.background": "#1e0d0d90",
                "editor.foreground": "#c6c2c2",
                "text": "#c6c2c2",
                "text.muted": "#c6c2c270",
                "text.ignored": "#c6c2c240",
                "text.placeholder": "#c6c2c250",
                "ignored": "#c6c2c230",
                "element.hover": "#c6c2c230",
                "ghost_element.hover": "#313C5130",
                "ghost_element.selected": "#313C5130",
                "ghost_element.active": "#313C5160",
                "border": "#1e0d0d",
                "editor.highlighted_line.background": "#313C5110",
                "editor.active_line.background": "#313C5110",
                "panel.background": "#1e0d0d90",
                "title_bar.background": "#1e0d0d90",
                "title_bar.inactive_background": "#1e0d0d90",
                "status_bar.background": "#1e0d0d90",
                "drop_target.background": "#1e0d0d90",
                "elevated_surface.background": "#1e0d0d",
                "toolbar.background": "#1e0d0d90",
                "tab_bar.background": "#1e0d0d90",
                "tab.inactive_background": "#1e0d0d90",
                "tab.active_background": "#313C5130",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#1e0d0d",
                "scrollbar.thumb.background": "#313C51",
                "editor.gutter.background": "#1e0d0d90",
                "terminal.background": "#1e0d0d10",
                "terminal.foreground": "#c6c2c2",
                "terminal.dim_foreground": "#c6c2c2",
                "terminal.bright_foreground": "#c6c2c2",
                "terminal.ansi.black": "#1e0d0d",
                "terminal.ansi.red": "#313C51",
                "terminal.ansi.green": "#4A3A48",
                "terminal.ansi.yellow": "#655662",
                "terminal.ansi.blue": "#9E3842",
                "terminal.ansi.magenta": "#4D6F8A",
                "terminal.ansi.cyan": "#8D7889",
                "terminal.ansi.white": "#c6c2c2",
                "terminal.ansi.bright_black": "#705c5c",
                "terminal.ansi.bright_red": "#313C51",
                "terminal.ansi.bright_green": "#4A3A48",
                "terminal.ansi.bright_yellow": "#655662",
                "terminal.ansi.bright_blue": "#9E3842",
                "terminal.ansi.bright_magenta": "#4D6F8A",
                "terminal.ansi.bright_cyan": "#8D7889",
                "terminal.ansi.bright_white": "#c6c2c2",
                "modified": "#313C51",
                "syntax": {
                    "attribute": {
                        "color": "#313C51"
                    },
                    "boolean": {
                      "color": "#4A3A48"
                    },
                    "comment": {
                      "color": "#705c5c"
                    },
                    "comment.doc": {
                      "color": "#705c5c"
                    },
                    "constant": {
                      "color": "#4A3A48"
                    },
                    "function": {
                      "color": "#8D7889"
                    },
                    "keyword": {
                      "color": "#9E3842"
                    },
                    "number": {
                      "color": "#4D6F8A"
                    },
                    "operator": {
                      "color": "#9E3842"
                    },
                    "string": {
                      "color": "#313C51"
                    },
                    "variable": {
                      "color": "#4A3A48"
                    }
                },
                "players": [
                  {
                    "cursor": "#313C51",
                    "background": "#1e0d0d",
                    "selection": "#313C5130"
                  }
                ]
            }
        }
    ]
}
