{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0d0d1f90",
                "editor.background": "#0d0d1f90",
                "editor.foreground": "#c2c2c7",
                "text": "#c2c2c7",
                "text.muted": "#c2c2c770",
                "text.ignored": "#c2c2c740",
                "text.placeholder": "#c2c2c750",
                "ignored": "#c2c2c730",
                "element.hover": "#c2c2c730",
                "ghost_element.hover": "#42527B30",
                "ghost_element.selected": "#42527B30",
                "ghost_element.active": "#42527B60",
                "border": "#0d0d1f",
                "editor.highlighted_line.background": "#42527B10",
                "editor.active_line.background": "#42527B10",
                "panel.background": "#0d0d1f90",
                "title_bar.background": "#0d0d1f90",
                "title_bar.inactive_background": "#0d0d1f90",
                "status_bar.background": "#0d0d1f90",
                "drop_target.background": "#0d0d1f90",
                "elevated_surface.background": "#0d0d1f",
                "toolbar.background": "#0d0d1f90",
                "tab_bar.background": "#0d0d1f90",
                "tab.inactive_background": "#0d0d1f90",
                "tab.active_background": "#42527B30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0d0d1f",
                "scrollbar.thumb.background": "#42527B",
                "editor.gutter.background": "#0d0d1f90",
                "terminal.background": "#0d0d1f10",
                "terminal.foreground": "#c2c2c7",
                "terminal.dim_foreground": "#c2c2c7",
                "terminal.bright_foreground": "#c2c2c7",
                "terminal.ansi.black": "#0d0d1f",
                "terminal.ansi.red": "#42527B",
                "terminal.ansi.green": "#51689D",
                "terminal.ansi.yellow": "#5E7ABC",
                "terminal.ansi.blue": "#6982BC",
                "terminal.ansi.magenta": "#6A8AD1",
                "terminal.ansi.cyan": "#789DEE",
                "terminal.ansi.white": "#c2c2c7",
                "terminal.ansi.bright_black": "#5c5c71",
                "terminal.ansi.bright_red": "#42527B",
                "terminal.ansi.bright_green": "#51689D",
                "terminal.ansi.bright_yellow": "#5E7ABC",
                "terminal.ansi.bright_blue": "#6982BC",
                "terminal.ansi.bright_magenta": "#6A8AD1",
                "terminal.ansi.bright_cyan": "#789DEE",
                "terminal.ansi.bright_white": "#c2c2c7",
                "modified": "#42527B",
                "syntax": {
                    "attribute": {
                        "color": "#42527B"
                    },
                    "boolean": {
                      "color": "#51689D"
                    },
                    "comment": {
                      "color": "#5c5c71"
                    },
                    "comment.doc": {
                      "color": "#5c5c71"
                    },
                    "constant": {
                      "color": "#51689D"
                    },
                    "function": {
                      "color": "#789DEE"
                    },
                    "keyword": {
                      "color": "#6982BC"
                    },
                    "number": {
                      "color": "#6A8AD1"
                    },
                    "operator": {
                      "color": "#6982BC"
                    },
                    "string": {
                      "color": "#42527B"
                    },
                    "variable": {
                      "color": "#51689D"
                    }
                },
                "players": [
                  {
                    "cursor": "#42527B",
                    "background": "#0d0d1f",
                    "selection": "#42527B30"
                  }
                ]
            }
        }
    ]
}
