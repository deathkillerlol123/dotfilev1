{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0c121e90",
                "editor.background": "#0c121e90",
                "editor.foreground": "#c2c3c6",
                "text": "#c2c3c6",
                "text.muted": "#c2c3c670",
                "text.ignored": "#c2c3c640",
                "text.placeholder": "#c2c3c650",
                "ignored": "#c2c3c630",
                "element.hover": "#c2c3c630",
                "ghost_element.hover": "#A0495930",
                "ghost_element.selected": "#A0495930",
                "ghost_element.active": "#A0495960",
                "border": "#0c121e",
                "editor.highlighted_line.background": "#A0495910",
                "editor.active_line.background": "#A0495910",
                "panel.background": "#0c121e90",
                "title_bar.background": "#0c121e90",
                "title_bar.inactive_background": "#0c121e90",
                "status_bar.background": "#0c121e90",
                "drop_target.background": "#0c121e90",
                "elevated_surface.background": "#0c121e",
                "toolbar.background": "#0c121e90",
                "tab_bar.background": "#0c121e90",
                "tab.inactive_background": "#0c121e90",
                "tab.active_background": "#A0495930",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0c121e",
                "scrollbar.thumb.background": "#A04959",
                "editor.gutter.background": "#0c121e90",
                "terminal.background": "#0c121e10",
                "terminal.foreground": "#c2c3c6",
                "terminal.dim_foreground": "#c2c3c6",
                "terminal.bright_foreground": "#c2c3c6",
                "terminal.ansi.black": "#0c121e",
                "terminal.ansi.red": "#A04959",
                "terminal.ansi.green": "#EC5D68",
                "terminal.ansi.yellow": "#E49C6F",
                "terminal.ansi.blue": "#4A738B",
                "terminal.ansi.magenta": "#CB6D8C",
                "terminal.ansi.cyan": "#5A9BAF",
                "terminal.ansi.white": "#c2c3c6",
                "terminal.ansi.bright_black": "#5c6170",
                "terminal.ansi.bright_red": "#A04959",
                "terminal.ansi.bright_green": "#EC5D68",
                "terminal.ansi.bright_yellow": "#E49C6F",
                "terminal.ansi.bright_blue": "#4A738B",
                "terminal.ansi.bright_magenta": "#CB6D8C",
                "terminal.ansi.bright_cyan": "#5A9BAF",
                "terminal.ansi.bright_white": "#c2c3c6",
                "modified": "#A04959",
                "syntax": {
                    "attribute": {
                        "color": "#A04959"
                    },
                    "boolean": {
                      "color": "#EC5D68"
                    },
                    "comment": {
                      "color": "#5c6170"
                    },
                    "comment.doc": {
                      "color": "#5c6170"
                    },
                    "constant": {
                      "color": "#EC5D68"
                    },
                    "function": {
                      "color": "#5A9BAF"
                    },
                    "keyword": {
                      "color": "#4A738B"
                    },
                    "number": {
                      "color": "#CB6D8C"
                    },
                    "operator": {
                      "color": "#4A738B"
                    },
                    "string": {
                      "color": "#A04959"
                    },
                    "variable": {
                      "color": "#EC5D68"
                    }
                },
                "players": [
                  {
                    "cursor": "#A04959",
                    "background": "#0c121e",
                    "selection": "#A0495930"
                  }
                ]
            }
        }
    ]
}
