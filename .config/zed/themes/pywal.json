{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#1e0d0d90",
                "editor.background": "#1e0d0d90",
                "editor.foreground": "#c6c2c2",
                "text": "#c6c2c2",
                "text.muted": "#c6c2c270",
                "text.ignored": "#c6c2c240",
                "text.placeholder": "#c6c2c250",
                "ignored": "#c6c2c230",
                "element.hover": "#c6c2c230",
                "ghost_element.hover": "#48607330",
                "ghost_element.selected": "#48607330",
                "ghost_element.active": "#48607360",
                "border": "#1e0d0d",
                "editor.highlighted_line.background": "#48607310",
                "editor.active_line.background": "#48607310",
                "panel.background": "#1e0d0d90",
                "title_bar.background": "#1e0d0d90",
                "title_bar.inactive_background": "#1e0d0d90",
                "status_bar.background": "#1e0d0d90",
                "drop_target.background": "#1e0d0d90",
                "elevated_surface.background": "#1e0d0d",
                "toolbar.background": "#1e0d0d90",
                "tab_bar.background": "#1e0d0d90",
                "tab.inactive_background": "#1e0d0d90",
                "tab.active_background": "#48607330",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#1e0d0d",
                "scrollbar.thumb.background": "#486073",
                "editor.gutter.background": "#1e0d0d90",
                "terminal.background": "#1e0d0d10",
                "terminal.foreground": "#c6c2c2",
                "terminal.dim_foreground": "#c6c2c2",
                "terminal.bright_foreground": "#c6c2c2",
                "terminal.ansi.black": "#1e0d0d",
                "terminal.ansi.red": "#486073",
                "terminal.ansi.green": "#55738D",
                "terminal.ansi.yellow": "#6C90A6",
                "terminal.ansi.blue": "#7BACC7",
                "terminal.ansi.magenta": "#91A8B3",
                "terminal.ansi.cyan": "#93B9CC",
                "terminal.ansi.white": "#c6c2c2",
                "terminal.ansi.bright_black": "#705c5c",
                "terminal.ansi.bright_red": "#486073",
                "terminal.ansi.bright_green": "#55738D",
                "terminal.ansi.bright_yellow": "#6C90A6",
                "terminal.ansi.bright_blue": "#7BACC7",
                "terminal.ansi.bright_magenta": "#91A8B3",
                "terminal.ansi.bright_cyan": "#93B9CC",
                "terminal.ansi.bright_white": "#c6c2c2",
                "modified": "#486073",
                "syntax": {
                    "attribute": {
                        "color": "#486073"
                    },
                    "boolean": {
                      "color": "#55738D"
                    },
                    "comment": {
                      "color": "#705c5c"
                    },
                    "comment.doc": {
                      "color": "#705c5c"
                    },
                    "constant": {
                      "color": "#55738D"
                    },
                    "function": {
                      "color": "#93B9CC"
                    },
                    "keyword": {
                      "color": "#7BACC7"
                    },
                    "number": {
                      "color": "#91A8B3"
                    },
                    "operator": {
                      "color": "#7BACC7"
                    },
                    "string": {
                      "color": "#486073"
                    },
                    "variable": {
                      "color": "#55738D"
                    }
                },
                "players": [
                  {
                    "cursor": "#486073",
                    "background": "#1e0d0d",
                    "selection": "#48607330"
                  }
                ]
            }
        }
    ]
}
