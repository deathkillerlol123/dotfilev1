{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#090b1590",
                "editor.background": "#090b1590",
                "editor.foreground": "#c1c2c4",
                "text": "#c1c2c4",
                "text.muted": "#c1c2c470",
                "text.ignored": "#c1c2c440",
                "text.placeholder": "#c1c2c450",
                "ignored": "#c1c2c430",
                "element.hover": "#c1c2c430",
                "ghost_element.hover": "#981C7130",
                "ghost_element.selected": "#981C7130",
                "ghost_element.active": "#981C7160",
                "border": "#090b15",
                "editor.highlighted_line.background": "#981C7110",
                "editor.active_line.background": "#981C7110",
                "panel.background": "#090b1590",
                "title_bar.background": "#090b1590",
                "title_bar.inactive_background": "#090b1590",
                "status_bar.background": "#090b1590",
                "drop_target.background": "#090b1590",
                "elevated_surface.background": "#090b15",
                "toolbar.background": "#090b1590",
                "tab_bar.background": "#090b1590",
                "tab.inactive_background": "#090b1590",
                "tab.active_background": "#981C7130",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#090b15",
                "scrollbar.thumb.background": "#981C71",
                "editor.gutter.background": "#090b1590",
                "terminal.background": "#090b1510",
                "terminal.foreground": "#c1c2c4",
                "terminal.dim_foreground": "#c1c2c4",
                "terminal.bright_foreground": "#c1c2c4",
                "terminal.ansi.black": "#090b15",
                "terminal.ansi.red": "#981C71",
                "terminal.ansi.green": "#096B94",
                "terminal.ansi.yellow": "#614D93",
                "terminal.ansi.blue": "#C94AA7",
                "terminal.ansi.magenta": "#EA58B4",
                "terminal.ansi.cyan": "#29ACCC",
                "terminal.ansi.white": "#c1c2c4",
                "terminal.ansi.bright_black": "#585b6c",
                "terminal.ansi.bright_red": "#981C71",
                "terminal.ansi.bright_green": "#096B94",
                "terminal.ansi.bright_yellow": "#614D93",
                "terminal.ansi.bright_blue": "#C94AA7",
                "terminal.ansi.bright_magenta": "#EA58B4",
                "terminal.ansi.bright_cyan": "#29ACCC",
                "terminal.ansi.bright_white": "#c1c2c4",
                "modified": "#981C71",
                "syntax": {
                    "attribute": {
                        "color": "#981C71"
                    },
                    "boolean": {
                      "color": "#096B94"
                    },
                    "comment": {
                      "color": "#585b6c"
                    },
                    "comment.doc": {
                      "color": "#585b6c"
                    },
                    "constant": {
                      "color": "#096B94"
                    },
                    "function": {
                      "color": "#29ACCC"
                    },
                    "keyword": {
                      "color": "#C94AA7"
                    },
                    "number": {
                      "color": "#EA58B4"
                    },
                    "operator": {
                      "color": "#C94AA7"
                    },
                    "string": {
                      "color": "#981C71"
                    },
                    "variable": {
                      "color": "#096B94"
                    }
                },
                "players": [
                  {
                    "cursor": "#981C71",
                    "background": "#090b15",
                    "selection": "#981C7130"
                  }
                ]
            }
        }
    ]
}
