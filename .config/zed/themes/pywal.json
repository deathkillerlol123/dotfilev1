{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#15091490",
                "editor.background": "#15091490",
                "editor.foreground": "#c4c1c4",
                "text": "#c4c1c4",
                "text.muted": "#c4c1c470",
                "text.ignored": "#c4c1c440",
                "text.placeholder": "#c4c1c450",
                "ignored": "#c4c1c430",
                "element.hover": "#c4c1c430",
                "ghost_element.hover": "#29328D30",
                "ghost_element.selected": "#29328D30",
                "ghost_element.active": "#29328D60",
                "border": "#150914",
                "editor.highlighted_line.background": "#29328D10",
                "editor.active_line.background": "#29328D10",
                "panel.background": "#15091490",
                "title_bar.background": "#15091490",
                "title_bar.inactive_background": "#15091490",
                "status_bar.background": "#15091490",
                "drop_target.background": "#15091490",
                "elevated_surface.background": "#150914",
                "toolbar.background": "#15091490",
                "tab_bar.background": "#15091490",
                "tab.inactive_background": "#15091490",
                "tab.active_background": "#29328D30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#150914",
                "scrollbar.thumb.background": "#29328D",
                "editor.gutter.background": "#15091490",
                "terminal.background": "#15091410",
                "terminal.foreground": "#c4c1c4",
                "terminal.dim_foreground": "#c4c1c4",
                "terminal.bright_foreground": "#c4c1c4",
                "terminal.ansi.black": "#150914",
                "terminal.ansi.red": "#29328D",
                "terminal.ansi.green": "#2A3B9F",
                "terminal.ansi.yellow": "#5B3FA1",
                "terminal.ansi.blue": "#1D4BA4",
                "terminal.ansi.magenta": "#2749B2",
                "terminal.ansi.cyan": "#176AD4",
                "terminal.ansi.white": "#c4c1c4",
                "terminal.ansi.bright_black": "#6c586c",
                "terminal.ansi.bright_red": "#29328D",
                "terminal.ansi.bright_green": "#2A3B9F",
                "terminal.ansi.bright_yellow": "#5B3FA1",
                "terminal.ansi.bright_blue": "#1D4BA4",
                "terminal.ansi.bright_magenta": "#2749B2",
                "terminal.ansi.bright_cyan": "#176AD4",
                "terminal.ansi.bright_white": "#c4c1c4",
                "modified": "#29328D",
                "syntax": {
                    "attribute": {
                        "color": "#29328D"
                    },
                    "boolean": {
                      "color": "#2A3B9F"
                    },
                    "comment": {
                      "color": "#6c586c"
                    },
                    "comment.doc": {
                      "color": "#6c586c"
                    },
                    "constant": {
                      "color": "#2A3B9F"
                    },
                    "function": {
                      "color": "#176AD4"
                    },
                    "keyword": {
                      "color": "#1D4BA4"
                    },
                    "number": {
                      "color": "#2749B2"
                    },
                    "operator": {
                      "color": "#1D4BA4"
                    },
                    "string": {
                      "color": "#29328D"
                    },
                    "variable": {
                      "color": "#2A3B9F"
                    }
                },
                "players": [
                  {
                    "cursor": "#29328D",
                    "background": "#150914",
                    "selection": "#29328D30"
                  }
                ]
            }
        }
    ]
}
