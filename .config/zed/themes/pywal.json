{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0a0b1890",
                "editor.background": "#0a0b1890",
                "editor.foreground": "#c1c2c5",
                "text": "#c1c2c5",
                "text.muted": "#c1c2c570",
                "text.ignored": "#c1c2c540",
                "text.placeholder": "#c1c2c550",
                "ignored": "#c1c2c530",
                "element.hover": "#c1c2c530",
                "ghost_element.hover": "#4C297030",
                "ghost_element.selected": "#4C297030",
                "ghost_element.active": "#4C297060",
                "border": "#0a0b18",
                "editor.highlighted_line.background": "#4C297010",
                "editor.active_line.background": "#4C297010",
                "panel.background": "#0a0b1890",
                "title_bar.background": "#0a0b1890",
                "title_bar.inactive_background": "#0a0b1890",
                "status_bar.background": "#0a0b1890",
                "drop_target.background": "#0a0b1890",
                "elevated_surface.background": "#0a0b18",
                "toolbar.background": "#0a0b1890",
                "tab_bar.background": "#0a0b1890",
                "tab.inactive_background": "#0a0b1890",
                "tab.active_background": "#4C297030",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0a0b18",
                "scrollbar.thumb.background": "#4C2970",
                "editor.gutter.background": "#0a0b1890",
                "terminal.background": "#0a0b1810",
                "terminal.foreground": "#c1c2c5",
                "terminal.dim_foreground": "#c1c2c5",
                "terminal.bright_foreground": "#c1c2c5",
                "terminal.ansi.black": "#0a0b18",
                "terminal.ansi.red": "#4C2970",
                "terminal.ansi.green": "#3D487A",
                "terminal.ansi.yellow": "#2B2488",
                "terminal.ansi.blue": "#522E94",
                "terminal.ansi.magenta": "#254F8F",
                "terminal.ansi.cyan": "#635198",
                "terminal.ansi.white": "#c1c2c5",
                "terminal.ansi.bright_black": "#595b6d",
                "terminal.ansi.bright_red": "#4C2970",
                "terminal.ansi.bright_green": "#3D487A",
                "terminal.ansi.bright_yellow": "#2B2488",
                "terminal.ansi.bright_blue": "#522E94",
                "terminal.ansi.bright_magenta": "#254F8F",
                "terminal.ansi.bright_cyan": "#635198",
                "terminal.ansi.bright_white": "#c1c2c5",
                "modified": "#4C2970",
                "syntax": {
                    "attribute": {
                        "color": "#4C2970"
                    },
                    "boolean": {
                      "color": "#3D487A"
                    },
                    "comment": {
                      "color": "#595b6d"
                    },
                    "comment.doc": {
                      "color": "#595b6d"
                    },
                    "constant": {
                      "color": "#3D487A"
                    },
                    "function": {
                      "color": "#635198"
                    },
                    "keyword": {
                      "color": "#522E94"
                    },
                    "number": {
                      "color": "#254F8F"
                    },
                    "operator": {
                      "color": "#522E94"
                    },
                    "string": {
                      "color": "#4C2970"
                    },
                    "variable": {
                      "color": "#3D487A"
                    }
                },
                "players": [
                  {
                    "cursor": "#4C2970",
                    "background": "#0a0b18",
                    "selection": "#4C297030"
                  }
                ]
            }
        }
    ]
}
