{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#12181d90",
                "editor.background": "#12181d90",
                "editor.foreground": "#c3c5c6",
                "text": "#c3c5c6",
                "text.muted": "#c3c5c670",
                "text.ignored": "#c3c5c640",
                "text.placeholder": "#c3c5c650",
                "ignored": "#c3c5c630",
                "element.hover": "#c3c5c630",
                "ghost_element.hover": "#8F897430",
                "ghost_element.selected": "#8F897430",
                "ghost_element.active": "#8F897460",
                "border": "#12181d",
                "editor.highlighted_line.background": "#8F897410",
                "editor.active_line.background": "#8F897410",
                "panel.background": "#12181d90",
                "title_bar.background": "#12181d90",
                "title_bar.inactive_background": "#12181d90",
                "status_bar.background": "#12181d90",
                "drop_target.background": "#12181d90",
                "elevated_surface.background": "#12181d",
                "toolbar.background": "#12181d90",
                "tab_bar.background": "#12181d90",
                "tab.inactive_background": "#12181d90",
                "tab.active_background": "#8F897430",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#12181d",
                "scrollbar.thumb.background": "#8F8974",
                "editor.gutter.background": "#12181d90",
                "terminal.background": "#12181d10",
                "terminal.foreground": "#c3c5c6",
                "terminal.dim_foreground": "#c3c5c6",
                "terminal.bright_foreground": "#c3c5c6",
                "terminal.ansi.black": "#12181d",
                "terminal.ansi.red": "#8F8974",
                "terminal.ansi.green": "#7C8382",
                "terminal.ansi.yellow": "#90938E",
                "terminal.ansi.blue": "#A4A49B",
                "terminal.ansi.magenta": "#B4B0A7",
                "terminal.ansi.cyan": "#C4BCB0",
                "terminal.ansi.white": "#c3c5c6",
                "terminal.ansi.bright_black": "#5d6772",
                "terminal.ansi.bright_red": "#8F8974",
                "terminal.ansi.bright_green": "#7C8382",
                "terminal.ansi.bright_yellow": "#90938E",
                "terminal.ansi.bright_blue": "#A4A49B",
                "terminal.ansi.bright_magenta": "#B4B0A7",
                "terminal.ansi.bright_cyan": "#C4BCB0",
                "terminal.ansi.bright_white": "#c3c5c6",
                "modified": "#8F8974",
                "syntax": {
                    "attribute": {
                        "color": "#8F8974"
                    },
                    "boolean": {
                      "color": "#7C8382"
                    },
                    "comment": {
                      "color": "#5d6772"
                    },
                    "comment.doc": {
                      "color": "#5d6772"
                    },
                    "constant": {
                      "color": "#7C8382"
                    },
                    "function": {
                      "color": "#C4BCB0"
                    },
                    "keyword": {
                      "color": "#A4A49B"
                    },
                    "number": {
                      "color": "#B4B0A7"
                    },
                    "operator": {
                      "color": "#A4A49B"
                    },
                    "string": {
                      "color": "#8F8974"
                    },
                    "variable": {
                      "color": "#7C8382"
                    }
                },
                "players": [
                  {
                    "cursor": "#8F8974",
                    "background": "#12181d",
                    "selection": "#8F897430"
                  }
                ]
            }
        }
    ]
}
