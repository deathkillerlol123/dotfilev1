{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0a0a1990",
                "editor.background": "#0a0a1990",
                "editor.foreground": "#c1c1c5",
                "text": "#c1c1c5",
                "text.muted": "#c1c1c570",
                "text.ignored": "#c1c1c540",
                "text.placeholder": "#c1c1c550",
                "ignored": "#c1c1c530",
                "element.hover": "#c1c1c530",
                "ghost_element.hover": "#703E4030",
                "ghost_element.selected": "#703E4030",
                "ghost_element.active": "#703E4060",
                "border": "#0a0a19",
                "editor.highlighted_line.background": "#703E4010",
                "editor.active_line.background": "#703E4010",
                "panel.background": "#0a0a1990",
                "title_bar.background": "#0a0a1990",
                "title_bar.inactive_background": "#0a0a1990",
                "status_bar.background": "#0a0a1990",
                "drop_target.background": "#0a0a1990",
                "elevated_surface.background": "#0a0a19",
                "toolbar.background": "#0a0a1990",
                "tab_bar.background": "#0a0a1990",
                "tab.inactive_background": "#0a0a1990",
                "tab.active_background": "#703E4030",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0a0a19",
                "scrollbar.thumb.background": "#703E40",
                "editor.gutter.background": "#0a0a1990",
                "terminal.background": "#0a0a1910",
                "terminal.foreground": "#c1c1c5",
                "terminal.dim_foreground": "#c1c1c5",
                "terminal.bright_foreground": "#c1c1c5",
                "terminal.ansi.black": "#0a0a19",
                "terminal.ansi.red": "#703E40",
                "terminal.ansi.green": "#40414E",
                "terminal.ansi.yellow": "#4E4851",
                "terminal.ansi.blue": "#6D5456",
                "terminal.ansi.magenta": "#6E5C62",
                "terminal.ansi.cyan": "#9A4A3D",
                "terminal.ansi.white": "#c1c1c5",
                "terminal.ansi.bright_black": "#59596e",
                "terminal.ansi.bright_red": "#703E40",
                "terminal.ansi.bright_green": "#40414E",
                "terminal.ansi.bright_yellow": "#4E4851",
                "terminal.ansi.bright_blue": "#6D5456",
                "terminal.ansi.bright_magenta": "#6E5C62",
                "terminal.ansi.bright_cyan": "#9A4A3D",
                "terminal.ansi.bright_white": "#c1c1c5",
                "modified": "#703E40",
                "syntax": {
                    "attribute": {
                        "color": "#703E40"
                    },
                    "boolean": {
                      "color": "#40414E"
                    },
                    "comment": {
                      "color": "#59596e"
                    },
                    "comment.doc": {
                      "color": "#59596e"
                    },
                    "constant": {
                      "color": "#40414E"
                    },
                    "function": {
                      "color": "#9A4A3D"
                    },
                    "keyword": {
                      "color": "#6D5456"
                    },
                    "number": {
                      "color": "#6E5C62"
                    },
                    "operator": {
                      "color": "#6D5456"
                    },
                    "string": {
                      "color": "#703E40"
                    },
                    "variable": {
                      "color": "#40414E"
                    }
                },
                "players": [
                  {
                    "cursor": "#703E40",
                    "background": "#0a0a19",
                    "selection": "#703E4030"
                  }
                ]
            }
        }
    ]
}
