{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#17090990",
                "editor.background": "#17090990",
                "editor.foreground": "#c5c1c1",
                "text": "#c5c1c1",
                "text.muted": "#c5c1c170",
                "text.ignored": "#c5c1c140",
                "text.placeholder": "#c5c1c150",
                "ignored": "#c5c1c130",
                "element.hover": "#c5c1c130",
                "ghost_element.hover": "#324A7030",
                "ghost_element.selected": "#324A7030",
                "ghost_element.active": "#324A7060",
                "border": "#170909",
                "editor.highlighted_line.background": "#324A7010",
                "editor.active_line.background": "#324A7010",
                "panel.background": "#17090990",
                "title_bar.background": "#17090990",
                "title_bar.inactive_background": "#17090990",
                "status_bar.background": "#17090990",
                "drop_target.background": "#17090990",
                "elevated_surface.background": "#170909",
                "toolbar.background": "#17090990",
                "tab_bar.background": "#17090990",
                "tab.inactive_background": "#17090990",
                "tab.active_background": "#324A7030",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#170909",
                "scrollbar.thumb.background": "#324A70",
                "editor.gutter.background": "#17090990",
                "terminal.background": "#17090910",
                "terminal.foreground": "#c5c1c1",
                "terminal.dim_foreground": "#c5c1c1",
                "terminal.bright_foreground": "#c5c1c1",
                "terminal.ansi.black": "#170909",
                "terminal.ansi.red": "#324A70",
                "terminal.ansi.green": "#5C536B",
                "terminal.ansi.yellow": "#A8502A",
                "terminal.ansi.blue": "#9F5E63",
                "terminal.ansi.magenta": "#E1675B",
                "terminal.ansi.cyan": "#ED9265",
                "terminal.ansi.white": "#c5c1c1",
                "terminal.ansi.bright_black": "#6d5959",
                "terminal.ansi.bright_red": "#324A70",
                "terminal.ansi.bright_green": "#5C536B",
                "terminal.ansi.bright_yellow": "#A8502A",
                "terminal.ansi.bright_blue": "#9F5E63",
                "terminal.ansi.bright_magenta": "#E1675B",
                "terminal.ansi.bright_cyan": "#ED9265",
                "terminal.ansi.bright_white": "#c5c1c1",
                "modified": "#324A70",
                "syntax": {
                    "attribute": {
                        "color": "#324A70"
                    },
                    "boolean": {
                      "color": "#5C536B"
                    },
                    "comment": {
                      "color": "#6d5959"
                    },
                    "comment.doc": {
                      "color": "#6d5959"
                    },
                    "constant": {
                      "color": "#5C536B"
                    },
                    "function": {
                      "color": "#ED9265"
                    },
                    "keyword": {
                      "color": "#9F5E63"
                    },
                    "number": {
                      "color": "#E1675B"
                    },
                    "operator": {
                      "color": "#9F5E63"
                    },
                    "string": {
                      "color": "#324A70"
                    },
                    "variable": {
                      "color": "#5C536B"
                    }
                },
                "players": [
                  {
                    "cursor": "#324A70",
                    "background": "#170909",
                    "selection": "#324A7030"
                  }
                ]
            }
        }
    ]
}
