{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0d1c1f90",
                "editor.background": "#0d1c1f90",
                "editor.foreground": "#c2c6c7",
                "text": "#c2c6c7",
                "text.muted": "#c2c6c770",
                "text.ignored": "#c2c6c740",
                "text.placeholder": "#c2c6c750",
                "ignored": "#c2c6c730",
                "element.hover": "#c2c6c730",
                "ghost_element.hover": "#53564F30",
                "ghost_element.selected": "#53564F30",
                "ghost_element.active": "#53564F60",
                "border": "#0d1c1f",
                "editor.highlighted_line.background": "#53564F10",
                "editor.active_line.background": "#53564F10",
                "panel.background": "#0d1c1f90",
                "title_bar.background": "#0d1c1f90",
                "title_bar.inactive_background": "#0d1c1f90",
                "status_bar.background": "#0d1c1f90",
                "drop_target.background": "#0d1c1f90",
                "elevated_surface.background": "#0d1c1f",
                "toolbar.background": "#0d1c1f90",
                "tab_bar.background": "#0d1c1f90",
                "tab.inactive_background": "#0d1c1f90",
                "tab.active_background": "#53564F30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0d1c1f",
                "scrollbar.thumb.background": "#53564F",
                "editor.gutter.background": "#0d1c1f90",
                "terminal.background": "#0d1c1f10",
                "terminal.foreground": "#c2c6c7",
                "terminal.dim_foreground": "#c2c6c7",
                "terminal.bright_foreground": "#c2c6c7",
                "terminal.ansi.black": "#0d1c1f",
                "terminal.ansi.red": "#53564F",
                "terminal.ansi.green": "#936D55",
                "terminal.ansi.yellow": "#9E944B",
                "terminal.ansi.blue": "#26678E",
                "terminal.ansi.magenta": "#4F7291",
                "terminal.ansi.cyan": "#6492A0",
                "terminal.ansi.white": "#c2c6c7",
                "terminal.ansi.bright_black": "#5c6d71",
                "terminal.ansi.bright_red": "#53564F",
                "terminal.ansi.bright_green": "#936D55",
                "terminal.ansi.bright_yellow": "#9E944B",
                "terminal.ansi.bright_blue": "#26678E",
                "terminal.ansi.bright_magenta": "#4F7291",
                "terminal.ansi.bright_cyan": "#6492A0",
                "terminal.ansi.bright_white": "#c2c6c7",
                "modified": "#53564F",
                "syntax": {
                    "attribute": {
                        "color": "#53564F"
                    },
                    "boolean": {
                      "color": "#936D55"
                    },
                    "comment": {
                      "color": "#5c6d71"
                    },
                    "comment.doc": {
                      "color": "#5c6d71"
                    },
                    "constant": {
                      "color": "#936D55"
                    },
                    "function": {
                      "color": "#6492A0"
                    },
                    "keyword": {
                      "color": "#26678E"
                    },
                    "number": {
                      "color": "#4F7291"
                    },
                    "operator": {
                      "color": "#26678E"
                    },
                    "string": {
                      "color": "#53564F"
                    },
                    "variable": {
                      "color": "#936D55"
                    }
                },
                "players": [
                  {
                    "cursor": "#53564F",
                    "background": "#0d1c1f",
                    "selection": "#53564F30"
                  }
                ]
            }
        }
    ]
}
