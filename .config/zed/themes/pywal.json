{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#130e2190",
                "editor.background": "#130e2190",
                "editor.foreground": "#c4c2c7",
                "text": "#c4c2c7",
                "text.muted": "#c4c2c770",
                "text.ignored": "#c4c2c740",
                "text.placeholder": "#c4c2c750",
                "ignored": "#c4c2c730",
                "element.hover": "#c4c2c730",
                "ghost_element.hover": "#E48F6830",
                "ghost_element.selected": "#E48F6830",
                "ghost_element.active": "#E48F6860",
                "border": "#130e21",
                "editor.highlighted_line.background": "#E48F6810",
                "editor.active_line.background": "#E48F6810",
                "panel.background": "#130e2190",
                "title_bar.background": "#130e2190",
                "title_bar.inactive_background": "#130e2190",
                "status_bar.background": "#130e2190",
                "drop_target.background": "#130e2190",
                "elevated_surface.background": "#130e21",
                "toolbar.background": "#130e2190",
                "tab_bar.background": "#130e2190",
                "tab.inactive_background": "#130e2190",
                "tab.active_background": "#E48F6830",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#130e21",
                "scrollbar.thumb.background": "#E48F68",
                "editor.gutter.background": "#130e2190",
                "terminal.background": "#130e2110",
                "terminal.foreground": "#c4c2c7",
                "terminal.dim_foreground": "#c4c2c7",
                "terminal.bright_foreground": "#c4c2c7",
                "terminal.ansi.black": "#130e21",
                "terminal.ansi.red": "#E48F68",
                "terminal.ansi.green": "#31728D",
                "terminal.ansi.yellow": "#787D82",
                "terminal.ansi.blue": "#B36F86",
                "terminal.ansi.magenta": "#E86E92",
                "terminal.ansi.cyan": "#CBABA2",
                "terminal.ansi.white": "#c4c2c7",
                "terminal.ansi.bright_black": "#625d72",
                "terminal.ansi.bright_red": "#E48F68",
                "terminal.ansi.bright_green": "#31728D",
                "terminal.ansi.bright_yellow": "#787D82",
                "terminal.ansi.bright_blue": "#B36F86",
                "terminal.ansi.bright_magenta": "#E86E92",
                "terminal.ansi.bright_cyan": "#CBABA2",
                "terminal.ansi.bright_white": "#c4c2c7",
                "modified": "#E48F68",
                "syntax": {
                    "attribute": {
                        "color": "#E48F68"
                    },
                    "boolean": {
                      "color": "#31728D"
                    },
                    "comment": {
                      "color": "#625d72"
                    },
                    "comment.doc": {
                      "color": "#625d72"
                    },
                    "constant": {
                      "color": "#31728D"
                    },
                    "function": {
                      "color": "#CBABA2"
                    },
                    "keyword": {
                      "color": "#B36F86"
                    },
                    "number": {
                      "color": "#E86E92"
                    },
                    "operator": {
                      "color": "#B36F86"
                    },
                    "string": {
                      "color": "#E48F68"
                    },
                    "variable": {
                      "color": "#31728D"
                    }
                },
                "players": [
                  {
                    "cursor": "#E48F68",
                    "background": "#130e21",
                    "selection": "#E48F6830"
                  }
                ]
            }
        }
    ]
}
