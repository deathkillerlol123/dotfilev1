{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#1b1e2590",
                "editor.background": "#1b1e2590",
                "editor.foreground": "#c6c6c8",
                "text": "#c6c6c8",
                "text.muted": "#c6c6c870",
                "text.ignored": "#c6c6c840",
                "text.placeholder": "#c6c6c850",
                "ignored": "#c6c6c830",
                "element.hover": "#c6c6c830",
                "ghost_element.hover": "#A15E6930",
                "ghost_element.selected": "#A15E6930",
                "ghost_element.active": "#A15E6960",
                "border": "#1b1e25",
                "editor.highlighted_line.background": "#A15E6910",
                "editor.active_line.background": "#A15E6910",
                "panel.background": "#1b1e2590",
                "title_bar.background": "#1b1e2590",
                "title_bar.inactive_background": "#1b1e2590",
                "status_bar.background": "#1b1e2590",
                "drop_target.background": "#1b1e2590",
                "elevated_surface.background": "#1b1e25",
                "toolbar.background": "#1b1e2590",
                "tab_bar.background": "#1b1e2590",
                "tab.inactive_background": "#1b1e2590",
                "tab.active_background": "#A15E6930",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#1b1e25",
                "scrollbar.thumb.background": "#A15E69",
                "editor.gutter.background": "#1b1e2590",
                "terminal.background": "#1b1e2510",
                "terminal.foreground": "#c6c6c8",
                "terminal.dim_foreground": "#c6c6c8",
                "terminal.bright_foreground": "#c6c6c8",
                "terminal.ansi.black": "#1b1e25",
                "terminal.ansi.red": "#A15E69",
                "terminal.ansi.green": "#BE616A",
                "terminal.ansi.yellow": "#C5676B",
                "terminal.ansi.blue": "#A08E77",
                "terminal.ansi.magenta": "#D08870",
                "terminal.ansi.cyan": "#79798E",
                "terminal.ansi.white": "#c6c6c8",
                "terminal.ansi.bright_black": "#626878",
                "terminal.ansi.bright_red": "#A15E69",
                "terminal.ansi.bright_green": "#BE616A",
                "terminal.ansi.bright_yellow": "#C5676B",
                "terminal.ansi.bright_blue": "#A08E77",
                "terminal.ansi.bright_magenta": "#D08870",
                "terminal.ansi.bright_cyan": "#79798E",
                "terminal.ansi.bright_white": "#c6c6c8",
                "modified": "#A15E69",
                "syntax": {
                    "attribute": {
                        "color": "#A15E69"
                    },
                    "boolean": {
                      "color": "#BE616A"
                    },
                    "comment": {
                      "color": "#626878"
                    },
                    "comment.doc": {
                      "color": "#626878"
                    },
                    "constant": {
                      "color": "#BE616A"
                    },
                    "function": {
                      "color": "#79798E"
                    },
                    "keyword": {
                      "color": "#A08E77"
                    },
                    "number": {
                      "color": "#D08870"
                    },
                    "operator": {
                      "color": "#A08E77"
                    },
                    "string": {
                      "color": "#A15E69"
                    },
                    "variable": {
                      "color": "#BE616A"
                    }
                },
                "players": [
                  {
                    "cursor": "#A15E69",
                    "background": "#1b1e25",
                    "selection": "#A15E6930"
                  }
                ]
            }
        }
    ]
}
