{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#080c1490",
                "editor.background": "#080c1490",
                "editor.foreground": "#c1c2c4",
                "text": "#c1c2c4",
                "text.muted": "#c1c2c470",
                "text.ignored": "#c1c2c440",
                "text.placeholder": "#c1c2c450",
                "ignored": "#c1c2c430",
                "element.hover": "#c1c2c430",
                "ghost_element.hover": "#16556530",
                "ghost_element.selected": "#16556530",
                "ghost_element.active": "#16556560",
                "border": "#080c14",
                "editor.highlighted_line.background": "#16556510",
                "editor.active_line.background": "#16556510",
                "panel.background": "#080c1490",
                "title_bar.background": "#080c1490",
                "title_bar.inactive_background": "#080c1490",
                "status_bar.background": "#080c1490",
                "drop_target.background": "#080c1490",
                "elevated_surface.background": "#080c14",
                "toolbar.background": "#080c1490",
                "tab_bar.background": "#080c1490",
                "tab.inactive_background": "#080c1490",
                "tab.active_background": "#16556530",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#080c14",
                "scrollbar.thumb.background": "#165565",
                "editor.gutter.background": "#080c1490",
                "terminal.background": "#080c1410",
                "terminal.foreground": "#c1c2c4",
                "terminal.dim_foreground": "#c1c2c4",
                "terminal.bright_foreground": "#c1c2c4",
                "terminal.ansi.black": "#080c14",
                "terminal.ansi.red": "#165565",
                "terminal.ansi.green": "#056C71",
                "terminal.ansi.yellow": "#434156",
                "terminal.ansi.blue": "#0E7587",
                "terminal.ansi.magenta": "#65428D",
                "terminal.ansi.cyan": "#85439C",
                "terminal.ansi.white": "#c1c2c4",
                "terminal.ansi.bright_black": "#585f6b",
                "terminal.ansi.bright_red": "#165565",
                "terminal.ansi.bright_green": "#056C71",
                "terminal.ansi.bright_yellow": "#434156",
                "terminal.ansi.bright_blue": "#0E7587",
                "terminal.ansi.bright_magenta": "#65428D",
                "terminal.ansi.bright_cyan": "#85439C",
                "terminal.ansi.bright_white": "#c1c2c4",
                "modified": "#165565",
                "syntax": {
                    "attribute": {
                        "color": "#165565"
                    },
                    "boolean": {
                      "color": "#056C71"
                    },
                    "comment": {
                      "color": "#585f6b"
                    },
                    "comment.doc": {
                      "color": "#585f6b"
                    },
                    "constant": {
                      "color": "#056C71"
                    },
                    "function": {
                      "color": "#85439C"
                    },
                    "keyword": {
                      "color": "#0E7587"
                    },
                    "number": {
                      "color": "#65428D"
                    },
                    "operator": {
                      "color": "#0E7587"
                    },
                    "string": {
                      "color": "#165565"
                    },
                    "variable": {
                      "color": "#056C71"
                    }
                },
                "players": [
                  {
                    "cursor": "#165565",
                    "background": "#080c14",
                    "selection": "#16556530"
                  }
                ]
            }
        }
    ]
}
