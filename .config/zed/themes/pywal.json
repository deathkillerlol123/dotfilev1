{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0e142290",
                "editor.background": "#0e142290",
                "editor.foreground": "#c2c4c7",
                "text": "#c2c4c7",
                "text.muted": "#c2c4c770",
                "text.ignored": "#c2c4c740",
                "text.placeholder": "#c2c4c750",
                "ignored": "#c2c4c730",
                "element.hover": "#c2c4c730",
                "ghost_element.hover": "#28497130",
                "ghost_element.selected": "#28497130",
                "ghost_element.active": "#28497160",
                "border": "#0e1422",
                "editor.highlighted_line.background": "#28497110",
                "editor.active_line.background": "#28497110",
                "panel.background": "#0e142290",
                "title_bar.background": "#0e142290",
                "title_bar.inactive_background": "#0e142290",
                "status_bar.background": "#0e142290",
                "drop_target.background": "#0e142290",
                "elevated_surface.background": "#0e1422",
                "toolbar.background": "#0e142290",
                "tab_bar.background": "#0e142290",
                "tab.inactive_background": "#0e142290",
                "tab.active_background": "#28497130",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0e1422",
                "scrollbar.thumb.background": "#284971",
                "editor.gutter.background": "#0e142290",
                "terminal.background": "#0e142210",
                "terminal.foreground": "#c2c4c7",
                "terminal.dim_foreground": "#c2c4c7",
                "terminal.bright_foreground": "#c2c4c7",
                "terminal.ansi.black": "#0e1422",
                "terminal.ansi.red": "#284971",
                "terminal.ansi.green": "#9B2B34",
                "terminal.ansi.yellow": "#C74648",
                "terminal.ansi.blue": "#F5AE68",
                "terminal.ansi.magenta": "#2F6598",
                "terminal.ansi.cyan": "#556E9B",
                "terminal.ansi.white": "#c2c4c7",
                "terminal.ansi.bright_black": "#5e6472",
                "terminal.ansi.bright_red": "#284971",
                "terminal.ansi.bright_green": "#9B2B34",
                "terminal.ansi.bright_yellow": "#C74648",
                "terminal.ansi.bright_blue": "#F5AE68",
                "terminal.ansi.bright_magenta": "#2F6598",
                "terminal.ansi.bright_cyan": "#556E9B",
                "terminal.ansi.bright_white": "#c2c4c7",
                "modified": "#284971",
                "syntax": {
                    "attribute": {
                        "color": "#284971"
                    },
                    "boolean": {
                      "color": "#9B2B34"
                    },
                    "comment": {
                      "color": "#5e6472"
                    },
                    "comment.doc": {
                      "color": "#5e6472"
                    },
                    "constant": {
                      "color": "#9B2B34"
                    },
                    "function": {
                      "color": "#556E9B"
                    },
                    "keyword": {
                      "color": "#F5AE68"
                    },
                    "number": {
                      "color": "#2F6598"
                    },
                    "operator": {
                      "color": "#F5AE68"
                    },
                    "string": {
                      "color": "#284971"
                    },
                    "variable": {
                      "color": "#9B2B34"
                    }
                },
                "players": [
                  {
                    "cursor": "#284971",
                    "background": "#0e1422",
                    "selection": "#28497130"
                  }
                ]
            }
        }
    ]
}
