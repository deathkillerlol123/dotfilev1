{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0f152290",
                "editor.background": "#0f152290",
                "editor.foreground": "#c3c4c7",
                "text": "#c3c4c7",
                "text.muted": "#c3c4c770",
                "text.ignored": "#c3c4c740",
                "text.placeholder": "#c3c4c750",
                "ignored": "#c3c4c730",
                "element.hover": "#c3c4c730",
                "ghost_element.hover": "#54305330",
                "ghost_element.selected": "#54305330",
                "ghost_element.active": "#54305360",
                "border": "#0f1522",
                "editor.highlighted_line.background": "#54305310",
                "editor.active_line.background": "#54305310",
                "panel.background": "#0f152290",
                "title_bar.background": "#0f152290",
                "title_bar.inactive_background": "#0f152290",
                "status_bar.background": "#0f152290",
                "drop_target.background": "#0f152290",
                "elevated_surface.background": "#0f1522",
                "toolbar.background": "#0f152290",
                "tab_bar.background": "#0f152290",
                "tab.inactive_background": "#0f152290",
                "tab.active_background": "#54305330",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0f1522",
                "scrollbar.thumb.background": "#543053",
                "editor.gutter.background": "#0f152290",
                "terminal.background": "#0f152210",
                "terminal.foreground": "#c3c4c7",
                "terminal.dim_foreground": "#c3c4c7",
                "terminal.bright_foreground": "#c3c4c7",
                "terminal.ansi.black": "#0f1522",
                "terminal.ansi.red": "#543053",
                "terminal.ansi.green": "#3B405A",
                "terminal.ansi.yellow": "#575171",
                "terminal.ansi.blue": "#364B8E",
                "terminal.ansi.magenta": "#5A6696",
                "terminal.ansi.cyan": "#7C7E98",
                "terminal.ansi.white": "#c3c4c7",
                "terminal.ansi.bright_black": "#5e6373",
                "terminal.ansi.bright_red": "#543053",
                "terminal.ansi.bright_green": "#3B405A",
                "terminal.ansi.bright_yellow": "#575171",
                "terminal.ansi.bright_blue": "#364B8E",
                "terminal.ansi.bright_magenta": "#5A6696",
                "terminal.ansi.bright_cyan": "#7C7E98",
                "terminal.ansi.bright_white": "#c3c4c7",
                "modified": "#543053",
                "syntax": {
                    "attribute": {
                        "color": "#543053"
                    },
                    "boolean": {
                      "color": "#3B405A"
                    },
                    "comment": {
                      "color": "#5e6373"
                    },
                    "comment.doc": {
                      "color": "#5e6373"
                    },
                    "constant": {
                      "color": "#3B405A"
                    },
                    "function": {
                      "color": "#7C7E98"
                    },
                    "keyword": {
                      "color": "#364B8E"
                    },
                    "number": {
                      "color": "#5A6696"
                    },
                    "operator": {
                      "color": "#364B8E"
                    },
                    "string": {
                      "color": "#543053"
                    },
                    "variable": {
                      "color": "#3B405A"
                    }
                },
                "players": [
                  {
                    "cursor": "#543053",
                    "background": "#0f1522",
                    "selection": "#54305330"
                  }
                ]
            }
        }
    ]
}
