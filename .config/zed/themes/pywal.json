{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#10102590",
                "editor.background": "#10102590",
                "editor.foreground": "#c3c3c8",
                "text": "#c3c3c8",
                "text.muted": "#c3c3c870",
                "text.ignored": "#c3c3c840",
                "text.placeholder": "#c3c3c850",
                "ignored": "#c3c3c830",
                "element.hover": "#c3c3c830",
                "ghost_element.hover": "#67486030",
                "ghost_element.selected": "#67486030",
                "ghost_element.active": "#67486060",
                "border": "#101025",
                "editor.highlighted_line.background": "#67486010",
                "editor.active_line.background": "#67486010",
                "panel.background": "#10102590",
                "title_bar.background": "#10102590",
                "title_bar.inactive_background": "#10102590",
                "status_bar.background": "#10102590",
                "drop_target.background": "#10102590",
                "elevated_surface.background": "#101025",
                "toolbar.background": "#10102590",
                "tab_bar.background": "#10102590",
                "tab.inactive_background": "#10102590",
                "tab.active_background": "#67486030",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#101025",
                "scrollbar.thumb.background": "#674860",
                "editor.gutter.background": "#10102590",
                "terminal.background": "#10102510",
                "terminal.foreground": "#c3c3c8",
                "terminal.dim_foreground": "#c3c3c8",
                "terminal.bright_foreground": "#c3c3c8",
                "terminal.ansi.black": "#101025",
                "terminal.ansi.red": "#674860",
                "terminal.ansi.green": "#8D3C4D",
                "terminal.ansi.yellow": "#9C5B64",
                "terminal.ansi.blue": "#D6736C",
                "terminal.ansi.magenta": "#EF9970",
                "terminal.ansi.cyan": "#FBCF78",
                "terminal.ansi.white": "#c3c3c8",
                "terminal.ansi.bright_black": "#5f5f74",
                "terminal.ansi.bright_red": "#674860",
                "terminal.ansi.bright_green": "#8D3C4D",
                "terminal.ansi.bright_yellow": "#9C5B64",
                "terminal.ansi.bright_blue": "#D6736C",
                "terminal.ansi.bright_magenta": "#EF9970",
                "terminal.ansi.bright_cyan": "#FBCF78",
                "terminal.ansi.bright_white": "#c3c3c8",
                "modified": "#674860",
                "syntax": {
                    "attribute": {
                        "color": "#674860"
                    },
                    "boolean": {
                      "color": "#8D3C4D"
                    },
                    "comment": {
                      "color": "#5f5f74"
                    },
                    "comment.doc": {
                      "color": "#5f5f74"
                    },
                    "constant": {
                      "color": "#8D3C4D"
                    },
                    "function": {
                      "color": "#FBCF78"
                    },
                    "keyword": {
                      "color": "#D6736C"
                    },
                    "number": {
                      "color": "#EF9970"
                    },
                    "operator": {
                      "color": "#D6736C"
                    },
                    "string": {
                      "color": "#674860"
                    },
                    "variable": {
                      "color": "#8D3C4D"
                    }
                },
                "players": [
                  {
                    "cursor": "#674860",
                    "background": "#101025",
                    "selection": "#67486030"
                  }
                ]
            }
        }
    ]
}
