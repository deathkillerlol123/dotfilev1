{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0a0e1990",
                "editor.background": "#0a0e1990",
                "editor.foreground": "#c1c2c5",
                "text": "#c1c2c5",
                "text.muted": "#c1c2c570",
                "text.ignored": "#c1c2c540",
                "text.placeholder": "#c1c2c550",
                "ignored": "#c1c2c530",
                "element.hover": "#c1c2c530",
                "ghost_element.hover": "#36394430",
                "ghost_element.selected": "#36394430",
                "ghost_element.active": "#36394460",
                "border": "#0a0e19",
                "editor.highlighted_line.background": "#36394410",
                "editor.active_line.background": "#36394410",
                "panel.background": "#0a0e1990",
                "title_bar.background": "#0a0e1990",
                "title_bar.inactive_background": "#0a0e1990",
                "status_bar.background": "#0a0e1990",
                "drop_target.background": "#0a0e1990",
                "elevated_surface.background": "#0a0e19",
                "toolbar.background": "#0a0e1990",
                "tab_bar.background": "#0a0e1990",
                "tab.inactive_background": "#0a0e1990",
                "tab.active_background": "#36394430",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0a0e19",
                "scrollbar.thumb.background": "#363944",
                "editor.gutter.background": "#0a0e1990",
                "terminal.background": "#0a0e1910",
                "terminal.foreground": "#c1c2c5",
                "terminal.dim_foreground": "#c1c2c5",
                "terminal.bright_foreground": "#c1c2c5",
                "terminal.ansi.black": "#0a0e19",
                "terminal.ansi.red": "#363944",
                "terminal.ansi.green": "#3A4551",
                "terminal.ansi.yellow": "#4F4B4E",
                "terminal.ansi.blue": "#69615D",
                "terminal.ansi.magenta": "#857460",
                "terminal.ansi.cyan": "#8C8673",
                "terminal.ansi.white": "#c1c2c5",
                "terminal.ansi.bright_black": "#59606e",
                "terminal.ansi.bright_red": "#363944",
                "terminal.ansi.bright_green": "#3A4551",
                "terminal.ansi.bright_yellow": "#4F4B4E",
                "terminal.ansi.bright_blue": "#69615D",
                "terminal.ansi.bright_magenta": "#857460",
                "terminal.ansi.bright_cyan": "#8C8673",
                "terminal.ansi.bright_white": "#c1c2c5",
                "modified": "#363944",
                "syntax": {
                    "attribute": {
                        "color": "#363944"
                    },
                    "boolean": {
                      "color": "#3A4551"
                    },
                    "comment": {
                      "color": "#59606e"
                    },
                    "comment.doc": {
                      "color": "#59606e"
                    },
                    "constant": {
                      "color": "#3A4551"
                    },
                    "function": {
                      "color": "#8C8673"
                    },
                    "keyword": {
                      "color": "#69615D"
                    },
                    "number": {
                      "color": "#857460"
                    },
                    "operator": {
                      "color": "#69615D"
                    },
                    "string": {
                      "color": "#363944"
                    },
                    "variable": {
                      "color": "#3A4551"
                    }
                },
                "players": [
                  {
                    "cursor": "#363944",
                    "background": "#0a0e19",
                    "selection": "#36394430"
                  }
                ]
            }
        }
    ]
}
