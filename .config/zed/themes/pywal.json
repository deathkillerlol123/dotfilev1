{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#09040490",
                "editor.background": "#09040490",
                "editor.foreground": "#c1c0c0",
                "text": "#c1c0c0",
                "text.muted": "#c1c0c070",
                "text.ignored": "#c1c0c040",
                "text.placeholder": "#c1c0c050",
                "ignored": "#c1c0c030",
                "element.hover": "#c1c0c030",
                "ghost_element.hover": "#34343430",
                "ghost_element.selected": "#34343430",
                "ghost_element.active": "#34343460",
                "border": "#090404",
                "editor.highlighted_line.background": "#34343410",
                "editor.active_line.background": "#34343410",
                "panel.background": "#09040490",
                "title_bar.background": "#09040490",
                "title_bar.inactive_background": "#09040490",
                "status_bar.background": "#09040490",
                "drop_target.background": "#09040490",
                "elevated_surface.background": "#090404",
                "toolbar.background": "#09040490",
                "tab_bar.background": "#09040490",
                "tab.inactive_background": "#09040490",
                "tab.active_background": "#34343430",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#090404",
                "scrollbar.thumb.background": "#343434",
                "editor.gutter.background": "#09040490",
                "terminal.background": "#09040410",
                "terminal.foreground": "#c1c0c0",
                "terminal.dim_foreground": "#c1c0c0",
                "terminal.bright_foreground": "#c1c0c0",
                "terminal.ansi.black": "#090404",
                "terminal.ansi.red": "#343434",
                "terminal.ansi.green": "#3C3C3C",
                "terminal.ansi.yellow": "#424242",
                "terminal.ansi.blue": "#454545",
                "terminal.ansi.magenta": "#4B4B4B",
                "terminal.ansi.cyan": "#535353",
                "terminal.ansi.white": "#c1c0c0",
                "terminal.ansi.bright_black": "#665353",
                "terminal.ansi.bright_red": "#343434",
                "terminal.ansi.bright_green": "#3C3C3C",
                "terminal.ansi.bright_yellow": "#424242",
                "terminal.ansi.bright_blue": "#454545",
                "terminal.ansi.bright_magenta": "#4B4B4B",
                "terminal.ansi.bright_cyan": "#535353",
                "terminal.ansi.bright_white": "#c1c0c0",
                "modified": "#343434",
                "syntax": {
                    "attribute": {
                        "color": "#343434"
                    },
                    "boolean": {
                      "color": "#3C3C3C"
                    },
                    "comment": {
                      "color": "#665353"
                    },
                    "comment.doc": {
                      "color": "#665353"
                    },
                    "constant": {
                      "color": "#3C3C3C"
                    },
                    "function": {
                      "color": "#535353"
                    },
                    "keyword": {
                      "color": "#454545"
                    },
                    "number": {
                      "color": "#4B4B4B"
                    },
                    "operator": {
                      "color": "#454545"
                    },
                    "string": {
                      "color": "#343434"
                    },
                    "variable": {
                      "color": "#3C3C3C"
                    }
                },
                "players": [
                  {
                    "cursor": "#343434",
                    "background": "#090404",
                    "selection": "#34343430"
                  }
                ]
            }
        }
    ]
}
