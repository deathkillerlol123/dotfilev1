{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0c141d90",
                "editor.background": "#0c141d90",
                "editor.foreground": "#c2c4c6",
                "text": "#c2c4c6",
                "text.muted": "#c2c4c670",
                "text.ignored": "#c2c4c640",
                "text.placeholder": "#c2c4c650",
                "ignored": "#c2c4c630",
                "element.hover": "#c2c4c630",
                "ghost_element.hover": "#55626130",
                "ghost_element.selected": "#55626130",
                "ghost_element.active": "#55626160",
                "border": "#0c141d",
                "editor.highlighted_line.background": "#55626110",
                "editor.active_line.background": "#55626110",
                "panel.background": "#0c141d90",
                "title_bar.background": "#0c141d90",
                "title_bar.inactive_background": "#0c141d90",
                "status_bar.background": "#0c141d90",
                "drop_target.background": "#0c141d90",
                "elevated_surface.background": "#0c141d",
                "toolbar.background": "#0c141d90",
                "tab_bar.background": "#0c141d90",
                "tab.inactive_background": "#0c141d90",
                "tab.active_background": "#55626130",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0c141d",
                "scrollbar.thumb.background": "#556261",
                "editor.gutter.background": "#0c141d90",
                "terminal.background": "#0c141d10",
                "terminal.foreground": "#c2c4c6",
                "terminal.dim_foreground": "#c2c4c6",
                "terminal.bright_foreground": "#c2c4c6",
                "terminal.ansi.black": "#0c141d",
                "terminal.ansi.red": "#556261",
                "terminal.ansi.green": "#827B57",
                "terminal.ansi.yellow": "#A19B52",
                "terminal.ansi.blue": "#3E6681",
                "terminal.ansi.magenta": "#547588",
                "terminal.ansi.cyan": "#6F8C9A",
                "terminal.ansi.white": "#c2c4c6",
                "terminal.ansi.bright_black": "#5c6570",
                "terminal.ansi.bright_red": "#556261",
                "terminal.ansi.bright_green": "#827B57",
                "terminal.ansi.bright_yellow": "#A19B52",
                "terminal.ansi.bright_blue": "#3E6681",
                "terminal.ansi.bright_magenta": "#547588",
                "terminal.ansi.bright_cyan": "#6F8C9A",
                "terminal.ansi.bright_white": "#c2c4c6",
                "modified": "#556261",
                "syntax": {
                    "attribute": {
                        "color": "#556261"
                    },
                    "boolean": {
                      "color": "#827B57"
                    },
                    "comment": {
                      "color": "#5c6570"
                    },
                    "comment.doc": {
                      "color": "#5c6570"
                    },
                    "constant": {
                      "color": "#827B57"
                    },
                    "function": {
                      "color": "#6F8C9A"
                    },
                    "keyword": {
                      "color": "#3E6681"
                    },
                    "number": {
                      "color": "#547588"
                    },
                    "operator": {
                      "color": "#3E6681"
                    },
                    "string": {
                      "color": "#556261"
                    },
                    "variable": {
                      "color": "#827B57"
                    }
                },
                "players": [
                  {
                    "cursor": "#556261",
                    "background": "#0c141d",
                    "selection": "#55626130"
                  }
                ]
            }
        }
    ]
}
