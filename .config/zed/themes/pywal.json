{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#141d2e90",
                "editor.background": "#141d2e90",
                "editor.foreground": "#c4c6ca",
                "text": "#c4c6ca",
                "text.muted": "#c4c6ca70",
                "text.ignored": "#c4c6ca40",
                "text.placeholder": "#c4c6ca50",
                "ignored": "#c4c6ca30",
                "element.hover": "#c4c6ca30",
                "ghost_element.hover": "#A23B3030",
                "ghost_element.selected": "#A23B3030",
                "ghost_element.active": "#A23B3060",
                "border": "#141d2e",
                "editor.highlighted_line.background": "#A23B3010",
                "editor.active_line.background": "#A23B3010",
                "panel.background": "#141d2e90",
                "title_bar.background": "#141d2e90",
                "title_bar.inactive_background": "#141d2e90",
                "status_bar.background": "#141d2e90",
                "drop_target.background": "#141d2e90",
                "elevated_surface.background": "#141d2e",
                "toolbar.background": "#141d2e90",
                "tab_bar.background": "#141d2e90",
                "tab.inactive_background": "#141d2e90",
                "tab.active_background": "#A23B3030",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#141d2e",
                "scrollbar.thumb.background": "#A23B30",
                "editor.gutter.background": "#141d2e90",
                "terminal.background": "#141d2e10",
                "terminal.foreground": "#c4c6ca",
                "terminal.dim_foreground": "#c4c6ca",
                "terminal.bright_foreground": "#c4c6ca",
                "terminal.ansi.black": "#141d2e",
                "terminal.ansi.red": "#A23B30",
                "terminal.ansi.green": "#E56537",
                "terminal.ansi.yellow": "#A35455",
                "terminal.ansi.blue": "#DB694C",
                "terminal.ansi.magenta": "#F49E51",
                "terminal.ansi.cyan": "#F7A748",
                "terminal.ansi.white": "#c4c6ca",
                "terminal.ansi.bright_black": "#636b79",
                "terminal.ansi.bright_red": "#A23B30",
                "terminal.ansi.bright_green": "#E56537",
                "terminal.ansi.bright_yellow": "#A35455",
                "terminal.ansi.bright_blue": "#DB694C",
                "terminal.ansi.bright_magenta": "#F49E51",
                "terminal.ansi.bright_cyan": "#F7A748",
                "terminal.ansi.bright_white": "#c4c6ca",
                "modified": "#A23B30",
                "syntax": {
                    "attribute": {
                        "color": "#A23B30"
                    },
                    "boolean": {
                      "color": "#E56537"
                    },
                    "comment": {
                      "color": "#636b79"
                    },
                    "comment.doc": {
                      "color": "#636b79"
                    },
                    "constant": {
                      "color": "#E56537"
                    },
                    "function": {
                      "color": "#F7A748"
                    },
                    "keyword": {
                      "color": "#DB694C"
                    },
                    "number": {
                      "color": "#F49E51"
                    },
                    "operator": {
                      "color": "#DB694C"
                    },
                    "string": {
                      "color": "#A23B30"
                    },
                    "variable": {
                      "color": "#E56537"
                    }
                },
                "players": [
                  {
                    "cursor": "#A23B30",
                    "background": "#141d2e",
                    "selection": "#A23B3030"
                  }
                ]
            }
        }
    ]
}
