{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#12151690",
                "editor.background": "#12151690",
                "editor.foreground": "#c3c4c4",
                "text": "#c3c4c4",
                "text.muted": "#c3c4c470",
                "text.ignored": "#c3c4c440",
                "text.placeholder": "#c3c4c450",
                "ignored": "#c3c4c430",
                "element.hover": "#c3c4c430",
                "ghost_element.hover": "#5C708530",
                "ghost_element.selected": "#5C708530",
                "ghost_element.active": "#5C708560",
                "border": "#121516",
                "editor.highlighted_line.background": "#5C708510",
                "editor.active_line.background": "#5C708510",
                "panel.background": "#12151690",
                "title_bar.background": "#12151690",
                "title_bar.inactive_background": "#12151690",
                "status_bar.background": "#12151690",
                "drop_target.background": "#12151690",
                "elevated_surface.background": "#121516",
                "toolbar.background": "#12151690",
                "tab_bar.background": "#12151690",
                "tab.inactive_background": "#12151690",
                "tab.active_background": "#5C708530",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#121516",
                "scrollbar.thumb.background": "#5C7085",
                "editor.gutter.background": "#12151690",
                "terminal.background": "#12151610",
                "terminal.foreground": "#c3c4c4",
                "terminal.dim_foreground": "#c3c4c4",
                "terminal.bright_foreground": "#c3c4c4",
                "terminal.ansi.black": "#121516",
                "terminal.ansi.red": "#5C7085",
                "terminal.ansi.green": "#67798A",
                "terminal.ansi.yellow": "#74899E",
                "terminal.ansi.blue": "#7F9BC1",
                "terminal.ansi.magenta": "#869AA9",
                "terminal.ansi.cyan": "#92A7B6",
                "terminal.ansi.white": "#c3c4c4",
                "terminal.ansi.bright_black": "#5b686f",
                "terminal.ansi.bright_red": "#5C7085",
                "terminal.ansi.bright_green": "#67798A",
                "terminal.ansi.bright_yellow": "#74899E",
                "terminal.ansi.bright_blue": "#7F9BC1",
                "terminal.ansi.bright_magenta": "#869AA9",
                "terminal.ansi.bright_cyan": "#92A7B6",
                "terminal.ansi.bright_white": "#c3c4c4",
                "modified": "#5C7085",
                "syntax": {
                    "attribute": {
                        "color": "#5C7085"
                    },
                    "boolean": {
                      "color": "#67798A"
                    },
                    "comment": {
                      "color": "#5b686f"
                    },
                    "comment.doc": {
                      "color": "#5b686f"
                    },
                    "constant": {
                      "color": "#67798A"
                    },
                    "function": {
                      "color": "#92A7B6"
                    },
                    "keyword": {
                      "color": "#7F9BC1"
                    },
                    "number": {
                      "color": "#869AA9"
                    },
                    "operator": {
                      "color": "#7F9BC1"
                    },
                    "string": {
                      "color": "#5C7085"
                    },
                    "variable": {
                      "color": "#67798A"
                    }
                },
                "players": [
                  {
                    "cursor": "#5C7085",
                    "background": "#121516",
                    "selection": "#5C708530"
                  }
                ]
            }
        }
    ]
}
