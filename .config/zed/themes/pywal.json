{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0d0d1e90",
                "editor.background": "#0d0d1e90",
                "editor.foreground": "#c2c2c6",
                "text": "#c2c2c6",
                "text.muted": "#c2c2c670",
                "text.ignored": "#c2c2c640",
                "text.placeholder": "#c2c2c650",
                "ignored": "#c2c2c630",
                "element.hover": "#c2c2c630",
                "ghost_element.hover": "#52556930",
                "ghost_element.selected": "#52556930",
                "ghost_element.active": "#52556960",
                "border": "#0d0d1e",
                "editor.highlighted_line.background": "#52556910",
                "editor.active_line.background": "#52556910",
                "panel.background": "#0d0d1e90",
                "title_bar.background": "#0d0d1e90",
                "title_bar.inactive_background": "#0d0d1e90",
                "status_bar.background": "#0d0d1e90",
                "drop_target.background": "#0d0d1e90",
                "elevated_surface.background": "#0d0d1e",
                "toolbar.background": "#0d0d1e90",
                "tab_bar.background": "#0d0d1e90",
                "tab.inactive_background": "#0d0d1e90",
                "tab.active_background": "#52556930",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0d0d1e",
                "scrollbar.thumb.background": "#525569",
                "editor.gutter.background": "#0d0d1e90",
                "terminal.background": "#0d0d1e10",
                "terminal.foreground": "#c2c2c6",
                "terminal.dim_foreground": "#c2c2c6",
                "terminal.bright_foreground": "#c2c2c6",
                "terminal.ansi.black": "#0d0d1e",
                "terminal.ansi.red": "#525569",
                "terminal.ansi.green": "#636478",
                "terminal.ansi.yellow": "#88717A",
                "terminal.ansi.blue": "#6E738A",
                "terminal.ansi.magenta": "#907892",
                "terminal.ansi.cyan": "#798AA2",
                "terminal.ansi.white": "#c2c2c6",
                "terminal.ansi.bright_black": "#5c5c70",
                "terminal.ansi.bright_red": "#525569",
                "terminal.ansi.bright_green": "#636478",
                "terminal.ansi.bright_yellow": "#88717A",
                "terminal.ansi.bright_blue": "#6E738A",
                "terminal.ansi.bright_magenta": "#907892",
                "terminal.ansi.bright_cyan": "#798AA2",
                "terminal.ansi.bright_white": "#c2c2c6",
                "modified": "#525569",
                "syntax": {
                    "attribute": {
                        "color": "#525569"
                    },
                    "boolean": {
                      "color": "#636478"
                    },
                    "comment": {
                      "color": "#5c5c70"
                    },
                    "comment.doc": {
                      "color": "#5c5c70"
                    },
                    "constant": {
                      "color": "#636478"
                    },
                    "function": {
                      "color": "#798AA2"
                    },
                    "keyword": {
                      "color": "#6E738A"
                    },
                    "number": {
                      "color": "#907892"
                    },
                    "operator": {
                      "color": "#6E738A"
                    },
                    "string": {
                      "color": "#525569"
                    },
                    "variable": {
                      "color": "#636478"
                    }
                },
                "players": [
                  {
                    "cursor": "#525569",
                    "background": "#0d0d1e",
                    "selection": "#52556930"
                  }
                ]
            }
        }
    ]
}
