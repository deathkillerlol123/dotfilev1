{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#12121c90",
                "editor.background": "#12121c90",
                "editor.foreground": "#c3c3c6",
                "text": "#c3c3c6",
                "text.muted": "#c3c3c670",
                "text.ignored": "#c3c3c640",
                "text.placeholder": "#c3c3c650",
                "ignored": "#c3c3c630",
                "element.hover": "#c3c3c630",
                "ghost_element.hover": "#2C354B30",
                "ghost_element.selected": "#2C354B30",
                "ghost_element.active": "#2C354B60",
                "border": "#12121c",
                "editor.highlighted_line.background": "#2C354B10",
                "editor.active_line.background": "#2C354B10",
                "panel.background": "#12121c90",
                "title_bar.background": "#12121c90",
                "title_bar.inactive_background": "#12121c90",
                "status_bar.background": "#12121c90",
                "drop_target.background": "#12121c90",
                "elevated_surface.background": "#12121c",
                "toolbar.background": "#12121c90",
                "tab_bar.background": "#12121c90",
                "tab.inactive_background": "#12121c90",
                "tab.active_background": "#2C354B30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#12121c",
                "scrollbar.thumb.background": "#2C354B",
                "editor.gutter.background": "#12121c90",
                "terminal.background": "#12121c10",
                "terminal.foreground": "#c3c3c6",
                "terminal.dim_foreground": "#c3c3c6",
                "terminal.bright_foreground": "#c3c3c6",
                "terminal.ansi.black": "#12121c",
                "terminal.ansi.red": "#2C354B",
                "terminal.ansi.green": "#2C3661",
                "terminal.ansi.yellow": "#493147",
                "terminal.ansi.blue": "#482962",
                "terminal.ansi.magenta": "#364B57",
                "terminal.ansi.cyan": "#365161",
                "terminal.ansi.white": "#c3c3c6",
                "terminal.ansi.bright_black": "#5d5d71",
                "terminal.ansi.bright_red": "#2C354B",
                "terminal.ansi.bright_green": "#2C3661",
                "terminal.ansi.bright_yellow": "#493147",
                "terminal.ansi.bright_blue": "#482962",
                "terminal.ansi.bright_magenta": "#364B57",
                "terminal.ansi.bright_cyan": "#365161",
                "terminal.ansi.bright_white": "#c3c3c6",
                "modified": "#2C354B",
                "syntax": {
                    "attribute": {
                        "color": "#2C354B"
                    },
                    "boolean": {
                      "color": "#2C3661"
                    },
                    "comment": {
                      "color": "#5d5d71"
                    },
                    "comment.doc": {
                      "color": "#5d5d71"
                    },
                    "constant": {
                      "color": "#2C3661"
                    },
                    "function": {
                      "color": "#365161"
                    },
                    "keyword": {
                      "color": "#482962"
                    },
                    "number": {
                      "color": "#364B57"
                    },
                    "operator": {
                      "color": "#482962"
                    },
                    "string": {
                      "color": "#2C354B"
                    },
                    "variable": {
                      "color": "#2C3661"
                    }
                },
                "players": [
                  {
                    "cursor": "#2C354B",
                    "background": "#12121c",
                    "selection": "#2C354B30"
                  }
                ]
            }
        }
    ]
}
