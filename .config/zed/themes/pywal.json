{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#181b1b90",
                "editor.background": "#181b1b90",
                "editor.foreground": "#c5c6c6",
                "text": "#c5c6c6",
                "text.muted": "#c5c6c670",
                "text.ignored": "#c5c6c640",
                "text.placeholder": "#c5c6c650",
                "ignored": "#c5c6c630",
                "element.hover": "#c5c6c630",
                "ghost_element.hover": "#8F342A30",
                "ghost_element.selected": "#8F342A30",
                "ghost_element.active": "#8F342A60",
                "border": "#181b1b",
                "editor.highlighted_line.background": "#8F342A10",
                "editor.active_line.background": "#8F342A10",
                "panel.background": "#181b1b90",
                "title_bar.background": "#181b1b90",
                "title_bar.inactive_background": "#181b1b90",
                "status_bar.background": "#181b1b90",
                "drop_target.background": "#181b1b90",
                "elevated_surface.background": "#181b1b",
                "toolbar.background": "#181b1b90",
                "tab_bar.background": "#181b1b90",
                "tab.inactive_background": "#181b1b90",
                "tab.active_background": "#8F342A30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#181b1b",
                "scrollbar.thumb.background": "#8F342A",
                "editor.gutter.background": "#181b1b90",
                "terminal.background": "#181b1b10",
                "terminal.foreground": "#c5c6c6",
                "terminal.dim_foreground": "#c5c6c6",
                "terminal.bright_foreground": "#c5c6c6",
                "terminal.ansi.black": "#181b1b",
                "terminal.ansi.red": "#8F342A",
                "terminal.ansi.green": "#944F2D",
                "terminal.ansi.yellow": "#9A6D36",
                "terminal.ansi.blue": "#8B7852",
                "terminal.ansi.magenta": "#A4853C",
                "terminal.ansi.cyan": "#A0905B",
                "terminal.ansi.white": "#c5c6c6",
                "terminal.ansi.bright_black": "#5e7373",
                "terminal.ansi.bright_red": "#8F342A",
                "terminal.ansi.bright_green": "#944F2D",
                "terminal.ansi.bright_yellow": "#9A6D36",
                "terminal.ansi.bright_blue": "#8B7852",
                "terminal.ansi.bright_magenta": "#A4853C",
                "terminal.ansi.bright_cyan": "#A0905B",
                "terminal.ansi.bright_white": "#c5c6c6",
                "modified": "#8F342A",
                "syntax": {
                    "attribute": {
                        "color": "#8F342A"
                    },
                    "boolean": {
                      "color": "#944F2D"
                    },
                    "comment": {
                      "color": "#5e7373"
                    },
                    "comment.doc": {
                      "color": "#5e7373"
                    },
                    "constant": {
                      "color": "#944F2D"
                    },
                    "function": {
                      "color": "#A0905B"
                    },
                    "keyword": {
                      "color": "#8B7852"
                    },
                    "number": {
                      "color": "#A4853C"
                    },
                    "operator": {
                      "color": "#8B7852"
                    },
                    "string": {
                      "color": "#8F342A"
                    },
                    "variable": {
                      "color": "#944F2D"
                    }
                },
                "players": [
                  {
                    "cursor": "#8F342A",
                    "background": "#181b1b",
                    "selection": "#8F342A30"
                  }
                ]
            }
        }
    ]
}
