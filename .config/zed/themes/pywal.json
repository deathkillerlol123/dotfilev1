{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#08071190",
                "editor.background": "#08071190",
                "editor.foreground": "#c1c1c3",
                "text": "#c1c1c3",
                "text.muted": "#c1c1c370",
                "text.ignored": "#c1c1c340",
                "text.placeholder": "#c1c1c350",
                "ignored": "#c1c1c330",
                "element.hover": "#c1c1c330",
                "ghost_element.hover": "#F2602D30",
                "ghost_element.selected": "#F2602D30",
                "ghost_element.active": "#F2602D60",
                "border": "#080711",
                "editor.highlighted_line.background": "#F2602D10",
                "editor.active_line.background": "#F2602D10",
                "panel.background": "#08071190",
                "title_bar.background": "#08071190",
                "title_bar.inactive_background": "#08071190",
                "status_bar.background": "#08071190",
                "drop_target.background": "#08071190",
                "elevated_surface.background": "#080711",
                "toolbar.background": "#08071190",
                "tab_bar.background": "#08071190",
                "tab.inactive_background": "#08071190",
                "tab.active_background": "#F2602D30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#080711",
                "scrollbar.thumb.background": "#F2602D",
                "editor.gutter.background": "#08071190",
                "terminal.background": "#08071110",
                "terminal.foreground": "#c1c1c3",
                "terminal.dim_foreground": "#c1c1c3",
                "terminal.bright_foreground": "#c1c1c3",
                "terminal.ansi.black": "#080711",
                "terminal.ansi.red": "#F2602D",
                "terminal.ansi.green": "#A12A46",
                "terminal.ansi.yellow": "#BC4B58",
                "terminal.ansi.blue": "#FD9434",
                "terminal.ansi.magenta": "#3B5889",
                "terminal.ansi.cyan": "#5F6691",
                "terminal.ansi.white": "#c1c1c3",
                "terminal.ansi.bright_black": "#59566a",
                "terminal.ansi.bright_red": "#F2602D",
                "terminal.ansi.bright_green": "#A12A46",
                "terminal.ansi.bright_yellow": "#BC4B58",
                "terminal.ansi.bright_blue": "#FD9434",
                "terminal.ansi.bright_magenta": "#3B5889",
                "terminal.ansi.bright_cyan": "#5F6691",
                "terminal.ansi.bright_white": "#c1c1c3",
                "modified": "#F2602D",
                "syntax": {
                    "attribute": {
                        "color": "#F2602D"
                    },
                    "boolean": {
                      "color": "#A12A46"
                    },
                    "comment": {
                      "color": "#59566a"
                    },
                    "comment.doc": {
                      "color": "#59566a"
                    },
                    "constant": {
                      "color": "#A12A46"
                    },
                    "function": {
                      "color": "#5F6691"
                    },
                    "keyword": {
                      "color": "#FD9434"
                    },
                    "number": {
                      "color": "#3B5889"
                    },
                    "operator": {
                      "color": "#FD9434"
                    },
                    "string": {
                      "color": "#F2602D"
                    },
                    "variable": {
                      "color": "#A12A46"
                    }
                },
                "players": [
                  {
                    "cursor": "#F2602D",
                    "background": "#080711",
                    "selection": "#F2602D30"
                  }
                ]
            }
        }
    ]
}
