{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0e1a2090",
                "editor.background": "#0e1a2090",
                "editor.foreground": "#c2c5c7",
                "text": "#c2c5c7",
                "text.muted": "#c2c5c770",
                "text.ignored": "#c2c5c740",
                "text.placeholder": "#c2c5c750",
                "ignored": "#c2c5c730",
                "element.hover": "#c2c5c730",
                "ghost_element.hover": "#A38E5B30",
                "ghost_element.selected": "#A38E5B30",
                "ghost_element.active": "#A38E5B60",
                "border": "#0e1a20",
                "editor.highlighted_line.background": "#A38E5B10",
                "editor.active_line.background": "#A38E5B10",
                "panel.background": "#0e1a2090",
                "title_bar.background": "#0e1a2090",
                "title_bar.inactive_background": "#0e1a2090",
                "status_bar.background": "#0e1a2090",
                "drop_target.background": "#0e1a2090",
                "elevated_surface.background": "#0e1a20",
                "toolbar.background": "#0e1a2090",
                "tab_bar.background": "#0e1a2090",
                "tab.inactive_background": "#0e1a2090",
                "tab.active_background": "#A38E5B30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0e1a20",
                "scrollbar.thumb.background": "#A38E5B",
                "editor.gutter.background": "#0e1a2090",
                "terminal.background": "#0e1a2010",
                "terminal.foreground": "#c2c5c7",
                "terminal.dim_foreground": "#c2c5c7",
                "terminal.bright_foreground": "#c2c5c7",
                "terminal.ansi.black": "#0e1a20",
                "terminal.ansi.red": "#A38E5B",
                "terminal.ansi.green": "#558C8A",
                "terminal.ansi.yellow": "#A1A893",
                "terminal.ansi.blue": "#C7B89A",
                "terminal.ansi.magenta": "#DBCCA8",
                "terminal.ansi.cyan": "#E9DAB2",
                "terminal.ansi.white": "#c2c5c7",
                "terminal.ansi.bright_black": "#5d6b72",
                "terminal.ansi.bright_red": "#A38E5B",
                "terminal.ansi.bright_green": "#558C8A",
                "terminal.ansi.bright_yellow": "#A1A893",
                "terminal.ansi.bright_blue": "#C7B89A",
                "terminal.ansi.bright_magenta": "#DBCCA8",
                "terminal.ansi.bright_cyan": "#E9DAB2",
                "terminal.ansi.bright_white": "#c2c5c7",
                "modified": "#A38E5B",
                "syntax": {
                    "attribute": {
                        "color": "#A38E5B"
                    },
                    "boolean": {
                      "color": "#558C8A"
                    },
                    "comment": {
                      "color": "#5d6b72"
                    },
                    "comment.doc": {
                      "color": "#5d6b72"
                    },
                    "constant": {
                      "color": "#558C8A"
                    },
                    "function": {
                      "color": "#E9DAB2"
                    },
                    "keyword": {
                      "color": "#C7B89A"
                    },
                    "number": {
                      "color": "#DBCCA8"
                    },
                    "operator": {
                      "color": "#C7B89A"
                    },
                    "string": {
                      "color": "#A38E5B"
                    },
                    "variable": {
                      "color": "#558C8A"
                    }
                },
                "players": [
                  {
                    "cursor": "#A38E5B",
                    "background": "#0e1a20",
                    "selection": "#A38E5B30"
                  }
                ]
            }
        }
    ]
}
