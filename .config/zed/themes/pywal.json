{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#10111390",
                "editor.background": "#10111390",
                "editor.foreground": "#c3c3c4",
                "text": "#c3c3c4",
                "text.muted": "#c3c3c470",
                "text.ignored": "#c3c3c440",
                "text.placeholder": "#c3c3c450",
                "ignored": "#c3c3c430",
                "element.hover": "#c3c3c430",
                "ghost_element.hover": "#CC615430",
                "ghost_element.selected": "#CC615430",
                "ghost_element.active": "#CC615460",
                "border": "#101113",
                "editor.highlighted_line.background": "#CC615410",
                "editor.active_line.background": "#CC615410",
                "panel.background": "#10111390",
                "title_bar.background": "#10111390",
                "title_bar.inactive_background": "#10111390",
                "status_bar.background": "#10111390",
                "drop_target.background": "#10111390",
                "elevated_surface.background": "#101113",
                "toolbar.background": "#10111390",
                "tab_bar.background": "#10111390",
                "tab.inactive_background": "#10111390",
                "tab.active_background": "#CC615430",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#101113",
                "scrollbar.thumb.background": "#CC6154",
                "editor.gutter.background": "#10111390",
                "terminal.background": "#10111310",
                "terminal.foreground": "#c3c3c4",
                "terminal.dim_foreground": "#c3c3c4",
                "terminal.bright_foreground": "#c3c3c4",
                "terminal.ansi.black": "#101113",
                "terminal.ansi.red": "#CC6154",
                "terminal.ansi.green": "#75897E",
                "terminal.ansi.yellow": "#B69166",
                "terminal.ansi.blue": "#6A6896",
                "terminal.ansi.magenta": "#997690",
                "terminal.ansi.cyan": "#A198A1",
                "terminal.ansi.white": "#c3c3c4",
                "terminal.ansi.bright_black": "#59636e",
                "terminal.ansi.bright_red": "#CC6154",
                "terminal.ansi.bright_green": "#75897E",
                "terminal.ansi.bright_yellow": "#B69166",
                "terminal.ansi.bright_blue": "#6A6896",
                "terminal.ansi.bright_magenta": "#997690",
                "terminal.ansi.bright_cyan": "#A198A1",
                "terminal.ansi.bright_white": "#c3c3c4",
                "modified": "#CC6154",
                "syntax": {
                    "attribute": {
                        "color": "#CC6154"
                    },
                    "boolean": {
                      "color": "#75897E"
                    },
                    "comment": {
                      "color": "#59636e"
                    },
                    "comment.doc": {
                      "color": "#59636e"
                    },
                    "constant": {
                      "color": "#75897E"
                    },
                    "function": {
                      "color": "#A198A1"
                    },
                    "keyword": {
                      "color": "#6A6896"
                    },
                    "number": {
                      "color": "#997690"
                    },
                    "operator": {
                      "color": "#6A6896"
                    },
                    "string": {
                      "color": "#CC6154"
                    },
                    "variable": {
                      "color": "#75897E"
                    }
                },
                "players": [
                  {
                    "cursor": "#CC6154",
                    "background": "#101113",
                    "selection": "#CC615430"
                  }
                ]
            }
        }
    ]
}
