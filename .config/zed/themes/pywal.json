{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#100a1790",
                "editor.background": "#100a1790",
                "editor.foreground": "#c3c1c5",
                "text": "#c3c1c5",
                "text.muted": "#c3c1c570",
                "text.ignored": "#c3c1c540",
                "text.placeholder": "#c3c1c550",
                "ignored": "#c3c1c530",
                "element.hover": "#c3c1c530",
                "ghost_element.hover": "#18129430",
                "ghost_element.selected": "#18129430",
                "ghost_element.active": "#18129460",
                "border": "#100a17",
                "editor.highlighted_line.background": "#18129410",
                "editor.active_line.background": "#18129410",
                "panel.background": "#100a1790",
                "title_bar.background": "#100a1790",
                "title_bar.inactive_background": "#100a1790",
                "status_bar.background": "#100a1790",
                "drop_target.background": "#100a1790",
                "elevated_surface.background": "#100a17",
                "toolbar.background": "#100a1790",
                "tab_bar.background": "#100a1790",
                "tab.inactive_background": "#100a1790",
                "tab.active_background": "#18129430",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#100a17",
                "scrollbar.thumb.background": "#181294",
                "editor.gutter.background": "#100a1790",
                "terminal.background": "#100a1710",
                "terminal.foreground": "#c3c1c5",
                "terminal.dim_foreground": "#c3c1c5",
                "terminal.bright_foreground": "#c3c1c5",
                "terminal.ansi.black": "#100a17",
                "terminal.ansi.red": "#181294",
                "terminal.ansi.green": "#3D3DBC",
                "terminal.ansi.yellow": "#9F1CDB",
                "terminal.ansi.blue": "#18A3F0",
                "terminal.ansi.magenta": "#4BA8DA",
                "terminal.ansi.cyan": "#1AD9FA",
                "terminal.ansi.white": "#c3c1c5",
                "terminal.ansi.bright_black": "#62596d",
                "terminal.ansi.bright_red": "#181294",
                "terminal.ansi.bright_green": "#3D3DBC",
                "terminal.ansi.bright_yellow": "#9F1CDB",
                "terminal.ansi.bright_blue": "#18A3F0",
                "terminal.ansi.bright_magenta": "#4BA8DA",
                "terminal.ansi.bright_cyan": "#1AD9FA",
                "terminal.ansi.bright_white": "#c3c1c5",
                "modified": "#181294",
                "syntax": {
                    "attribute": {
                        "color": "#181294"
                    },
                    "boolean": {
                      "color": "#3D3DBC"
                    },
                    "comment": {
                      "color": "#62596d"
                    },
                    "comment.doc": {
                      "color": "#62596d"
                    },
                    "constant": {
                      "color": "#3D3DBC"
                    },
                    "function": {
                      "color": "#1AD9FA"
                    },
                    "keyword": {
                      "color": "#18A3F0"
                    },
                    "number": {
                      "color": "#4BA8DA"
                    },
                    "operator": {
                      "color": "#18A3F0"
                    },
                    "string": {
                      "color": "#181294"
                    },
                    "variable": {
                      "color": "#3D3DBC"
                    }
                },
                "players": [
                  {
                    "cursor": "#181294",
                    "background": "#100a17",
                    "selection": "#18129430"
                  }
                ]
            }
        }
    ]
}
