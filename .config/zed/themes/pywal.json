{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#220f1f90",
                "editor.background": "#220f1f90",
                "editor.foreground": "#c7c3c7",
                "text": "#c7c3c7",
                "text.muted": "#c7c3c770",
                "text.ignored": "#c7c3c740",
                "text.placeholder": "#c7c3c750",
                "ignored": "#c7c3c730",
                "element.hover": "#c7c3c730",
                "ghost_element.hover": "#49395230",
                "ghost_element.selected": "#49395230",
                "ghost_element.active": "#49395260",
                "border": "#220f1f",
                "editor.highlighted_line.background": "#49395210",
                "editor.active_line.background": "#49395210",
                "panel.background": "#220f1f90",
                "title_bar.background": "#220f1f90",
                "title_bar.inactive_background": "#220f1f90",
                "status_bar.background": "#220f1f90",
                "drop_target.background": "#220f1f90",
                "elevated_surface.background": "#220f1f",
                "toolbar.background": "#220f1f90",
                "tab_bar.background": "#220f1f90",
                "tab.inactive_background": "#220f1f90",
                "tab.active_background": "#49395230",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#220f1f",
                "scrollbar.thumb.background": "#493952",
                "editor.gutter.background": "#220f1f90",
                "terminal.background": "#220f1f10",
                "terminal.foreground": "#c7c3c7",
                "terminal.dim_foreground": "#c7c3c7",
                "terminal.bright_foreground": "#c7c3c7",
                "terminal.ansi.black": "#220f1f",
                "terminal.ansi.red": "#493952",
                "terminal.ansi.green": "#4F3B5F",
                "terminal.ansi.yellow": "#5D4D5F",
                "terminal.ansi.blue": "#AB532A",
                "terminal.ansi.magenta": "#976558",
                "terminal.ansi.cyan": "#CA9A57",
                "terminal.ansi.white": "#c7c3c7",
                "terminal.ansi.bright_black": "#735e6f",
                "terminal.ansi.bright_red": "#493952",
                "terminal.ansi.bright_green": "#4F3B5F",
                "terminal.ansi.bright_yellow": "#5D4D5F",
                "terminal.ansi.bright_blue": "#AB532A",
                "terminal.ansi.bright_magenta": "#976558",
                "terminal.ansi.bright_cyan": "#CA9A57",
                "terminal.ansi.bright_white": "#c7c3c7",
                "modified": "#493952",
                "syntax": {
                    "attribute": {
                        "color": "#493952"
                    },
                    "boolean": {
                      "color": "#4F3B5F"
                    },
                    "comment": {
                      "color": "#735e6f"
                    },
                    "comment.doc": {
                      "color": "#735e6f"
                    },
                    "constant": {
                      "color": "#4F3B5F"
                    },
                    "function": {
                      "color": "#CA9A57"
                    },
                    "keyword": {
                      "color": "#AB532A"
                    },
                    "number": {
                      "color": "#976558"
                    },
                    "operator": {
                      "color": "#AB532A"
                    },
                    "string": {
                      "color": "#493952"
                    },
                    "variable": {
                      "color": "#4F3B5F"
                    }
                },
                "players": [
                  {
                    "cursor": "#493952",
                    "background": "#220f1f",
                    "selection": "#49395230"
                  }
                ]
            }
        }
    ]
}
