{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#1b212590",
                "editor.background": "#1b212590",
                "editor.foreground": "#c6c7c8",
                "text": "#c6c7c8",
                "text.muted": "#c6c7c870",
                "text.ignored": "#c6c7c840",
                "text.placeholder": "#c6c7c850",
                "ignored": "#c6c7c830",
                "element.hover": "#c6c7c830",
                "ghost_element.hover": "#88857B30",
                "ghost_element.selected": "#88857B30",
                "ghost_element.active": "#88857B60",
                "border": "#1b2125",
                "editor.highlighted_line.background": "#88857B10",
                "editor.active_line.background": "#88857B10",
                "panel.background": "#1b212590",
                "title_bar.background": "#1b212590",
                "title_bar.inactive_background": "#1b212590",
                "status_bar.background": "#1b212590",
                "drop_target.background": "#1b212590",
                "elevated_surface.background": "#1b2125",
                "toolbar.background": "#1b212590",
                "tab_bar.background": "#1b212590",
                "tab.inactive_background": "#1b212590",
                "tab.active_background": "#88857B30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#1b2125",
                "scrollbar.thumb.background": "#88857B",
                "editor.gutter.background": "#1b212590",
                "terminal.background": "#1b212510",
                "terminal.foreground": "#c6c7c8",
                "terminal.dim_foreground": "#c6c7c8",
                "terminal.bright_foreground": "#c6c7c8",
                "terminal.ansi.black": "#1b2125",
                "terminal.ansi.red": "#88857B",
                "terminal.ansi.green": "#989386",
                "terminal.ansi.yellow": "#A29D8F",
                "terminal.ansi.blue": "#B0AA9B",
                "terminal.ansi.magenta": "#B7B1A1",
                "terminal.ansi.cyan": "#BAB4A5",
                "terminal.ansi.white": "#c6c7c8",
                "terminal.ansi.bright_black": "#626f78",
                "terminal.ansi.bright_red": "#88857B",
                "terminal.ansi.bright_green": "#989386",
                "terminal.ansi.bright_yellow": "#A29D8F",
                "terminal.ansi.bright_blue": "#B0AA9B",
                "terminal.ansi.bright_magenta": "#B7B1A1",
                "terminal.ansi.bright_cyan": "#BAB4A5",
                "terminal.ansi.bright_white": "#c6c7c8",
                "modified": "#88857B",
                "syntax": {
                    "attribute": {
                        "color": "#88857B"
                    },
                    "boolean": {
                      "color": "#989386"
                    },
                    "comment": {
                      "color": "#626f78"
                    },
                    "comment.doc": {
                      "color": "#626f78"
                    },
                    "constant": {
                      "color": "#989386"
                    },
                    "function": {
                      "color": "#BAB4A5"
                    },
                    "keyword": {
                      "color": "#B0AA9B"
                    },
                    "number": {
                      "color": "#B7B1A1"
                    },
                    "operator": {
                      "color": "#B0AA9B"
                    },
                    "string": {
                      "color": "#88857B"
                    },
                    "variable": {
                      "color": "#989386"
                    }
                },
                "players": [
                  {
                    "cursor": "#88857B",
                    "background": "#1b2125",
                    "selection": "#88857B30"
                  }
                ]
            }
        }
    ]
}
