{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#111d2990",
                "editor.background": "#111d2990",
                "editor.foreground": "#c3c6c9",
                "text": "#c3c6c9",
                "text.muted": "#c3c6c970",
                "text.ignored": "#c3c6c940",
                "text.placeholder": "#c3c6c950",
                "ignored": "#c3c6c930",
                "element.hover": "#c3c6c930",
                "ghost_element.hover": "#5A769130",
                "ghost_element.selected": "#5A769130",
                "ghost_element.active": "#5A769160",
                "border": "#111d29",
                "editor.highlighted_line.background": "#5A769110",
                "editor.active_line.background": "#5A769110",
                "panel.background": "#111d2990",
                "title_bar.background": "#111d2990",
                "title_bar.inactive_background": "#111d2990",
                "status_bar.background": "#111d2990",
                "drop_target.background": "#111d2990",
                "elevated_surface.background": "#111d29",
                "toolbar.background": "#111d2990",
                "tab_bar.background": "#111d2990",
                "tab.inactive_background": "#111d2990",
                "tab.active_background": "#5A769130",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#111d29",
                "scrollbar.thumb.background": "#5A7691",
                "editor.gutter.background": "#111d2990",
                "terminal.background": "#111d2910",
                "terminal.foreground": "#c3c6c9",
                "terminal.dim_foreground": "#c3c6c9",
                "terminal.bright_foreground": "#c3c6c9",
                "terminal.ansi.black": "#111d29",
                "terminal.ansi.red": "#5A7691",
                "terminal.ansi.green": "#B5788E",
                "terminal.ansi.yellow": "#279FB5",
                "terminal.ansi.blue": "#648FA6",
                "terminal.ansi.magenta": "#A18FA0",
                "terminal.ansi.cyan": "#E29F94",
                "terminal.ansi.white": "#c3c6c9",
                "terminal.ansi.bright_black": "#606c76",
                "terminal.ansi.bright_red": "#5A7691",
                "terminal.ansi.bright_green": "#B5788E",
                "terminal.ansi.bright_yellow": "#279FB5",
                "terminal.ansi.bright_blue": "#648FA6",
                "terminal.ansi.bright_magenta": "#A18FA0",
                "terminal.ansi.bright_cyan": "#E29F94",
                "terminal.ansi.bright_white": "#c3c6c9",
                "modified": "#5A7691",
                "syntax": {
                    "attribute": {
                        "color": "#5A7691"
                    },
                    "boolean": {
                      "color": "#B5788E"
                    },
                    "comment": {
                      "color": "#606c76"
                    },
                    "comment.doc": {
                      "color": "#606c76"
                    },
                    "constant": {
                      "color": "#B5788E"
                    },
                    "function": {
                      "color": "#E29F94"
                    },
                    "keyword": {
                      "color": "#648FA6"
                    },
                    "number": {
                      "color": "#A18FA0"
                    },
                    "operator": {
                      "color": "#648FA6"
                    },
                    "string": {
                      "color": "#5A7691"
                    },
                    "variable": {
                      "color": "#B5788E"
                    }
                },
                "players": [
                  {
                    "cursor": "#5A7691",
                    "background": "#111d29",
                    "selection": "#5A769130"
                  }
                ]
            }
        }
    ]
}
