{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0b0b1990",
                "editor.background": "#0b0b1990",
                "editor.foreground": "#c2c2c5",
                "text": "#c2c2c5",
                "text.muted": "#c2c2c570",
                "text.ignored": "#c2c2c540",
                "text.placeholder": "#c2c2c550",
                "ignored": "#c2c2c530",
                "element.hover": "#c2c2c530",
                "ghost_element.hover": "#37455630",
                "ghost_element.selected": "#37455630",
                "ghost_element.active": "#37455660",
                "border": "#0b0b19",
                "editor.highlighted_line.background": "#37455610",
                "editor.active_line.background": "#37455610",
                "panel.background": "#0b0b1990",
                "title_bar.background": "#0b0b1990",
                "title_bar.inactive_background": "#0b0b1990",
                "status_bar.background": "#0b0b1990",
                "drop_target.background": "#0b0b1990",
                "elevated_surface.background": "#0b0b19",
                "toolbar.background": "#0b0b1990",
                "tab_bar.background": "#0b0b1990",
                "tab.inactive_background": "#0b0b1990",
                "tab.active_background": "#37455630",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0b0b19",
                "scrollbar.thumb.background": "#374556",
                "editor.gutter.background": "#0b0b1990",
                "terminal.background": "#0b0b1910",
                "terminal.foreground": "#c2c2c5",
                "terminal.dim_foreground": "#c2c2c5",
                "terminal.bright_foreground": "#c2c2c5",
                "terminal.ansi.black": "#0b0b19",
                "terminal.ansi.red": "#374556",
                "terminal.ansi.green": "#394D6A",
                "terminal.ansi.yellow": "#49576D",
                "terminal.ansi.blue": "#967066",
                "terminal.ansi.magenta": "#3A5B8D",
                "terminal.ansi.cyan": "#516E91",
                "terminal.ansi.white": "#c2c2c5",
                "terminal.ansi.bright_black": "#5a5a6e",
                "terminal.ansi.bright_red": "#374556",
                "terminal.ansi.bright_green": "#394D6A",
                "terminal.ansi.bright_yellow": "#49576D",
                "terminal.ansi.bright_blue": "#967066",
                "terminal.ansi.bright_magenta": "#3A5B8D",
                "terminal.ansi.bright_cyan": "#516E91",
                "terminal.ansi.bright_white": "#c2c2c5",
                "modified": "#374556",
                "syntax": {
                    "attribute": {
                        "color": "#374556"
                    },
                    "boolean": {
                      "color": "#394D6A"
                    },
                    "comment": {
                      "color": "#5a5a6e"
                    },
                    "comment.doc": {
                      "color": "#5a5a6e"
                    },
                    "constant": {
                      "color": "#394D6A"
                    },
                    "function": {
                      "color": "#516E91"
                    },
                    "keyword": {
                      "color": "#967066"
                    },
                    "number": {
                      "color": "#3A5B8D"
                    },
                    "operator": {
                      "color": "#967066"
                    },
                    "string": {
                      "color": "#374556"
                    },
                    "variable": {
                      "color": "#394D6A"
                    }
                },
                "players": [
                  {
                    "cursor": "#374556",
                    "background": "#0b0b19",
                    "selection": "#37455630"
                  }
                ]
            }
        }
    ]
}
