{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0a091590",
                "editor.background": "#0a091590",
                "editor.foreground": "#c1c1c4",
                "text": "#c1c1c4",
                "text.muted": "#c1c1c470",
                "text.ignored": "#c1c1c440",
                "text.placeholder": "#c1c1c450",
                "ignored": "#c1c1c430",
                "element.hover": "#c1c1c430",
                "ghost_element.hover": "#3341CF30",
                "ghost_element.selected": "#3341CF30",
                "ghost_element.active": "#3341CF60",
                "border": "#0a0915",
                "editor.highlighted_line.background": "#3341CF10",
                "editor.active_line.background": "#3341CF10",
                "panel.background": "#0a091590",
                "title_bar.background": "#0a091590",
                "title_bar.inactive_background": "#0a091590",
                "status_bar.background": "#0a091590",
                "drop_target.background": "#0a091590",
                "elevated_surface.background": "#0a0915",
                "toolbar.background": "#0a091590",
                "tab_bar.background": "#0a091590",
                "tab.inactive_background": "#0a091590",
                "tab.active_background": "#3341CF30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0a0915",
                "scrollbar.thumb.background": "#3341CF",
                "editor.gutter.background": "#0a091590",
                "terminal.background": "#0a091510",
                "terminal.foreground": "#c1c1c4",
                "terminal.dim_foreground": "#c1c1c4",
                "terminal.bright_foreground": "#c1c1c4",
                "terminal.ansi.black": "#0a0915",
                "terminal.ansi.red": "#3341CF",
                "terminal.ansi.green": "#0153FE",
                "terminal.ansi.yellow": "#0170FE",
                "terminal.ansi.blue": "#AE45DC",
                "terminal.ansi.magenta": "#0B8BFE",
                "terminal.ansi.cyan": "#2E98F9",
                "terminal.ansi.white": "#c1c1c4",
                "terminal.ansi.bright_black": "#58586c",
                "terminal.ansi.bright_red": "#3341CF",
                "terminal.ansi.bright_green": "#0153FE",
                "terminal.ansi.bright_yellow": "#0170FE",
                "terminal.ansi.bright_blue": "#AE45DC",
                "terminal.ansi.bright_magenta": "#0B8BFE",
                "terminal.ansi.bright_cyan": "#2E98F9",
                "terminal.ansi.bright_white": "#c1c1c4",
                "modified": "#3341CF",
                "syntax": {
                    "attribute": {
                        "color": "#3341CF"
                    },
                    "boolean": {
                      "color": "#0153FE"
                    },
                    "comment": {
                      "color": "#58586c"
                    },
                    "comment.doc": {
                      "color": "#58586c"
                    },
                    "constant": {
                      "color": "#0153FE"
                    },
                    "function": {
                      "color": "#2E98F9"
                    },
                    "keyword": {
                      "color": "#AE45DC"
                    },
                    "number": {
                      "color": "#0B8BFE"
                    },
                    "operator": {
                      "color": "#AE45DC"
                    },
                    "string": {
                      "color": "#3341CF"
                    },
                    "variable": {
                      "color": "#0153FE"
                    }
                },
                "players": [
                  {
                    "cursor": "#3341CF",
                    "background": "#0a0915",
                    "selection": "#3341CF30"
                  }
                ]
            }
        }
    ]
}
