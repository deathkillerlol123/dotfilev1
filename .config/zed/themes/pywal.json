{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0d101e90",
                "editor.background": "#0d101e90",
                "editor.foreground": "#c2c3c6",
                "text": "#c2c3c6",
                "text.muted": "#c2c3c670",
                "text.ignored": "#c2c3c640",
                "text.placeholder": "#c2c3c650",
                "ignored": "#c2c3c630",
                "element.hover": "#c2c3c630",
                "ghost_element.hover": "#2E354930",
                "ghost_element.selected": "#2E354930",
                "ghost_element.active": "#2E354960",
                "border": "#0d101e",
                "editor.highlighted_line.background": "#2E354910",
                "editor.active_line.background": "#2E354910",
                "panel.background": "#0d101e90",
                "title_bar.background": "#0d101e90",
                "title_bar.inactive_background": "#0d101e90",
                "status_bar.background": "#0d101e90",
                "drop_target.background": "#0d101e90",
                "elevated_surface.background": "#0d101e",
                "toolbar.background": "#0d101e90",
                "tab_bar.background": "#0d101e90",
                "tab.inactive_background": "#0d101e90",
                "tab.active_background": "#2E354930",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0d101e",
                "scrollbar.thumb.background": "#2E3549",
                "editor.gutter.background": "#0d101e90",
                "terminal.background": "#0d101e10",
                "terminal.foreground": "#c2c3c6",
                "terminal.dim_foreground": "#c2c3c6",
                "terminal.bright_foreground": "#c2c3c6",
                "terminal.ansi.black": "#0d101e",
                "terminal.ansi.red": "#2E3549",
                "terminal.ansi.green": "#0B4E67",
                "terminal.ansi.yellow": "#5B424F",
                "terminal.ansi.blue": "#B74242",
                "terminal.ansi.magenta": "#CD9756",
                "terminal.ansi.cyan": "#106E90",
                "terminal.ansi.white": "#c2c3c6",
                "terminal.ansi.bright_black": "#5c5f70",
                "terminal.ansi.bright_red": "#2E3549",
                "terminal.ansi.bright_green": "#0B4E67",
                "terminal.ansi.bright_yellow": "#5B424F",
                "terminal.ansi.bright_blue": "#B74242",
                "terminal.ansi.bright_magenta": "#CD9756",
                "terminal.ansi.bright_cyan": "#106E90",
                "terminal.ansi.bright_white": "#c2c3c6",
                "modified": "#2E3549",
                "syntax": {
                    "attribute": {
                        "color": "#2E3549"
                    },
                    "boolean": {
                      "color": "#0B4E67"
                    },
                    "comment": {
                      "color": "#5c5f70"
                    },
                    "comment.doc": {
                      "color": "#5c5f70"
                    },
                    "constant": {
                      "color": "#0B4E67"
                    },
                    "function": {
                      "color": "#106E90"
                    },
                    "keyword": {
                      "color": "#B74242"
                    },
                    "number": {
                      "color": "#CD9756"
                    },
                    "operator": {
                      "color": "#B74242"
                    },
                    "string": {
                      "color": "#2E3549"
                    },
                    "variable": {
                      "color": "#0B4E67"
                    }
                },
                "players": [
                  {
                    "cursor": "#2E3549",
                    "background": "#0d101e",
                    "selection": "#2E354930"
                  }
                ]
            }
        }
    ]
}
