{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#1b1e2590",
                "editor.background": "#1b1e2590",
                "editor.foreground": "#c6c6c8",
                "text": "#c6c6c8",
                "text.muted": "#c6c6c870",
                "text.ignored": "#c6c6c840",
                "text.placeholder": "#c6c6c850",
                "ignored": "#c6c6c830",
                "element.hover": "#c6c6c830",
                "ghost_element.hover": "#50617B30",
                "ghost_element.selected": "#50617B30",
                "ghost_element.active": "#50617B60",
                "border": "#1b1e25",
                "editor.highlighted_line.background": "#50617B10",
                "editor.active_line.background": "#50617B10",
                "panel.background": "#1b1e2590",
                "title_bar.background": "#1b1e2590",
                "title_bar.inactive_background": "#1b1e2590",
                "status_bar.background": "#1b1e2590",
                "drop_target.background": "#1b1e2590",
                "elevated_surface.background": "#1b1e25",
                "toolbar.background": "#1b1e2590",
                "tab_bar.background": "#1b1e2590",
                "tab.inactive_background": "#1b1e2590",
                "tab.active_background": "#50617B30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#1b1e25",
                "scrollbar.thumb.background": "#50617B",
                "editor.gutter.background": "#1b1e2590",
                "terminal.background": "#1b1e2510",
                "terminal.foreground": "#c6c6c8",
                "terminal.dim_foreground": "#c6c6c8",
                "terminal.bright_foreground": "#c6c6c8",
                "terminal.ansi.black": "#1b1e25",
                "terminal.ansi.red": "#50617B",
                "terminal.ansi.green": "#9A606F",
                "terminal.ansi.yellow": "#C06A77",
                "terminal.ansi.blue": "#587497",
                "terminal.ansi.magenta": "#5C7BA2",
                "terminal.ansi.cyan": "#B6788C",
                "terminal.ansi.white": "#c6c6c8",
                "terminal.ansi.bright_black": "#626878",
                "terminal.ansi.bright_red": "#50617B",
                "terminal.ansi.bright_green": "#9A606F",
                "terminal.ansi.bright_yellow": "#C06A77",
                "terminal.ansi.bright_blue": "#587497",
                "terminal.ansi.bright_magenta": "#5C7BA2",
                "terminal.ansi.bright_cyan": "#B6788C",
                "terminal.ansi.bright_white": "#c6c6c8",
                "modified": "#50617B",
                "syntax": {
                    "attribute": {
                        "color": "#50617B"
                    },
                    "boolean": {
                      "color": "#9A606F"
                    },
                    "comment": {
                      "color": "#626878"
                    },
                    "comment.doc": {
                      "color": "#626878"
                    },
                    "constant": {
                      "color": "#9A606F"
                    },
                    "function": {
                      "color": "#B6788C"
                    },
                    "keyword": {
                      "color": "#587497"
                    },
                    "number": {
                      "color": "#5C7BA2"
                    },
                    "operator": {
                      "color": "#587497"
                    },
                    "string": {
                      "color": "#50617B"
                    },
                    "variable": {
                      "color": "#9A606F"
                    }
                },
                "players": [
                  {
                    "cursor": "#50617B",
                    "background": "#1b1e25",
                    "selection": "#50617B30"
                  }
                ]
            }
        }
    ]
}
