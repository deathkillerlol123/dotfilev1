{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#120e2090",
                "editor.background": "#120e2090",
                "editor.foreground": "#c3c2c7",
                "text": "#c3c2c7",
                "text.muted": "#c3c2c770",
                "text.ignored": "#c3c2c740",
                "text.placeholder": "#c3c2c750",
                "ignored": "#c3c2c730",
                "element.hover": "#c3c2c730",
                "ghost_element.hover": "#58326430",
                "ghost_element.selected": "#58326430",
                "ghost_element.active": "#58326460",
                "border": "#120e20",
                "editor.highlighted_line.background": "#58326410",
                "editor.active_line.background": "#58326410",
                "panel.background": "#120e2090",
                "title_bar.background": "#120e2090",
                "title_bar.inactive_background": "#120e2090",
                "status_bar.background": "#120e2090",
                "drop_target.background": "#120e2090",
                "elevated_surface.background": "#120e20",
                "toolbar.background": "#120e2090",
                "tab_bar.background": "#120e2090",
                "tab.inactive_background": "#120e2090",
                "tab.active_background": "#58326430",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#120e20",
                "scrollbar.thumb.background": "#583264",
                "editor.gutter.background": "#120e2090",
                "terminal.background": "#120e2010",
                "terminal.foreground": "#c3c2c7",
                "terminal.dim_foreground": "#c3c2c7",
                "terminal.bright_foreground": "#c3c2c7",
                "terminal.ansi.black": "#120e20",
                "terminal.ansi.red": "#583264",
                "terminal.ansi.green": "#674C68",
                "terminal.ansi.yellow": "#A05965",
                "terminal.ansi.blue": "#ED9A6A",
                "terminal.ansi.magenta": "#6F5789",
                "terminal.ansi.cyan": "#946C8B",
                "terminal.ansi.white": "#c3c2c7",
                "terminal.ansi.bright_black": "#615d72",
                "terminal.ansi.bright_red": "#583264",
                "terminal.ansi.bright_green": "#674C68",
                "terminal.ansi.bright_yellow": "#A05965",
                "terminal.ansi.bright_blue": "#ED9A6A",
                "terminal.ansi.bright_magenta": "#6F5789",
                "terminal.ansi.bright_cyan": "#946C8B",
                "terminal.ansi.bright_white": "#c3c2c7",
                "modified": "#583264",
                "syntax": {
                    "attribute": {
                        "color": "#583264"
                    },
                    "boolean": {
                      "color": "#674C68"
                    },
                    "comment": {
                      "color": "#615d72"
                    },
                    "comment.doc": {
                      "color": "#615d72"
                    },
                    "constant": {
                      "color": "#674C68"
                    },
                    "function": {
                      "color": "#946C8B"
                    },
                    "keyword": {
                      "color": "#ED9A6A"
                    },
                    "number": {
                      "color": "#6F5789"
                    },
                    "operator": {
                      "color": "#ED9A6A"
                    },
                    "string": {
                      "color": "#583264"
                    },
                    "variable": {
                      "color": "#674C68"
                    }
                },
                "players": [
                  {
                    "cursor": "#583264",
                    "background": "#120e20",
                    "selection": "#58326430"
                  }
                ]
            }
        }
    ]
}
