{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#100c1d90",
                "editor.background": "#100c1d90",
                "editor.foreground": "#c3c2c6",
                "text": "#c3c2c6",
                "text.muted": "#c3c2c670",
                "text.ignored": "#c3c2c640",
                "text.placeholder": "#c3c2c650",
                "ignored": "#c3c2c630",
                "element.hover": "#c3c2c630",
                "ghost_element.hover": "#4F427630",
                "ghost_element.selected": "#4F427630",
                "ghost_element.active": "#4F427660",
                "border": "#100c1d",
                "editor.highlighted_line.background": "#4F427610",
                "editor.active_line.background": "#4F427610",
                "panel.background": "#100c1d90",
                "title_bar.background": "#100c1d90",
                "title_bar.inactive_background": "#100c1d90",
                "status_bar.background": "#100c1d90",
                "drop_target.background": "#100c1d90",
                "elevated_surface.background": "#100c1d",
                "toolbar.background": "#100c1d90",
                "tab_bar.background": "#100c1d90",
                "tab.inactive_background": "#100c1d90",
                "tab.active_background": "#4F427630",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#100c1d",
                "scrollbar.thumb.background": "#4F4276",
                "editor.gutter.background": "#100c1d90",
                "terminal.background": "#100c1d10",
                "terminal.foreground": "#c3c2c6",
                "terminal.dim_foreground": "#c3c2c6",
                "terminal.bright_foreground": "#c3c2c6",
                "terminal.ansi.black": "#100c1d",
                "terminal.ansi.red": "#4F4276",
                "terminal.ansi.green": "#C54854",
                "terminal.ansi.yellow": "#423E85",
                "terminal.ansi.blue": "#3A4489",
                "terminal.ansi.magenta": "#4C4A90",
                "terminal.ansi.cyan": "#6755A0",
                "terminal.ansi.white": "#c3c2c6",
                "terminal.ansi.bright_black": "#5f5c70",
                "terminal.ansi.bright_red": "#4F4276",
                "terminal.ansi.bright_green": "#C54854",
                "terminal.ansi.bright_yellow": "#423E85",
                "terminal.ansi.bright_blue": "#3A4489",
                "terminal.ansi.bright_magenta": "#4C4A90",
                "terminal.ansi.bright_cyan": "#6755A0",
                "terminal.ansi.bright_white": "#c3c2c6",
                "modified": "#4F4276",
                "syntax": {
                    "attribute": {
                        "color": "#4F4276"
                    },
                    "boolean": {
                      "color": "#C54854"
                    },
                    "comment": {
                      "color": "#5f5c70"
                    },
                    "comment.doc": {
                      "color": "#5f5c70"
                    },
                    "constant": {
                      "color": "#C54854"
                    },
                    "function": {
                      "color": "#6755A0"
                    },
                    "keyword": {
                      "color": "#3A4489"
                    },
                    "number": {
                      "color": "#4C4A90"
                    },
                    "operator": {
                      "color": "#3A4489"
                    },
                    "string": {
                      "color": "#4F4276"
                    },
                    "variable": {
                      "color": "#C54854"
                    }
                },
                "players": [
                  {
                    "cursor": "#4F4276",
                    "background": "#100c1d",
                    "selection": "#4F427630"
                  }
                ]
            }
        }
    ]
}
