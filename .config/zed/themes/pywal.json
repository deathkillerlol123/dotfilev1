{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#090f1590",
                "editor.background": "#090f1590",
                "editor.foreground": "#c1c3c4",
                "text": "#c1c3c4",
                "text.muted": "#c1c3c470",
                "text.ignored": "#c1c3c440",
                "text.placeholder": "#c1c3c450",
                "ignored": "#c1c3c430",
                "element.hover": "#c1c3c430",
                "ghost_element.hover": "#28555F30",
                "ghost_element.selected": "#28555F30",
                "ghost_element.active": "#28555F60",
                "border": "#090f15",
                "editor.highlighted_line.background": "#28555F10",
                "editor.active_line.background": "#28555F10",
                "panel.background": "#090f1590",
                "title_bar.background": "#090f1590",
                "title_bar.inactive_background": "#090f1590",
                "status_bar.background": "#090f1590",
                "drop_target.background": "#090f1590",
                "elevated_surface.background": "#090f15",
                "toolbar.background": "#090f1590",
                "tab_bar.background": "#090f1590",
                "tab.inactive_background": "#090f1590",
                "tab.active_background": "#28555F30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#090f15",
                "scrollbar.thumb.background": "#28555F",
                "editor.gutter.background": "#090f1590",
                "terminal.background": "#090f1510",
                "terminal.foreground": "#c1c3c4",
                "terminal.dim_foreground": "#c1c3c4",
                "terminal.bright_foreground": "#c1c3c4",
                "terminal.ansi.black": "#090f15",
                "terminal.ansi.red": "#28555F",
                "terminal.ansi.green": "#5D5F5B",
                "terminal.ansi.yellow": "#AA5239",
                "terminal.ansi.blue": "#DA9C63",
                "terminal.ansi.magenta": "#457C82",
                "terminal.ansi.cyan": "#5B9596",
                "terminal.ansi.white": "#c1c3c4",
                "terminal.ansi.bright_black": "#58636c",
                "terminal.ansi.bright_red": "#28555F",
                "terminal.ansi.bright_green": "#5D5F5B",
                "terminal.ansi.bright_yellow": "#AA5239",
                "terminal.ansi.bright_blue": "#DA9C63",
                "terminal.ansi.bright_magenta": "#457C82",
                "terminal.ansi.bright_cyan": "#5B9596",
                "terminal.ansi.bright_white": "#c1c3c4",
                "modified": "#28555F",
                "syntax": {
                    "attribute": {
                        "color": "#28555F"
                    },
                    "boolean": {
                      "color": "#5D5F5B"
                    },
                    "comment": {
                      "color": "#58636c"
                    },
                    "comment.doc": {
                      "color": "#58636c"
                    },
                    "constant": {
                      "color": "#5D5F5B"
                    },
                    "function": {
                      "color": "#5B9596"
                    },
                    "keyword": {
                      "color": "#DA9C63"
                    },
                    "number": {
                      "color": "#457C82"
                    },
                    "operator": {
                      "color": "#DA9C63"
                    },
                    "string": {
                      "color": "#28555F"
                    },
                    "variable": {
                      "color": "#5D5F5B"
                    }
                },
                "players": [
                  {
                    "cursor": "#28555F",
                    "background": "#090f15",
                    "selection": "#28555F30"
                  }
                ]
            }
        }
    ]
}
