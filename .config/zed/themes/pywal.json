{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0e0e2290",
                "editor.background": "#0e0e2290",
                "editor.foreground": "#c2c2c7",
                "text": "#c2c2c7",
                "text.muted": "#c2c2c770",
                "text.ignored": "#c2c2c740",
                "text.placeholder": "#c2c2c750",
                "ignored": "#c2c2c730",
                "element.hover": "#c2c2c730",
                "ghost_element.hover": "#C8927430",
                "ghost_element.selected": "#C8927430",
                "ghost_element.active": "#C8927460",
                "border": "#0e0e22",
                "editor.highlighted_line.background": "#C8927410",
                "editor.active_line.background": "#C8927410",
                "panel.background": "#0e0e2290",
                "title_bar.background": "#0e0e2290",
                "title_bar.inactive_background": "#0e0e2290",
                "status_bar.background": "#0e0e2290",
                "drop_target.background": "#0e0e2290",
                "elevated_surface.background": "#0e0e22",
                "toolbar.background": "#0e0e2290",
                "tab_bar.background": "#0e0e2290",
                "tab.inactive_background": "#0e0e2290",
                "tab.active_background": "#C8927430",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0e0e22",
                "scrollbar.thumb.background": "#C89274",
                "editor.gutter.background": "#0e0e2290",
                "terminal.background": "#0e0e2210",
                "terminal.foreground": "#c2c2c7",
                "terminal.dim_foreground": "#c2c2c7",
                "terminal.bright_foreground": "#c2c2c7",
                "terminal.ansi.black": "#0e0e22",
                "terminal.ansi.red": "#C89274",
                "terminal.ansi.green": "#A07B84",
                "terminal.ansi.yellow": "#A79496",
                "terminal.ansi.blue": "#DCA4A7",
                "terminal.ansi.magenta": "#F5B0AB",
                "terminal.ansi.cyan": "#F4C9AF",
                "terminal.ansi.white": "#c2c2c7",
                "terminal.ansi.bright_black": "#5e5e72",
                "terminal.ansi.bright_red": "#C89274",
                "terminal.ansi.bright_green": "#A07B84",
                "terminal.ansi.bright_yellow": "#A79496",
                "terminal.ansi.bright_blue": "#DCA4A7",
                "terminal.ansi.bright_magenta": "#F5B0AB",
                "terminal.ansi.bright_cyan": "#F4C9AF",
                "terminal.ansi.bright_white": "#c2c2c7",
                "modified": "#C89274",
                "syntax": {
                    "attribute": {
                        "color": "#C89274"
                    },
                    "boolean": {
                      "color": "#A07B84"
                    },
                    "comment": {
                      "color": "#5e5e72"
                    },
                    "comment.doc": {
                      "color": "#5e5e72"
                    },
                    "constant": {
                      "color": "#A07B84"
                    },
                    "function": {
                      "color": "#F4C9AF"
                    },
                    "keyword": {
                      "color": "#DCA4A7"
                    },
                    "number": {
                      "color": "#F5B0AB"
                    },
                    "operator": {
                      "color": "#DCA4A7"
                    },
                    "string": {
                      "color": "#C89274"
                    },
                    "variable": {
                      "color": "#A07B84"
                    }
                },
                "players": [
                  {
                    "cursor": "#C89274",
                    "background": "#0e0e22",
                    "selection": "#C8927430"
                  }
                ]
            }
        }
    ]
}
