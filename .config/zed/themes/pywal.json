{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#180d1e90",
                "editor.background": "#180d1e90",
                "editor.foreground": "#c5c2c6",
                "text": "#c5c2c6",
                "text.muted": "#c5c2c670",
                "text.ignored": "#c5c2c640",
                "text.placeholder": "#c5c2c650",
                "ignored": "#c5c2c630",
                "element.hover": "#c5c2c630",
                "ghost_element.hover": "#55487130",
                "ghost_element.selected": "#55487130",
                "ghost_element.active": "#55487160",
                "border": "#180d1e",
                "editor.highlighted_line.background": "#55487110",
                "editor.active_line.background": "#55487110",
                "panel.background": "#180d1e90",
                "title_bar.background": "#180d1e90",
                "title_bar.inactive_background": "#180d1e90",
                "status_bar.background": "#180d1e90",
                "drop_target.background": "#180d1e90",
                "elevated_surface.background": "#180d1e",
                "toolbar.background": "#180d1e90",
                "tab_bar.background": "#180d1e90",
                "tab.inactive_background": "#180d1e90",
                "tab.active_background": "#55487130",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#180d1e",
                "scrollbar.thumb.background": "#554871",
                "editor.gutter.background": "#180d1e90",
                "terminal.background": "#180d1e10",
                "terminal.foreground": "#c5c2c6",
                "terminal.dim_foreground": "#c5c2c6",
                "terminal.bright_foreground": "#c5c2c6",
                "terminal.ansi.black": "#180d1e",
                "terminal.ansi.red": "#554871",
                "terminal.ansi.green": "#6A2E8B",
                "terminal.ansi.yellow": "#3E408F",
                "terminal.ansi.blue": "#66559B",
                "terminal.ansi.magenta": "#9354B0",
                "terminal.ansi.cyan": "#9C50B8",
                "terminal.ansi.white": "#c5c2c6",
                "terminal.ansi.bright_black": "#695c70",
                "terminal.ansi.bright_red": "#554871",
                "terminal.ansi.bright_green": "#6A2E8B",
                "terminal.ansi.bright_yellow": "#3E408F",
                "terminal.ansi.bright_blue": "#66559B",
                "terminal.ansi.bright_magenta": "#9354B0",
                "terminal.ansi.bright_cyan": "#9C50B8",
                "terminal.ansi.bright_white": "#c5c2c6",
                "modified": "#554871",
                "syntax": {
                    "attribute": {
                        "color": "#554871"
                    },
                    "boolean": {
                      "color": "#6A2E8B"
                    },
                    "comment": {
                      "color": "#695c70"
                    },
                    "comment.doc": {
                      "color": "#695c70"
                    },
                    "constant": {
                      "color": "#6A2E8B"
                    },
                    "function": {
                      "color": "#9C50B8"
                    },
                    "keyword": {
                      "color": "#66559B"
                    },
                    "number": {
                      "color": "#9354B0"
                    },
                    "operator": {
                      "color": "#66559B"
                    },
                    "string": {
                      "color": "#554871"
                    },
                    "variable": {
                      "color": "#6A2E8B"
                    }
                },
                "players": [
                  {
                    "cursor": "#554871",
                    "background": "#180d1e",
                    "selection": "#55487130"
                  }
                ]
            }
        }
    ]
}
