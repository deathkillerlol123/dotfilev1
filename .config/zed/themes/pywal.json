{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#1a0b1590",
                "editor.background": "#1a0b1590",
                "editor.foreground": "#c5c2c4",
                "text": "#c5c2c4",
                "text.muted": "#c5c2c470",
                "text.ignored": "#c5c2c440",
                "text.placeholder": "#c5c2c450",
                "ignored": "#c5c2c430",
                "element.hover": "#c5c2c430",
                "ghost_element.hover": "#E7543230",
                "ghost_element.selected": "#E7543230",
                "ghost_element.active": "#E7543260",
                "border": "#1a0b15",
                "editor.highlighted_line.background": "#E7543210",
                "editor.active_line.background": "#E7543210",
                "panel.background": "#1a0b1590",
                "title_bar.background": "#1a0b1590",
                "title_bar.inactive_background": "#1a0b1590",
                "status_bar.background": "#1a0b1590",
                "drop_target.background": "#1a0b1590",
                "elevated_surface.background": "#1a0b15",
                "toolbar.background": "#1a0b1590",
                "tab_bar.background": "#1a0b1590",
                "tab.inactive_background": "#1a0b1590",
                "tab.active_background": "#E7543230",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#1a0b15",
                "scrollbar.thumb.background": "#E75432",
                "editor.gutter.background": "#1a0b1590",
                "terminal.background": "#1a0b1510",
                "terminal.foreground": "#c5c2c4",
                "terminal.dim_foreground": "#c5c2c4",
                "terminal.bright_foreground": "#c5c2c4",
                "terminal.ansi.black": "#1a0b15",
                "terminal.ansi.red": "#E75432",
                "terminal.ansi.green": "#9F5C5B",
                "terminal.ansi.yellow": "#E0694F",
                "terminal.ansi.blue": "#EB9A6A",
                "terminal.ansi.magenta": "#576C90",
                "terminal.ansi.cyan": "#977787",
                "terminal.ansi.white": "#c5c2c4",
                "terminal.ansi.bright_black": "#6f5a67",
                "terminal.ansi.bright_red": "#E75432",
                "terminal.ansi.bright_green": "#9F5C5B",
                "terminal.ansi.bright_yellow": "#E0694F",
                "terminal.ansi.bright_blue": "#EB9A6A",
                "terminal.ansi.bright_magenta": "#576C90",
                "terminal.ansi.bright_cyan": "#977787",
                "terminal.ansi.bright_white": "#c5c2c4",
                "modified": "#E75432",
                "syntax": {
                    "attribute": {
                        "color": "#E75432"
                    },
                    "boolean": {
                      "color": "#9F5C5B"
                    },
                    "comment": {
                      "color": "#6f5a67"
                    },
                    "comment.doc": {
                      "color": "#6f5a67"
                    },
                    "constant": {
                      "color": "#9F5C5B"
                    },
                    "function": {
                      "color": "#977787"
                    },
                    "keyword": {
                      "color": "#EB9A6A"
                    },
                    "number": {
                      "color": "#576C90"
                    },
                    "operator": {
                      "color": "#EB9A6A"
                    },
                    "string": {
                      "color": "#E75432"
                    },
                    "variable": {
                      "color": "#9F5C5B"
                    }
                },
                "players": [
                  {
                    "cursor": "#E75432",
                    "background": "#1a0b15",
                    "selection": "#E7543230"
                  }
                ]
            }
        }
    ]
}
