{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#13080b90",
                "editor.background": "#13080b90",
                "editor.foreground": "#c4c1c2",
                "text": "#c4c1c2",
                "text.muted": "#c4c1c270",
                "text.ignored": "#c4c1c240",
                "text.placeholder": "#c4c1c250",
                "ignored": "#c4c1c230",
                "element.hover": "#c4c1c230",
                "ghost_element.hover": "#5D5E5C30",
                "ghost_element.selected": "#5D5E5C30",
                "ghost_element.active": "#5D5E5C60",
                "border": "#13080b",
                "editor.highlighted_line.background": "#5D5E5C10",
                "editor.active_line.background": "#5D5E5C10",
                "panel.background": "#13080b90",
                "title_bar.background": "#13080b90",
                "title_bar.inactive_background": "#13080b90",
                "status_bar.background": "#13080b90",
                "drop_target.background": "#13080b90",
                "elevated_surface.background": "#13080b",
                "toolbar.background": "#13080b90",
                "tab_bar.background": "#13080b90",
                "tab.inactive_background": "#13080b90",
                "tab.active_background": "#5D5E5C30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#13080b",
                "scrollbar.thumb.background": "#5D5E5C",
                "editor.gutter.background": "#13080b90",
                "terminal.background": "#13080b10",
                "terminal.foreground": "#c4c1c2",
                "terminal.dim_foreground": "#c4c1c2",
                "terminal.bright_foreground": "#c4c1c2",
                "terminal.ansi.black": "#13080b",
                "terminal.ansi.red": "#5D5E5C",
                "terminal.ansi.green": "#C2654A",
                "terminal.ansi.yellow": "#23867C",
                "terminal.ansi.blue": "#C99359",
                "terminal.ansi.magenta": "#F2A05C",
                "terminal.ansi.cyan": "#0D998A",
                "terminal.ansi.white": "#c4c1c2",
                "terminal.ansi.bright_black": "#6b575d",
                "terminal.ansi.bright_red": "#5D5E5C",
                "terminal.ansi.bright_green": "#C2654A",
                "terminal.ansi.bright_yellow": "#23867C",
                "terminal.ansi.bright_blue": "#C99359",
                "terminal.ansi.bright_magenta": "#F2A05C",
                "terminal.ansi.bright_cyan": "#0D998A",
                "terminal.ansi.bright_white": "#c4c1c2",
                "modified": "#5D5E5C",
                "syntax": {
                    "attribute": {
                        "color": "#5D5E5C"
                    },
                    "boolean": {
                      "color": "#C2654A"
                    },
                    "comment": {
                      "color": "#6b575d"
                    },
                    "comment.doc": {
                      "color": "#6b575d"
                    },
                    "constant": {
                      "color": "#C2654A"
                    },
                    "function": {
                      "color": "#0D998A"
                    },
                    "keyword": {
                      "color": "#C99359"
                    },
                    "number": {
                      "color": "#F2A05C"
                    },
                    "operator": {
                      "color": "#C99359"
                    },
                    "string": {
                      "color": "#5D5E5C"
                    },
                    "variable": {
                      "color": "#C2654A"
                    }
                },
                "players": [
                  {
                    "cursor": "#5D5E5C",
                    "background": "#13080b",
                    "selection": "#5D5E5C30"
                  }
                ]
            }
        }
    ]
}
