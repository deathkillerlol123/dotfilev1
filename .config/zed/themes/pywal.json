{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0b0b1990",
                "editor.background": "#0b0b1990",
                "editor.foreground": "#c2c2c5",
                "text": "#c2c2c5",
                "text.muted": "#c2c2c570",
                "text.ignored": "#c2c2c540",
                "text.placeholder": "#c2c2c550",
                "ignored": "#c2c2c530",
                "element.hover": "#c2c2c530",
                "ghost_element.hover": "#553B8830",
                "ghost_element.selected": "#553B8830",
                "ghost_element.active": "#553B8860",
                "border": "#0b0b19",
                "editor.highlighted_line.background": "#553B8810",
                "editor.active_line.background": "#553B8810",
                "panel.background": "#0b0b1990",
                "title_bar.background": "#0b0b1990",
                "title_bar.inactive_background": "#0b0b1990",
                "status_bar.background": "#0b0b1990",
                "drop_target.background": "#0b0b1990",
                "elevated_surface.background": "#0b0b19",
                "toolbar.background": "#0b0b1990",
                "tab_bar.background": "#0b0b1990",
                "tab.inactive_background": "#0b0b1990",
                "tab.active_background": "#553B8830",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0b0b19",
                "scrollbar.thumb.background": "#553B88",
                "editor.gutter.background": "#0b0b1990",
                "terminal.background": "#0b0b1910",
                "terminal.foreground": "#c2c2c5",
                "terminal.dim_foreground": "#c2c2c5",
                "terminal.bright_foreground": "#c2c2c5",
                "terminal.ansi.black": "#0b0b19",
                "terminal.ansi.red": "#553B88",
                "terminal.ansi.green": "#354994",
                "terminal.ansi.yellow": "#60549D",
                "terminal.ansi.blue": "#9E6495",
                "terminal.ansi.magenta": "#CB7191",
                "terminal.ansi.cyan": "#6295C4",
                "terminal.ansi.white": "#c2c2c5",
                "terminal.ansi.bright_black": "#5a5a6e",
                "terminal.ansi.bright_red": "#553B88",
                "terminal.ansi.bright_green": "#354994",
                "terminal.ansi.bright_yellow": "#60549D",
                "terminal.ansi.bright_blue": "#9E6495",
                "terminal.ansi.bright_magenta": "#CB7191",
                "terminal.ansi.bright_cyan": "#6295C4",
                "terminal.ansi.bright_white": "#c2c2c5",
                "modified": "#553B88",
                "syntax": {
                    "attribute": {
                        "color": "#553B88"
                    },
                    "boolean": {
                      "color": "#354994"
                    },
                    "comment": {
                      "color": "#5a5a6e"
                    },
                    "comment.doc": {
                      "color": "#5a5a6e"
                    },
                    "constant": {
                      "color": "#354994"
                    },
                    "function": {
                      "color": "#6295C4"
                    },
                    "keyword": {
                      "color": "#9E6495"
                    },
                    "number": {
                      "color": "#CB7191"
                    },
                    "operator": {
                      "color": "#9E6495"
                    },
                    "string": {
                      "color": "#553B88"
                    },
                    "variable": {
                      "color": "#354994"
                    }
                },
                "players": [
                  {
                    "cursor": "#553B88",
                    "background": "#0b0b19",
                    "selection": "#553B8830"
                  }
                ]
            }
        }
    ]
}
