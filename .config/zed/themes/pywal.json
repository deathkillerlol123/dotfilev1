{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#1b0c1490",
                "editor.background": "#1b0c1490",
                "editor.foreground": "#c6c2c4",
                "text": "#c6c2c4",
                "text.muted": "#c6c2c470",
                "text.ignored": "#c6c2c440",
                "text.placeholder": "#c6c2c450",
                "ignored": "#c6c2c430",
                "element.hover": "#c6c2c430",
                "ghost_element.hover": "#60565430",
                "ghost_element.selected": "#60565430",
                "ghost_element.active": "#60565460",
                "border": "#1b0c14",
                "editor.highlighted_line.background": "#60565410",
                "editor.active_line.background": "#60565410",
                "panel.background": "#1b0c1490",
                "title_bar.background": "#1b0c1490",
                "title_bar.inactive_background": "#1b0c1490",
                "status_bar.background": "#1b0c1490",
                "drop_target.background": "#1b0c1490",
                "elevated_surface.background": "#1b0c14",
                "toolbar.background": "#1b0c1490",
                "tab_bar.background": "#1b0c1490",
                "tab.inactive_background": "#1b0c1490",
                "tab.active_background": "#60565430",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#1b0c14",
                "scrollbar.thumb.background": "#605654",
                "editor.gutter.background": "#1b0c1490",
                "terminal.background": "#1b0c1410",
                "terminal.foreground": "#c6c2c4",
                "terminal.dim_foreground": "#c6c2c4",
                "terminal.bright_foreground": "#c6c2c4",
                "terminal.ansi.black": "#1b0c14",
                "terminal.ansi.red": "#605654",
                "terminal.ansi.green": "#AA5530",
                "terminal.ansi.yellow": "#996C5B",
                "terminal.ansi.blue": "#C99752",
                "terminal.ansi.magenta": "#E5A65D",
                "terminal.ansi.cyan": "#607B8B",
                "terminal.ansi.white": "#c6c2c4",
                "terminal.ansi.bright_black": "#6f5b66",
                "terminal.ansi.bright_red": "#605654",
                "terminal.ansi.bright_green": "#AA5530",
                "terminal.ansi.bright_yellow": "#996C5B",
                "terminal.ansi.bright_blue": "#C99752",
                "terminal.ansi.bright_magenta": "#E5A65D",
                "terminal.ansi.bright_cyan": "#607B8B",
                "terminal.ansi.bright_white": "#c6c2c4",
                "modified": "#605654",
                "syntax": {
                    "attribute": {
                        "color": "#605654"
                    },
                    "boolean": {
                      "color": "#AA5530"
                    },
                    "comment": {
                      "color": "#6f5b66"
                    },
                    "comment.doc": {
                      "color": "#6f5b66"
                    },
                    "constant": {
                      "color": "#AA5530"
                    },
                    "function": {
                      "color": "#607B8B"
                    },
                    "keyword": {
                      "color": "#C99752"
                    },
                    "number": {
                      "color": "#E5A65D"
                    },
                    "operator": {
                      "color": "#C99752"
                    },
                    "string": {
                      "color": "#605654"
                    },
                    "variable": {
                      "color": "#AA5530"
                    }
                },
                "players": [
                  {
                    "cursor": "#605654",
                    "background": "#1b0c14",
                    "selection": "#60565430"
                  }
                ]
            }
        }
    ]
}
