{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0d0d2090",
                "editor.background": "#0d0d2090",
                "editor.foreground": "#c2c2c7",
                "text": "#c2c2c7",
                "text.muted": "#c2c2c770",
                "text.ignored": "#c2c2c740",
                "text.placeholder": "#c2c2c750",
                "ignored": "#c2c2c730",
                "element.hover": "#c2c2c730",
                "ghost_element.hover": "#3A444C30",
                "ghost_element.selected": "#3A444C30",
                "ghost_element.active": "#3A444C60",
                "border": "#0d0d20",
                "editor.highlighted_line.background": "#3A444C10",
                "editor.active_line.background": "#3A444C10",
                "panel.background": "#0d0d2090",
                "title_bar.background": "#0d0d2090",
                "title_bar.inactive_background": "#0d0d2090",
                "status_bar.background": "#0d0d2090",
                "drop_target.background": "#0d0d2090",
                "elevated_surface.background": "#0d0d20",
                "toolbar.background": "#0d0d2090",
                "tab_bar.background": "#0d0d2090",
                "tab.inactive_background": "#0d0d2090",
                "tab.active_background": "#3A444C30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0d0d20",
                "scrollbar.thumb.background": "#3A444C",
                "editor.gutter.background": "#0d0d2090",
                "terminal.background": "#0d0d2010",
                "terminal.foreground": "#c2c2c7",
                "terminal.dim_foreground": "#c2c2c7",
                "terminal.bright_foreground": "#c2c2c7",
                "terminal.ansi.black": "#0d0d20",
                "terminal.ansi.red": "#3A444C",
                "terminal.ansi.green": "#595B5C",
                "terminal.ansi.yellow": "#A14C32",
                "terminal.ansi.blue": "#B55335",
                "terminal.ansi.magenta": "#6E817F",
                "terminal.ansi.cyan": "#E6A15B",
                "terminal.ansi.white": "#c2c2c7",
                "terminal.ansi.bright_black": "#5d5d71",
                "terminal.ansi.bright_red": "#3A444C",
                "terminal.ansi.bright_green": "#595B5C",
                "terminal.ansi.bright_yellow": "#A14C32",
                "terminal.ansi.bright_blue": "#B55335",
                "terminal.ansi.bright_magenta": "#6E817F",
                "terminal.ansi.bright_cyan": "#E6A15B",
                "terminal.ansi.bright_white": "#c2c2c7",
                "modified": "#3A444C",
                "syntax": {
                    "attribute": {
                        "color": "#3A444C"
                    },
                    "boolean": {
                      "color": "#595B5C"
                    },
                    "comment": {
                      "color": "#5d5d71"
                    },
                    "comment.doc": {
                      "color": "#5d5d71"
                    },
                    "constant": {
                      "color": "#595B5C"
                    },
                    "function": {
                      "color": "#E6A15B"
                    },
                    "keyword": {
                      "color": "#B55335"
                    },
                    "number": {
                      "color": "#6E817F"
                    },
                    "operator": {
                      "color": "#B55335"
                    },
                    "string": {
                      "color": "#3A444C"
                    },
                    "variable": {
                      "color": "#595B5C"
                    }
                },
                "players": [
                  {
                    "cursor": "#3A444C",
                    "background": "#0d0d20",
                    "selection": "#3A444C30"
                  }
                ]
            }
        }
    ]
}
