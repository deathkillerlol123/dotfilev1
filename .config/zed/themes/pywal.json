{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#15131090",
                "editor.background": "#15131090",
                "editor.foreground": "#c4c4c3",
                "text": "#c4c4c3",
                "text.muted": "#c4c4c370",
                "text.ignored": "#c4c4c340",
                "text.placeholder": "#c4c4c350",
                "ignored": "#c4c4c330",
                "element.hover": "#c4c4c330",
                "ghost_element.hover": "#5177C330",
                "ghost_element.selected": "#5177C330",
                "ghost_element.active": "#5177C360",
                "border": "#151310",
                "editor.highlighted_line.background": "#5177C310",
                "editor.active_line.background": "#5177C310",
                "panel.background": "#15131090",
                "title_bar.background": "#15131090",
                "title_bar.inactive_background": "#15131090",
                "status_bar.background": "#15131090",
                "drop_target.background": "#15131090",
                "elevated_surface.background": "#151310",
                "toolbar.background": "#15131090",
                "tab_bar.background": "#15131090",
                "tab.inactive_background": "#15131090",
                "tab.active_background": "#5177C330",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#151310",
                "scrollbar.thumb.background": "#5177C3",
                "editor.gutter.background": "#15131090",
                "terminal.background": "#15131010",
                "terminal.foreground": "#c4c4c3",
                "terminal.dim_foreground": "#c4c4c3",
                "terminal.bright_foreground": "#c4c4c3",
                "terminal.ansi.black": "#151310",
                "terminal.ansi.red": "#5177C3",
                "terminal.ansi.green": "#6992AE",
                "terminal.ansi.yellow": "#6B9CC4",
                "terminal.ansi.blue": "#7AB0DB",
                "terminal.ansi.magenta": "#7EB8E3",
                "terminal.ansi.cyan": "#83B5D3",
                "terminal.ansi.white": "#c4c4c3",
                "terminal.ansi.bright_black": "#6e675a",
                "terminal.ansi.bright_red": "#5177C3",
                "terminal.ansi.bright_green": "#6992AE",
                "terminal.ansi.bright_yellow": "#6B9CC4",
                "terminal.ansi.bright_blue": "#7AB0DB",
                "terminal.ansi.bright_magenta": "#7EB8E3",
                "terminal.ansi.bright_cyan": "#83B5D3",
                "terminal.ansi.bright_white": "#c4c4c3",
                "modified": "#5177C3",
                "syntax": {
                    "attribute": {
                        "color": "#5177C3"
                    },
                    "boolean": {
                      "color": "#6992AE"
                    },
                    "comment": {
                      "color": "#6e675a"
                    },
                    "comment.doc": {
                      "color": "#6e675a"
                    },
                    "constant": {
                      "color": "#6992AE"
                    },
                    "function": {
                      "color": "#83B5D3"
                    },
                    "keyword": {
                      "color": "#7AB0DB"
                    },
                    "number": {
                      "color": "#7EB8E3"
                    },
                    "operator": {
                      "color": "#7AB0DB"
                    },
                    "string": {
                      "color": "#5177C3"
                    },
                    "variable": {
                      "color": "#6992AE"
                    }
                },
                "players": [
                  {
                    "cursor": "#5177C3",
                    "background": "#151310",
                    "selection": "#5177C330"
                  }
                ]
            }
        }
    ]
}
