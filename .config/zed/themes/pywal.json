{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0d0d1f90",
                "editor.background": "#0d0d1f90",
                "editor.foreground": "#c2c2c7",
                "text": "#c2c2c7",
                "text.muted": "#c2c2c770",
                "text.ignored": "#c2c2c740",
                "text.placeholder": "#c2c2c750",
                "ignored": "#c2c2c730",
                "element.hover": "#c2c2c730",
                "ghost_element.hover": "#A9677230",
                "ghost_element.selected": "#A9677230",
                "ghost_element.active": "#A9677260",
                "border": "#0d0d1f",
                "editor.highlighted_line.background": "#A9677210",
                "editor.active_line.background": "#A9677210",
                "panel.background": "#0d0d1f90",
                "title_bar.background": "#0d0d1f90",
                "title_bar.inactive_background": "#0d0d1f90",
                "status_bar.background": "#0d0d1f90",
                "drop_target.background": "#0d0d1f90",
                "elevated_surface.background": "#0d0d1f",
                "toolbar.background": "#0d0d1f90",
                "tab_bar.background": "#0d0d1f90",
                "tab.inactive_background": "#0d0d1f90",
                "tab.active_background": "#A9677230",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0d0d1f",
                "scrollbar.thumb.background": "#A96772",
                "editor.gutter.background": "#0d0d1f90",
                "terminal.background": "#0d0d1f10",
                "terminal.foreground": "#c2c2c7",
                "terminal.dim_foreground": "#c2c2c7",
                "terminal.bright_foreground": "#c2c2c7",
                "terminal.ansi.black": "#0d0d1f",
                "terminal.ansi.red": "#A96772",
                "terminal.ansi.green": "#F3975F",
                "terminal.ansi.yellow": "#FE9E64",
                "terminal.ansi.blue": "#DC6B81",
                "terminal.ansi.magenta": "#F7768E",
                "terminal.ansi.cyan": "#A78ADD",
                "terminal.ansi.white": "#c2c2c7",
                "terminal.ansi.bright_black": "#5c5c71",
                "terminal.ansi.bright_red": "#A96772",
                "terminal.ansi.bright_green": "#F3975F",
                "terminal.ansi.bright_yellow": "#FE9E64",
                "terminal.ansi.bright_blue": "#DC6B81",
                "terminal.ansi.bright_magenta": "#F7768E",
                "terminal.ansi.bright_cyan": "#A78ADD",
                "terminal.ansi.bright_white": "#c2c2c7",
                "modified": "#A96772",
                "syntax": {
                    "attribute": {
                        "color": "#A96772"
                    },
                    "boolean": {
                      "color": "#F3975F"
                    },
                    "comment": {
                      "color": "#5c5c71"
                    },
                    "comment.doc": {
                      "color": "#5c5c71"
                    },
                    "constant": {
                      "color": "#F3975F"
                    },
                    "function": {
                      "color": "#A78ADD"
                    },
                    "keyword": {
                      "color": "#DC6B81"
                    },
                    "number": {
                      "color": "#F7768E"
                    },
                    "operator": {
                      "color": "#DC6B81"
                    },
                    "string": {
                      "color": "#A96772"
                    },
                    "variable": {
                      "color": "#F3975F"
                    }
                },
                "players": [
                  {
                    "cursor": "#A96772",
                    "background": "#0d0d1f",
                    "selection": "#A9677230"
                  }
                ]
            }
        }
    ]
}
