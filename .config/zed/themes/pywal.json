{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0f0e2190",
                "editor.background": "#0f0e2190",
                "editor.foreground": "#c3c2c7",
                "text": "#c3c2c7",
                "text.muted": "#c3c2c770",
                "text.ignored": "#c3c2c740",
                "text.placeholder": "#c3c2c750",
                "ignored": "#c3c2c730",
                "element.hover": "#c3c2c730",
                "ghost_element.hover": "#33447730",
                "ghost_element.selected": "#33447730",
                "ghost_element.active": "#33447760",
                "border": "#0f0e21",
                "editor.highlighted_line.background": "#33447710",
                "editor.active_line.background": "#33447710",
                "panel.background": "#0f0e2190",
                "title_bar.background": "#0f0e2190",
                "title_bar.inactive_background": "#0f0e2190",
                "status_bar.background": "#0f0e2190",
                "drop_target.background": "#0f0e2190",
                "elevated_surface.background": "#0f0e21",
                "toolbar.background": "#0f0e2190",
                "tab_bar.background": "#0f0e2190",
                "tab.inactive_background": "#0f0e2190",
                "tab.active_background": "#33447730",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0f0e21",
                "scrollbar.thumb.background": "#334477",
                "editor.gutter.background": "#0f0e2190",
                "terminal.background": "#0f0e2110",
                "terminal.foreground": "#c3c2c7",
                "terminal.dim_foreground": "#c3c2c7",
                "terminal.bright_foreground": "#c3c2c7",
                "terminal.ansi.black": "#0f0e21",
                "terminal.ansi.red": "#334477",
                "terminal.ansi.green": "#CA594C",
                "terminal.ansi.yellow": "#F89573",
                "terminal.ansi.blue": "#2C3F83",
                "terminal.ansi.magenta": "#374A87",
                "terminal.ansi.cyan": "#59619C",
                "terminal.ansi.white": "#c3c2c7",
                "terminal.ansi.bright_black": "#5f5d72",
                "terminal.ansi.bright_red": "#334477",
                "terminal.ansi.bright_green": "#CA594C",
                "terminal.ansi.bright_yellow": "#F89573",
                "terminal.ansi.bright_blue": "#2C3F83",
                "terminal.ansi.bright_magenta": "#374A87",
                "terminal.ansi.bright_cyan": "#59619C",
                "terminal.ansi.bright_white": "#c3c2c7",
                "modified": "#334477",
                "syntax": {
                    "attribute": {
                        "color": "#334477"
                    },
                    "boolean": {
                      "color": "#CA594C"
                    },
                    "comment": {
                      "color": "#5f5d72"
                    },
                    "comment.doc": {
                      "color": "#5f5d72"
                    },
                    "constant": {
                      "color": "#CA594C"
                    },
                    "function": {
                      "color": "#59619C"
                    },
                    "keyword": {
                      "color": "#2C3F83"
                    },
                    "number": {
                      "color": "#374A87"
                    },
                    "operator": {
                      "color": "#2C3F83"
                    },
                    "string": {
                      "color": "#334477"
                    },
                    "variable": {
                      "color": "#CA594C"
                    }
                },
                "players": [
                  {
                    "cursor": "#334477",
                    "background": "#0f0e21",
                    "selection": "#33447730"
                  }
                ]
            }
        }
    ]
}
