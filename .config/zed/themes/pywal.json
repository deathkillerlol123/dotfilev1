{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0b0d1990",
                "editor.background": "#0b0d1990",
                "editor.foreground": "#c2c2c5",
                "text": "#c2c2c5",
                "text.muted": "#c2c2c570",
                "text.ignored": "#c2c2c540",
                "text.placeholder": "#c2c2c550",
                "ignored": "#c2c2c530",
                "element.hover": "#c2c2c530",
                "ghost_element.hover": "#9E647130",
                "ghost_element.selected": "#9E647130",
                "ghost_element.active": "#9E647160",
                "border": "#0b0d19",
                "editor.highlighted_line.background": "#9E647110",
                "editor.active_line.background": "#9E647110",
                "panel.background": "#0b0d1990",
                "title_bar.background": "#0b0d1990",
                "title_bar.inactive_background": "#0b0d1990",
                "status_bar.background": "#0b0d1990",
                "drop_target.background": "#0b0d1990",
                "elevated_surface.background": "#0b0d19",
                "toolbar.background": "#0b0d1990",
                "tab_bar.background": "#0b0d1990",
                "tab.inactive_background": "#0b0d1990",
                "tab.active_background": "#9E647130",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0b0d19",
                "scrollbar.thumb.background": "#9E6471",
                "editor.gutter.background": "#0b0d1990",
                "terminal.background": "#0b0d1910",
                "terminal.foreground": "#c2c2c5",
                "terminal.dim_foreground": "#c2c2c5",
                "terminal.bright_foreground": "#c2c2c5",
                "terminal.ansi.black": "#0b0d19",
                "terminal.ansi.red": "#9E6471",
                "terminal.ansi.green": "#16308F",
                "terminal.ansi.yellow": "#1F37A5",
                "terminal.ansi.blue": "#294CAA",
                "terminal.ansi.magenta": "#495AB9",
                "terminal.ansi.cyan": "#2B54C9",
                "terminal.ansi.white": "#c2c2c5",
                "terminal.ansi.bright_black": "#5a5c6e",
                "terminal.ansi.bright_red": "#9E6471",
                "terminal.ansi.bright_green": "#16308F",
                "terminal.ansi.bright_yellow": "#1F37A5",
                "terminal.ansi.bright_blue": "#294CAA",
                "terminal.ansi.bright_magenta": "#495AB9",
                "terminal.ansi.bright_cyan": "#2B54C9",
                "terminal.ansi.bright_white": "#c2c2c5",
                "modified": "#9E6471",
                "syntax": {
                    "attribute": {
                        "color": "#9E6471"
                    },
                    "boolean": {
                      "color": "#16308F"
                    },
                    "comment": {
                      "color": "#5a5c6e"
                    },
                    "comment.doc": {
                      "color": "#5a5c6e"
                    },
                    "constant": {
                      "color": "#16308F"
                    },
                    "function": {
                      "color": "#2B54C9"
                    },
                    "keyword": {
                      "color": "#294CAA"
                    },
                    "number": {
                      "color": "#495AB9"
                    },
                    "operator": {
                      "color": "#294CAA"
                    },
                    "string": {
                      "color": "#9E6471"
                    },
                    "variable": {
                      "color": "#16308F"
                    }
                },
                "players": [
                  {
                    "cursor": "#9E6471",
                    "background": "#0b0d19",
                    "selection": "#9E647130"
                  }
                ]
            }
        }
    ]
}
