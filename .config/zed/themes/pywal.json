{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0a191990",
                "editor.background": "#0a191990",
                "editor.foreground": "#c1c5c5",
                "text": "#c1c5c5",
                "text.muted": "#c1c5c570",
                "text.ignored": "#c1c5c540",
                "text.placeholder": "#c1c5c550",
                "ignored": "#c1c5c530",
                "element.hover": "#c1c5c530",
                "ghost_element.hover": "#C38D3D30",
                "ghost_element.selected": "#C38D3D30",
                "ghost_element.active": "#C38D3D60",
                "border": "#0a1919",
                "editor.highlighted_line.background": "#C38D3D10",
                "editor.active_line.background": "#C38D3D10",
                "panel.background": "#0a191990",
                "title_bar.background": "#0a191990",
                "title_bar.inactive_background": "#0a191990",
                "status_bar.background": "#0a191990",
                "drop_target.background": "#0a191990",
                "elevated_surface.background": "#0a1919",
                "toolbar.background": "#0a191990",
                "tab_bar.background": "#0a191990",
                "tab.inactive_background": "#0a191990",
                "tab.active_background": "#C38D3D30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0a1919",
                "scrollbar.thumb.background": "#C38D3D",
                "editor.gutter.background": "#0a191990",
                "terminal.background": "#0a191910",
                "terminal.foreground": "#c1c5c5",
                "terminal.dim_foreground": "#c1c5c5",
                "terminal.bright_foreground": "#c1c5c5",
                "terminal.ansi.black": "#0a1919",
                "terminal.ansi.red": "#C38D3D",
                "terminal.ansi.green": "#B48953",
                "terminal.ansi.yellow": "#A59263",
                "terminal.ansi.blue": "#CB954D",
                "terminal.ansi.magenta": "#E2AE57",
                "terminal.ansi.cyan": "#F9D367",
                "terminal.ansi.white": "#c1c5c5",
                "terminal.ansi.bright_black": "#596e6e",
                "terminal.ansi.bright_red": "#C38D3D",
                "terminal.ansi.bright_green": "#B48953",
                "terminal.ansi.bright_yellow": "#A59263",
                "terminal.ansi.bright_blue": "#CB954D",
                "terminal.ansi.bright_magenta": "#E2AE57",
                "terminal.ansi.bright_cyan": "#F9D367",
                "terminal.ansi.bright_white": "#c1c5c5",
                "modified": "#C38D3D",
                "syntax": {
                    "attribute": {
                        "color": "#C38D3D"
                    },
                    "boolean": {
                      "color": "#B48953"
                    },
                    "comment": {
                      "color": "#596e6e"
                    },
                    "comment.doc": {
                      "color": "#596e6e"
                    },
                    "constant": {
                      "color": "#B48953"
                    },
                    "function": {
                      "color": "#F9D367"
                    },
                    "keyword": {
                      "color": "#CB954D"
                    },
                    "number": {
                      "color": "#E2AE57"
                    },
                    "operator": {
                      "color": "#CB954D"
                    },
                    "string": {
                      "color": "#C38D3D"
                    },
                    "variable": {
                      "color": "#B48953"
                    }
                },
                "players": [
                  {
                    "cursor": "#C38D3D",
                    "background": "#0a1919",
                    "selection": "#C38D3D30"
                  }
                ]
            }
        }
    ]
}
