{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0b111b90",
                "editor.background": "#0b111b90",
                "editor.foreground": "#c2c3c6",
                "text": "#c2c3c6",
                "text.muted": "#c2c3c670",
                "text.ignored": "#c2c3c640",
                "text.placeholder": "#c2c3c650",
                "ignored": "#c2c3c630",
                "element.hover": "#c2c3c630",
                "ghost_element.hover": "#54586130",
                "ghost_element.selected": "#54586130",
                "ghost_element.active": "#54586160",
                "border": "#0b111b",
                "editor.highlighted_line.background": "#54586110",
                "editor.active_line.background": "#54586110",
                "panel.background": "#0b111b90",
                "title_bar.background": "#0b111b90",
                "title_bar.inactive_background": "#0b111b90",
                "status_bar.background": "#0b111b90",
                "drop_target.background": "#0b111b90",
                "elevated_surface.background": "#0b111b",
                "toolbar.background": "#0b111b90",
                "tab_bar.background": "#0b111b90",
                "tab.inactive_background": "#0b111b90",
                "tab.active_background": "#54586130",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0b111b",
                "scrollbar.thumb.background": "#545861",
                "editor.gutter.background": "#0b111b90",
                "terminal.background": "#0b111b10",
                "terminal.foreground": "#c2c3c6",
                "terminal.dim_foreground": "#c2c3c6",
                "terminal.bright_foreground": "#c2c3c6",
                "terminal.ansi.black": "#0b111b",
                "terminal.ansi.red": "#545861",
                "terminal.ansi.green": "#843E45",
                "terminal.ansi.yellow": "#9E555B",
                "terminal.ansi.blue": "#DB5F65",
                "terminal.ansi.magenta": "#838A7A",
                "terminal.ansi.cyan": "#709E8E",
                "terminal.ansi.white": "#c2c3c6",
                "terminal.ansi.bright_black": "#5a626f",
                "terminal.ansi.bright_red": "#545861",
                "terminal.ansi.bright_green": "#843E45",
                "terminal.ansi.bright_yellow": "#9E555B",
                "terminal.ansi.bright_blue": "#DB5F65",
                "terminal.ansi.bright_magenta": "#838A7A",
                "terminal.ansi.bright_cyan": "#709E8E",
                "terminal.ansi.bright_white": "#c2c3c6",
                "modified": "#545861",
                "syntax": {
                    "attribute": {
                        "color": "#545861"
                    },
                    "boolean": {
                      "color": "#843E45"
                    },
                    "comment": {
                      "color": "#5a626f"
                    },
                    "comment.doc": {
                      "color": "#5a626f"
                    },
                    "constant": {
                      "color": "#843E45"
                    },
                    "function": {
                      "color": "#709E8E"
                    },
                    "keyword": {
                      "color": "#DB5F65"
                    },
                    "number": {
                      "color": "#838A7A"
                    },
                    "operator": {
                      "color": "#DB5F65"
                    },
                    "string": {
                      "color": "#545861"
                    },
                    "variable": {
                      "color": "#843E45"
                    }
                },
                "players": [
                  {
                    "cursor": "#545861",
                    "background": "#0b111b",
                    "selection": "#54586130"
                  }
                ]
            }
        }
    ]
}
