{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#11091690",
                "editor.background": "#11091690",
                "editor.foreground": "#c3c1c4",
                "text": "#c3c1c4",
                "text.muted": "#c3c1c470",
                "text.ignored": "#c3c1c440",
                "text.placeholder": "#c3c1c450",
                "ignored": "#c3c1c430",
                "element.hover": "#c3c1c430",
                "ghost_element.hover": "#2F2E8F30",
                "ghost_element.selected": "#2F2E8F30",
                "ghost_element.active": "#2F2E8F60",
                "border": "#110916",
                "editor.highlighted_line.background": "#2F2E8F10",
                "editor.active_line.background": "#2F2E8F10",
                "panel.background": "#11091690",
                "title_bar.background": "#11091690",
                "title_bar.inactive_background": "#11091690",
                "status_bar.background": "#11091690",
                "drop_target.background": "#11091690",
                "elevated_surface.background": "#110916",
                "toolbar.background": "#11091690",
                "tab_bar.background": "#11091690",
                "tab.inactive_background": "#11091690",
                "tab.active_background": "#2F2E8F30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#110916",
                "scrollbar.thumb.background": "#2F2E8F",
                "editor.gutter.background": "#11091690",
                "terminal.background": "#11091610",
                "terminal.foreground": "#c3c1c4",
                "terminal.dim_foreground": "#c3c1c4",
                "terminal.bright_foreground": "#c3c1c4",
                "terminal.ansi.black": "#110916",
                "terminal.ansi.red": "#2F2E8F",
                "terminal.ansi.green": "#31359F",
                "terminal.ansi.yellow": "#5C2C94",
                "terminal.ansi.blue": "#2849B0",
                "terminal.ansi.magenta": "#2167D4",
                "terminal.ansi.cyan": "#615AC1",
                "terminal.ansi.white": "#c3c1c4",
                "terminal.ansi.bright_black": "#65596c",
                "terminal.ansi.bright_red": "#2F2E8F",
                "terminal.ansi.bright_green": "#31359F",
                "terminal.ansi.bright_yellow": "#5C2C94",
                "terminal.ansi.bright_blue": "#2849B0",
                "terminal.ansi.bright_magenta": "#2167D4",
                "terminal.ansi.bright_cyan": "#615AC1",
                "terminal.ansi.bright_white": "#c3c1c4",
                "modified": "#2F2E8F",
                "syntax": {
                    "attribute": {
                        "color": "#2F2E8F"
                    },
                    "boolean": {
                      "color": "#31359F"
                    },
                    "comment": {
                      "color": "#65596c"
                    },
                    "comment.doc": {
                      "color": "#65596c"
                    },
                    "constant": {
                      "color": "#31359F"
                    },
                    "function": {
                      "color": "#615AC1"
                    },
                    "keyword": {
                      "color": "#2849B0"
                    },
                    "number": {
                      "color": "#2167D4"
                    },
                    "operator": {
                      "color": "#2849B0"
                    },
                    "string": {
                      "color": "#2F2E8F"
                    },
                    "variable": {
                      "color": "#31359F"
                    }
                },
                "players": [
                  {
                    "cursor": "#2F2E8F",
                    "background": "#110916",
                    "selection": "#2F2E8F30"
                  }
                ]
            }
        }
    ]
}
