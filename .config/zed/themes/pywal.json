{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0b0d1990",
                "editor.background": "#0b0d1990",
                "editor.foreground": "#c2c2c5",
                "text": "#c2c2c5",
                "text.muted": "#c2c2c570",
                "text.ignored": "#c2c2c540",
                "text.placeholder": "#c2c2c550",
                "ignored": "#c2c2c530",
                "element.hover": "#c2c2c530",
                "ghost_element.hover": "#86807930",
                "ghost_element.selected": "#86807930",
                "ghost_element.active": "#86807960",
                "border": "#0b0d19",
                "editor.highlighted_line.background": "#86807910",
                "editor.active_line.background": "#86807910",
                "panel.background": "#0b0d1990",
                "title_bar.background": "#0b0d1990",
                "title_bar.inactive_background": "#0b0d1990",
                "status_bar.background": "#0b0d1990",
                "drop_target.background": "#0b0d1990",
                "elevated_surface.background": "#0b0d19",
                "toolbar.background": "#0b0d1990",
                "tab_bar.background": "#0b0d1990",
                "tab.inactive_background": "#0b0d1990",
                "tab.active_background": "#86807930",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0b0d19",
                "scrollbar.thumb.background": "#868079",
                "editor.gutter.background": "#0b0d1990",
                "terminal.background": "#0b0d1910",
                "terminal.foreground": "#c2c2c5",
                "terminal.dim_foreground": "#c2c2c5",
                "terminal.bright_foreground": "#c2c2c5",
                "terminal.ansi.black": "#0b0d19",
                "terminal.ansi.red": "#868079",
                "terminal.ansi.green": "#033689",
                "terminal.ansi.yellow": "#085B9A",
                "terminal.ansi.blue": "#3D739F",
                "terminal.ansi.magenta": "#1791B1",
                "terminal.ansi.cyan": "#46AFC4",
                "terminal.ansi.white": "#c2c2c5",
                "terminal.ansi.bright_black": "#5a5c6e",
                "terminal.ansi.bright_red": "#868079",
                "terminal.ansi.bright_green": "#033689",
                "terminal.ansi.bright_yellow": "#085B9A",
                "terminal.ansi.bright_blue": "#3D739F",
                "terminal.ansi.bright_magenta": "#1791B1",
                "terminal.ansi.bright_cyan": "#46AFC4",
                "terminal.ansi.bright_white": "#c2c2c5",
                "modified": "#868079",
                "syntax": {
                    "attribute": {
                        "color": "#868079"
                    },
                    "boolean": {
                      "color": "#033689"
                    },
                    "comment": {
                      "color": "#5a5c6e"
                    },
                    "comment.doc": {
                      "color": "#5a5c6e"
                    },
                    "constant": {
                      "color": "#033689"
                    },
                    "function": {
                      "color": "#46AFC4"
                    },
                    "keyword": {
                      "color": "#3D739F"
                    },
                    "number": {
                      "color": "#1791B1"
                    },
                    "operator": {
                      "color": "#3D739F"
                    },
                    "string": {
                      "color": "#868079"
                    },
                    "variable": {
                      "color": "#033689"
                    }
                },
                "players": [
                  {
                    "cursor": "#868079",
                    "background": "#0b0d19",
                    "selection": "#86807930"
                  }
                ]
            }
        }
    ]
}
