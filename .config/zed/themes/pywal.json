{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0a0a1790",
                "editor.background": "#0a0a1790",
                "editor.foreground": "#c1c1c5",
                "text": "#c1c1c5",
                "text.muted": "#c1c1c570",
                "text.ignored": "#c1c1c540",
                "text.placeholder": "#c1c1c550",
                "ignored": "#c1c1c530",
                "element.hover": "#c1c1c530",
                "ghost_element.hover": "#38468D30",
                "ghost_element.selected": "#38468D30",
                "ghost_element.active": "#38468D60",
                "border": "#0a0a17",
                "editor.highlighted_line.background": "#38468D10",
                "editor.active_line.background": "#38468D10",
                "panel.background": "#0a0a1790",
                "title_bar.background": "#0a0a1790",
                "title_bar.inactive_background": "#0a0a1790",
                "status_bar.background": "#0a0a1790",
                "drop_target.background": "#0a0a1790",
                "elevated_surface.background": "#0a0a17",
                "toolbar.background": "#0a0a1790",
                "tab_bar.background": "#0a0a1790",
                "tab.inactive_background": "#0a0a1790",
                "tab.active_background": "#38468D30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0a0a17",
                "scrollbar.thumb.background": "#38468D",
                "editor.gutter.background": "#0a0a1790",
                "terminal.background": "#0a0a1710",
                "terminal.foreground": "#c1c1c5",
                "terminal.dim_foreground": "#c1c1c5",
                "terminal.bright_foreground": "#c1c1c5",
                "terminal.ansi.black": "#0a0a17",
                "terminal.ansi.red": "#38468D",
                "terminal.ansi.green": "#384BAC",
                "terminal.ansi.yellow": "#3454AC",
                "terminal.ansi.blue": "#5055A0",
                "terminal.ansi.magenta": "#BF63BA",
                "terminal.ansi.cyan": "#50BEEA",
                "terminal.ansi.white": "#c1c1c5",
                "terminal.ansi.bright_black": "#59596d",
                "terminal.ansi.bright_red": "#38468D",
                "terminal.ansi.bright_green": "#384BAC",
                "terminal.ansi.bright_yellow": "#3454AC",
                "terminal.ansi.bright_blue": "#5055A0",
                "terminal.ansi.bright_magenta": "#BF63BA",
                "terminal.ansi.bright_cyan": "#50BEEA",
                "terminal.ansi.bright_white": "#c1c1c5",
                "modified": "#38468D",
                "syntax": {
                    "attribute": {
                        "color": "#38468D"
                    },
                    "boolean": {
                      "color": "#384BAC"
                    },
                    "comment": {
                      "color": "#59596d"
                    },
                    "comment.doc": {
                      "color": "#59596d"
                    },
                    "constant": {
                      "color": "#384BAC"
                    },
                    "function": {
                      "color": "#50BEEA"
                    },
                    "keyword": {
                      "color": "#5055A0"
                    },
                    "number": {
                      "color": "#BF63BA"
                    },
                    "operator": {
                      "color": "#5055A0"
                    },
                    "string": {
                      "color": "#38468D"
                    },
                    "variable": {
                      "color": "#384BAC"
                    }
                },
                "players": [
                  {
                    "cursor": "#38468D",
                    "background": "#0a0a17",
                    "selection": "#38468D30"
                  }
                ]
            }
        }
    ]
}
