{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0b071190",
                "editor.background": "#0b071190",
                "editor.foreground": "#c2c1c3",
                "text": "#c2c1c3",
                "text.muted": "#c2c1c370",
                "text.ignored": "#c2c1c340",
                "text.placeholder": "#c2c1c350",
                "ignored": "#c2c1c330",
                "element.hover": "#c2c1c330",
                "ghost_element.hover": "#3D02BD30",
                "ghost_element.selected": "#3D02BD30",
                "ghost_element.active": "#3D02BD60",
                "border": "#0b0711",
                "editor.highlighted_line.background": "#3D02BD10",
                "editor.active_line.background": "#3D02BD10",
                "panel.background": "#0b071190",
                "title_bar.background": "#0b071190",
                "title_bar.inactive_background": "#0b071190",
                "status_bar.background": "#0b071190",
                "drop_target.background": "#0b071190",
                "elevated_surface.background": "#0b0711",
                "toolbar.background": "#0b071190",
                "tab_bar.background": "#0b071190",
                "tab.inactive_background": "#0b071190",
                "tab.active_background": "#3D02BD30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0b0711",
                "scrollbar.thumb.background": "#3D02BD",
                "editor.gutter.background": "#0b071190",
                "terminal.background": "#0b071110",
                "terminal.foreground": "#c2c1c3",
                "terminal.dim_foreground": "#c2c1c3",
                "terminal.bright_foreground": "#c2c1c3",
                "terminal.ansi.black": "#0b0711",
                "terminal.ansi.red": "#3D02BD",
                "terminal.ansi.green": "#4D0EB5",
                "terminal.ansi.yellow": "#6B2CA7",
                "terminal.ansi.blue": "#5C07D7",
                "terminal.ansi.magenta": "#5321C4",
                "terminal.ansi.cyan": "#9B5591",
                "terminal.ansi.white": "#c2c1c3",
                "terminal.ansi.bright_black": "#5f566a",
                "terminal.ansi.bright_red": "#3D02BD",
                "terminal.ansi.bright_green": "#4D0EB5",
                "terminal.ansi.bright_yellow": "#6B2CA7",
                "terminal.ansi.bright_blue": "#5C07D7",
                "terminal.ansi.bright_magenta": "#5321C4",
                "terminal.ansi.bright_cyan": "#9B5591",
                "terminal.ansi.bright_white": "#c2c1c3",
                "modified": "#3D02BD",
                "syntax": {
                    "attribute": {
                        "color": "#3D02BD"
                    },
                    "boolean": {
                      "color": "#4D0EB5"
                    },
                    "comment": {
                      "color": "#5f566a"
                    },
                    "comment.doc": {
                      "color": "#5f566a"
                    },
                    "constant": {
                      "color": "#4D0EB5"
                    },
                    "function": {
                      "color": "#9B5591"
                    },
                    "keyword": {
                      "color": "#5C07D7"
                    },
                    "number": {
                      "color": "#5321C4"
                    },
                    "operator": {
                      "color": "#5C07D7"
                    },
                    "string": {
                      "color": "#3D02BD"
                    },
                    "variable": {
                      "color": "#4D0EB5"
                    }
                },
                "players": [
                  {
                    "cursor": "#3D02BD",
                    "background": "#0b0711",
                    "selection": "#3D02BD30"
                  }
                ]
            }
        }
    ]
}
