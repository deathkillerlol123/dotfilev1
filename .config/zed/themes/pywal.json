{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0f192490",
                "editor.background": "#0f192490",
                "editor.foreground": "#c3c5c8",
                "text": "#c3c5c8",
                "text.muted": "#c3c5c870",
                "text.ignored": "#c3c5c840",
                "text.placeholder": "#c3c5c850",
                "ignored": "#c3c5c830",
                "element.hover": "#c3c5c830",
                "ghost_element.hover": "#49536430",
                "ghost_element.selected": "#49536430",
                "ghost_element.active": "#49536460",
                "border": "#0f1924",
                "editor.highlighted_line.background": "#49536410",
                "editor.active_line.background": "#49536410",
                "panel.background": "#0f192490",
                "title_bar.background": "#0f192490",
                "title_bar.inactive_background": "#0f192490",
                "status_bar.background": "#0f192490",
                "drop_target.background": "#0f192490",
                "elevated_surface.background": "#0f1924",
                "toolbar.background": "#0f192490",
                "tab_bar.background": "#0f192490",
                "tab.inactive_background": "#0f192490",
                "tab.active_background": "#49536430",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0f1924",
                "scrollbar.thumb.background": "#495364",
                "editor.gutter.background": "#0f192490",
                "terminal.background": "#0f192410",
                "terminal.foreground": "#c3c5c8",
                "terminal.dim_foreground": "#c3c5c8",
                "terminal.bright_foreground": "#c3c5c8",
                "terminal.ansi.black": "#0f1924",
                "terminal.ansi.red": "#495364",
                "terminal.ansi.green": "#823E45",
                "terminal.ansi.yellow": "#9E555D",
                "terminal.ansi.blue": "#E15F65",
                "terminal.ansi.magenta": "#D86166",
                "terminal.ansi.cyan": "#A47D94",
                "terminal.ansi.white": "#c3c5c8",
                "terminal.ansi.bright_black": "#5e6874",
                "terminal.ansi.bright_red": "#495364",
                "terminal.ansi.bright_green": "#823E45",
                "terminal.ansi.bright_yellow": "#9E555D",
                "terminal.ansi.bright_blue": "#E15F65",
                "terminal.ansi.bright_magenta": "#D86166",
                "terminal.ansi.bright_cyan": "#A47D94",
                "terminal.ansi.bright_white": "#c3c5c8",
                "modified": "#495364",
                "syntax": {
                    "attribute": {
                        "color": "#495364"
                    },
                    "boolean": {
                      "color": "#823E45"
                    },
                    "comment": {
                      "color": "#5e6874"
                    },
                    "comment.doc": {
                      "color": "#5e6874"
                    },
                    "constant": {
                      "color": "#823E45"
                    },
                    "function": {
                      "color": "#A47D94"
                    },
                    "keyword": {
                      "color": "#E15F65"
                    },
                    "number": {
                      "color": "#D86166"
                    },
                    "operator": {
                      "color": "#E15F65"
                    },
                    "string": {
                      "color": "#495364"
                    },
                    "variable": {
                      "color": "#823E45"
                    }
                },
                "players": [
                  {
                    "cursor": "#495364",
                    "background": "#0f1924",
                    "selection": "#49536430"
                  }
                ]
            }
        }
    ]
}
