{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#120b1a90",
                "editor.background": "#120b1a90",
                "editor.foreground": "#c3c2c5",
                "text": "#c3c2c5",
                "text.muted": "#c3c2c570",
                "text.ignored": "#c3c2c540",
                "text.placeholder": "#c3c2c550",
                "ignored": "#c3c2c530",
                "element.hover": "#c3c2c530",
                "ghost_element.hover": "#4F195230",
                "ghost_element.selected": "#4F195230",
                "ghost_element.active": "#4F195260",
                "border": "#120b1a",
                "editor.highlighted_line.background": "#4F195210",
                "editor.active_line.background": "#4F195210",
                "panel.background": "#120b1a90",
                "title_bar.background": "#120b1a90",
                "title_bar.inactive_background": "#120b1a90",
                "status_bar.background": "#120b1a90",
                "drop_target.background": "#120b1a90",
                "elevated_surface.background": "#120b1a",
                "toolbar.background": "#120b1a90",
                "tab_bar.background": "#120b1a90",
                "tab.inactive_background": "#120b1a90",
                "tab.active_background": "#4F195230",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#120b1a",
                "scrollbar.thumb.background": "#4F1952",
                "editor.gutter.background": "#120b1a90",
                "terminal.background": "#120b1a10",
                "terminal.foreground": "#c3c2c5",
                "terminal.dim_foreground": "#c3c2c5",
                "terminal.bright_foreground": "#c3c2c5",
                "terminal.ansi.black": "#120b1a",
                "terminal.ansi.red": "#4F1952",
                "terminal.ansi.green": "#601D65",
                "terminal.ansi.yellow": "#6B1A6B",
                "terminal.ansi.blue": "#8D2269",
                "terminal.ansi.magenta": "#76208A",
                "terminal.ansi.cyan": "#9921A1",
                "terminal.ansi.white": "#c3c2c5",
                "terminal.ansi.bright_black": "#625a6f",
                "terminal.ansi.bright_red": "#4F1952",
                "terminal.ansi.bright_green": "#601D65",
                "terminal.ansi.bright_yellow": "#6B1A6B",
                "terminal.ansi.bright_blue": "#8D2269",
                "terminal.ansi.bright_magenta": "#76208A",
                "terminal.ansi.bright_cyan": "#9921A1",
                "terminal.ansi.bright_white": "#c3c2c5",
                "modified": "#4F1952",
                "syntax": {
                    "attribute": {
                        "color": "#4F1952"
                    },
                    "boolean": {
                      "color": "#601D65"
                    },
                    "comment": {
                      "color": "#625a6f"
                    },
                    "comment.doc": {
                      "color": "#625a6f"
                    },
                    "constant": {
                      "color": "#601D65"
                    },
                    "function": {
                      "color": "#9921A1"
                    },
                    "keyword": {
                      "color": "#8D2269"
                    },
                    "number": {
                      "color": "#76208A"
                    },
                    "operator": {
                      "color": "#8D2269"
                    },
                    "string": {
                      "color": "#4F1952"
                    },
                    "variable": {
                      "color": "#601D65"
                    }
                },
                "players": [
                  {
                    "cursor": "#4F1952",
                    "background": "#120b1a",
                    "selection": "#4F195230"
                  }
                ]
            }
        }
    ]
}
