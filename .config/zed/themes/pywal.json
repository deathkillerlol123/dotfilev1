{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#2b336490",
                "editor.background": "#2b336490",
                "editor.foreground": "#caccd8",
                "text": "#caccd8",
                "text.muted": "#caccd870",
                "text.ignored": "#caccd840",
                "text.placeholder": "#caccd850",
                "ignored": "#caccd830",
                "element.hover": "#caccd830",
                "ghost_element.hover": "#514EB630",
                "ghost_element.selected": "#514EB630",
                "ghost_element.active": "#514EB660",
                "border": "#2b3364",
                "editor.highlighted_line.background": "#514EB610",
                "editor.active_line.background": "#514EB610",
                "panel.background": "#2b336490",
                "title_bar.background": "#2b336490",
                "title_bar.inactive_background": "#2b336490",
                "status_bar.background": "#2b336490",
                "drop_target.background": "#2b336490",
                "elevated_surface.background": "#2b3364",
                "toolbar.background": "#2b336490",
                "tab_bar.background": "#2b336490",
                "tab.inactive_background": "#2b336490",
                "tab.active_background": "#514EB630",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#2b3364",
                "scrollbar.thumb.background": "#514EB6",
                "editor.gutter.background": "#2b336490",
                "terminal.background": "#2b336410",
                "terminal.foreground": "#caccd8",
                "terminal.dim_foreground": "#caccd8",
                "terminal.bright_foreground": "#caccd8",
                "terminal.ansi.black": "#2b3364",
                "terminal.ansi.red": "#514EB6",
                "terminal.ansi.green": "#223BC4",
                "terminal.ansi.yellow": "#324BCD",
                "terminal.ansi.blue": "#3858E6",
                "terminal.ansi.magenta": "#5762DC",
                "terminal.ansi.cyan": "#956FCB",
                "terminal.ansi.white": "#caccd8",
                "terminal.ansi.bright_black": "#7b7e93",
                "terminal.ansi.bright_red": "#514EB6",
                "terminal.ansi.bright_green": "#223BC4",
                "terminal.ansi.bright_yellow": "#324BCD",
                "terminal.ansi.bright_blue": "#3858E6",
                "terminal.ansi.bright_magenta": "#5762DC",
                "terminal.ansi.bright_cyan": "#956FCB",
                "terminal.ansi.bright_white": "#caccd8",
                "modified": "#514EB6",
                "syntax": {
                    "attribute": {
                        "color": "#514EB6"
                    },
                    "boolean": {
                      "color": "#223BC4"
                    },
                    "comment": {
                      "color": "#7b7e93"
                    },
                    "comment.doc": {
                      "color": "#7b7e93"
                    },
                    "constant": {
                      "color": "#223BC4"
                    },
                    "function": {
                      "color": "#956FCB"
                    },
                    "keyword": {
                      "color": "#3858E6"
                    },
                    "number": {
                      "color": "#5762DC"
                    },
                    "operator": {
                      "color": "#3858E6"
                    },
                    "string": {
                      "color": "#514EB6"
                    },
                    "variable": {
                      "color": "#223BC4"
                    }
                },
                "players": [
                  {
                    "cursor": "#514EB6",
                    "background": "#2b3364",
                    "selection": "#514EB630"
                  }
                ]
            }
        }
    ]
}
