{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0c050790",
                "editor.background": "#0c050790",
                "editor.foreground": "#c2c0c1",
                "text": "#c2c0c1",
                "text.muted": "#c2c0c170",
                "text.ignored": "#c2c0c140",
                "text.placeholder": "#c2c0c150",
                "ignored": "#c2c0c130",
                "element.hover": "#c2c0c130",
                "ghost_element.hover": "#CE971E30",
                "ghost_element.selected": "#CE971E30",
                "ghost_element.active": "#CE971E60",
                "border": "#0c0507",
                "editor.highlighted_line.background": "#CE971E10",
                "editor.active_line.background": "#CE971E10",
                "panel.background": "#0c050790",
                "title_bar.background": "#0c050790",
                "title_bar.inactive_background": "#0c050790",
                "status_bar.background": "#0c050790",
                "drop_target.background": "#0c050790",
                "elevated_surface.background": "#0c0507",
                "toolbar.background": "#0c050790",
                "tab_bar.background": "#0c050790",
                "tab.inactive_background": "#0c050790",
                "tab.active_background": "#CE971E30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0c0507",
                "scrollbar.thumb.background": "#CE971E",
                "editor.gutter.background": "#0c050790",
                "terminal.background": "#0c050710",
                "terminal.foreground": "#c2c0c1",
                "terminal.dim_foreground": "#c2c0c1",
                "terminal.bright_foreground": "#c2c0c1",
                "terminal.ansi.black": "#0c0507",
                "terminal.ansi.red": "#CE971E",
                "terminal.ansi.green": "#6F21A5",
                "terminal.ansi.yellow": "#2C6995",
                "terminal.ansi.blue": "#A221C6",
                "terminal.ansi.magenta": "#CF12DB",
                "terminal.ansi.cyan": "#FA04FA",
                "terminal.ansi.white": "#c2c0c1",
                "terminal.ansi.bright_black": "#675558",
                "terminal.ansi.bright_red": "#CE971E",
                "terminal.ansi.bright_green": "#6F21A5",
                "terminal.ansi.bright_yellow": "#2C6995",
                "terminal.ansi.bright_blue": "#A221C6",
                "terminal.ansi.bright_magenta": "#CF12DB",
                "terminal.ansi.bright_cyan": "#FA04FA",
                "terminal.ansi.bright_white": "#c2c0c1",
                "modified": "#CE971E",
                "syntax": {
                    "attribute": {
                        "color": "#CE971E"
                    },
                    "boolean": {
                      "color": "#6F21A5"
                    },
                    "comment": {
                      "color": "#675558"
                    },
                    "comment.doc": {
                      "color": "#675558"
                    },
                    "constant": {
                      "color": "#6F21A5"
                    },
                    "function": {
                      "color": "#FA04FA"
                    },
                    "keyword": {
                      "color": "#A221C6"
                    },
                    "number": {
                      "color": "#CF12DB"
                    },
                    "operator": {
                      "color": "#A221C6"
                    },
                    "string": {
                      "color": "#CE971E"
                    },
                    "variable": {
                      "color": "#6F21A5"
                    }
                },
                "players": [
                  {
                    "cursor": "#CE971E",
                    "background": "#0c0507",
                    "selection": "#CE971E30"
                  }
                ]
            }
        }
    ]
}
