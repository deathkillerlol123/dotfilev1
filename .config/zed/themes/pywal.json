{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#1e0d0d90",
                "editor.background": "#1e0d0d90",
                "editor.foreground": "#c6c2c2",
                "text": "#c6c2c2",
                "text.muted": "#c6c2c270",
                "text.ignored": "#c6c2c240",
                "text.placeholder": "#c6c2c250",
                "ignored": "#c6c2c230",
                "element.hover": "#c6c2c230",
                "ghost_element.hover": "#2D50B430",
                "ghost_element.selected": "#2D50B430",
                "ghost_element.active": "#2D50B460",
                "border": "#1e0d0d",
                "editor.highlighted_line.background": "#2D50B410",
                "editor.active_line.background": "#2D50B410",
                "panel.background": "#1e0d0d90",
                "title_bar.background": "#1e0d0d90",
                "title_bar.inactive_background": "#1e0d0d90",
                "status_bar.background": "#1e0d0d90",
                "drop_target.background": "#1e0d0d90",
                "elevated_surface.background": "#1e0d0d",
                "toolbar.background": "#1e0d0d90",
                "tab_bar.background": "#1e0d0d90",
                "tab.inactive_background": "#1e0d0d90",
                "tab.active_background": "#2D50B430",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#1e0d0d",
                "scrollbar.thumb.background": "#2D50B4",
                "editor.gutter.background": "#1e0d0d90",
                "terminal.background": "#1e0d0d10",
                "terminal.foreground": "#c6c2c2",
                "terminal.dim_foreground": "#c6c2c2",
                "terminal.bright_foreground": "#c6c2c2",
                "terminal.ansi.black": "#1e0d0d",
                "terminal.ansi.red": "#2D50B4",
                "terminal.ansi.green": "#576D92",
                "terminal.ansi.yellow": "#867B83",
                "terminal.ansi.blue": "#639AC0",
                "terminal.ansi.magenta": "#6DE1F8",
                "terminal.ansi.cyan": "#97A6B6",
                "terminal.ansi.white": "#c6c2c2",
                "terminal.ansi.bright_black": "#705c5c",
                "terminal.ansi.bright_red": "#2D50B4",
                "terminal.ansi.bright_green": "#576D92",
                "terminal.ansi.bright_yellow": "#867B83",
                "terminal.ansi.bright_blue": "#639AC0",
                "terminal.ansi.bright_magenta": "#6DE1F8",
                "terminal.ansi.bright_cyan": "#97A6B6",
                "terminal.ansi.bright_white": "#c6c2c2",
                "modified": "#2D50B4",
                "syntax": {
                    "attribute": {
                        "color": "#2D50B4"
                    },
                    "boolean": {
                      "color": "#576D92"
                    },
                    "comment": {
                      "color": "#705c5c"
                    },
                    "comment.doc": {
                      "color": "#705c5c"
                    },
                    "constant": {
                      "color": "#576D92"
                    },
                    "function": {
                      "color": "#97A6B6"
                    },
                    "keyword": {
                      "color": "#639AC0"
                    },
                    "number": {
                      "color": "#6DE1F8"
                    },
                    "operator": {
                      "color": "#639AC0"
                    },
                    "string": {
                      "color": "#2D50B4"
                    },
                    "variable": {
                      "color": "#576D92"
                    }
                },
                "players": [
                  {
                    "cursor": "#2D50B4",
                    "background": "#1e0d0d",
                    "selection": "#2D50B430"
                  }
                ]
            }
        }
    ]
}
