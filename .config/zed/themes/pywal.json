{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#141e2f90",
                "editor.background": "#141e2f90",
                "editor.foreground": "#c4c6cb",
                "text": "#c4c6cb",
                "text.muted": "#c4c6cb70",
                "text.ignored": "#c4c6cb40",
                "text.placeholder": "#c4c6cb50",
                "ignored": "#c4c6cb30",
                "element.hover": "#c4c6cb30",
                "ghost_element.hover": "#39487430",
                "ghost_element.selected": "#39487430",
                "ghost_element.active": "#39487460",
                "border": "#141e2f",
                "editor.highlighted_line.background": "#39487410",
                "editor.active_line.background": "#39487410",
                "panel.background": "#141e2f90",
                "title_bar.background": "#141e2f90",
                "title_bar.inactive_background": "#141e2f90",
                "status_bar.background": "#141e2f90",
                "drop_target.background": "#141e2f90",
                "elevated_surface.background": "#141e2f",
                "toolbar.background": "#141e2f90",
                "tab_bar.background": "#141e2f90",
                "tab.inactive_background": "#141e2f90",
                "tab.active_background": "#39487430",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#141e2f",
                "scrollbar.thumb.background": "#394874",
                "editor.gutter.background": "#141e2f90",
                "terminal.background": "#141e2f10",
                "terminal.foreground": "#c4c6cb",
                "terminal.dim_foreground": "#c4c6cb",
                "terminal.bright_foreground": "#c4c6cb",
                "terminal.ansi.black": "#141e2f",
                "terminal.ansi.red": "#394874",
                "terminal.ansi.green": "#B04B55",
                "terminal.ansi.yellow": "#F6A06D",
                "terminal.ansi.blue": "#1B6396",
                "terminal.ansi.magenta": "#62638F",
                "terminal.ansi.cyan": "#A36E90",
                "terminal.ansi.white": "#c4c6cb",
                "terminal.ansi.bright_black": "#636b79",
                "terminal.ansi.bright_red": "#394874",
                "terminal.ansi.bright_green": "#B04B55",
                "terminal.ansi.bright_yellow": "#F6A06D",
                "terminal.ansi.bright_blue": "#1B6396",
                "terminal.ansi.bright_magenta": "#62638F",
                "terminal.ansi.bright_cyan": "#A36E90",
                "terminal.ansi.bright_white": "#c4c6cb",
                "modified": "#394874",
                "syntax": {
                    "attribute": {
                        "color": "#394874"
                    },
                    "boolean": {
                      "color": "#B04B55"
                    },
                    "comment": {
                      "color": "#636b79"
                    },
                    "comment.doc": {
                      "color": "#636b79"
                    },
                    "constant": {
                      "color": "#B04B55"
                    },
                    "function": {
                      "color": "#A36E90"
                    },
                    "keyword": {
                      "color": "#1B6396"
                    },
                    "number": {
                      "color": "#62638F"
                    },
                    "operator": {
                      "color": "#1B6396"
                    },
                    "string": {
                      "color": "#394874"
                    },
                    "variable": {
                      "color": "#B04B55"
                    }
                },
                "players": [
                  {
                    "cursor": "#394874",
                    "background": "#141e2f",
                    "selection": "#39487430"
                  }
                ]
            }
        }
    ]
}
