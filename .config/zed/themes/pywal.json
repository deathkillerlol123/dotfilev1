{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#09040490",
                "editor.background": "#09040490",
                "editor.foreground": "#c1c0c0",
                "text": "#c1c0c0",
                "text.muted": "#c1c0c070",
                "text.ignored": "#c1c0c040",
                "text.placeholder": "#c1c0c050",
                "ignored": "#c1c0c030",
                "element.hover": "#c1c0c030",
                "ghost_element.hover": "#642E2830",
                "ghost_element.selected": "#642E2830",
                "ghost_element.active": "#642E2860",
                "border": "#090404",
                "editor.highlighted_line.background": "#642E2810",
                "editor.active_line.background": "#642E2810",
                "panel.background": "#09040490",
                "title_bar.background": "#09040490",
                "title_bar.inactive_background": "#09040490",
                "status_bar.background": "#09040490",
                "drop_target.background": "#09040490",
                "elevated_surface.background": "#090404",
                "toolbar.background": "#09040490",
                "tab_bar.background": "#09040490",
                "tab.inactive_background": "#09040490",
                "tab.active_background": "#642E2830",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#090404",
                "scrollbar.thumb.background": "#642E28",
                "editor.gutter.background": "#09040490",
                "terminal.background": "#09040410",
                "terminal.foreground": "#c1c0c0",
                "terminal.dim_foreground": "#c1c0c0",
                "terminal.bright_foreground": "#c1c0c0",
                "terminal.ansi.black": "#090404",
                "terminal.ansi.red": "#642E28",
                "terminal.ansi.green": "#6D443E",
                "terminal.ansi.yellow": "#133551",
                "terminal.ansi.blue": "#17496C",
                "terminal.ansi.magenta": "#A14B35",
                "terminal.ansi.cyan": "#A64A36",
                "terminal.ansi.white": "#c1c0c0",
                "terminal.ansi.bright_black": "#665353",
                "terminal.ansi.bright_red": "#642E28",
                "terminal.ansi.bright_green": "#6D443E",
                "terminal.ansi.bright_yellow": "#133551",
                "terminal.ansi.bright_blue": "#17496C",
                "terminal.ansi.bright_magenta": "#A14B35",
                "terminal.ansi.bright_cyan": "#A64A36",
                "terminal.ansi.bright_white": "#c1c0c0",
                "modified": "#642E28",
                "syntax": {
                    "attribute": {
                        "color": "#642E28"
                    },
                    "boolean": {
                      "color": "#6D443E"
                    },
                    "comment": {
                      "color": "#665353"
                    },
                    "comment.doc": {
                      "color": "#665353"
                    },
                    "constant": {
                      "color": "#6D443E"
                    },
                    "function": {
                      "color": "#A64A36"
                    },
                    "keyword": {
                      "color": "#17496C"
                    },
                    "number": {
                      "color": "#A14B35"
                    },
                    "operator": {
                      "color": "#17496C"
                    },
                    "string": {
                      "color": "#642E28"
                    },
                    "variable": {
                      "color": "#6D443E"
                    }
                },
                "players": [
                  {
                    "cursor": "#642E28",
                    "background": "#090404",
                    "selection": "#642E2830"
                  }
                ]
            }
        }
    ]
}
