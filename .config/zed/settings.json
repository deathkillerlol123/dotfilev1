// documentation: https://zed.dev/docs/configuring-zed
{
  "format_on_save": "off",
  "theme": "pywal",
  "theme_overrides": {
    "Cyberpunk Scarlet Protocol":{
    },
  },
  "terminal": {
    "shell": {
      "program": "zsh"
    }
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 10
    }
  },
  "icon_theme": "VSCode Great Icons Theme",
  "when_closing_with_no_tabs": "platform_default",
  "on_last_window_closed": "quit_app",
  "session": {
    "trust_all_worktrees": true
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 15,
}
