{
  "position": "bottom",
  "height": 20,
  "start": [
    {
      "type" : "notifications",
      "show_count": true
    },
    {
      "format": [
        " {cpu_percent}% | {cpu_frequency} GHz | {temp_c@CPUTIN}°C"
      ],
      "interval": {
        "cpu": 1,
        "disks": 300,
        "memory": 30,
        "networks": 3,
        "temps": 5
      },
      "type": "sys_info"
    }   
  ],
  "center": [
    {
      "type": "music",
      "player_type": "mpris",
      "format": "{title} / {artist}",
      "truncate": "end",
      "icons": {
        "play": "",
        "pause": ""
      },
      "music_dir": "/home/nixboom/Music"
    },
    {
      "type": "clock",
      "format": "%d/%m/%Y %H:%M"
    }      
  ],
  "end": [
    {
      "type": "battery",
      "format": "{percentage}%",
      "profiles": {
        "warning": 20,
        "critical": {
          "when": { "percent":  5, "charging": false },
          "format": "[LOW] {percentage}%"
        }
      }
    },
    {
      "type": "tray"
    }
  ]
}
